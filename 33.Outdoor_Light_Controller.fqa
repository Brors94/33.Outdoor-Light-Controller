pe":"onReleased","name":"s21"},{"callback":"","eventType":"onLongPressDown","name":"s21"},{"callback":"","eventType":"onLongPressReleased","name":"s21"},{"callback":"t1","eventType":"onReleased","name":"t1"},{"callback":"","eventType":"onLongPressDown","name":"t1"},{"callback":"","eventType":"onLongPressReleased","name":"t1"},{"callback":"t2","eventType":"onReleased","name":"t2"},{"callback":"","eventType":"onLongPressDown","name":"t2"},{"callback":"","eventType":"onLongPressReleased","name":"t2"}],"quickAppVariables":[{"name":"language","type":"string","value":"en"},{"name":"roomID","type":"string","value":""},{"name":"Setup","type":"string","value":"0"},{"name":"scene1","type":"string","value":"100%"},{"name":"scene2","type":"string","value":"Dim"},{"name":"scene3","type":"string","value":"Midnight"},{"name":"scene4","type":"string","value":"Evening"},{"name":"color1","type":"string","value":"#ff9933"},{"name":"color2","type":"string","value":"#99ff33"},{"name":"color3","type":"string","value":"#990000"},{"name":"color4","type":"string","value":"#66ffff"},{"name":"scene6","type":"string","value":"Low Light"},{"name":"scene5","type":"string","value":"60%"}],"typeTemplateInitialized":true,"userDescription":"Easy Light controller \nMade by Joachim Brørs Sommerfeld, Norway\njoachim.brors.sommerfeld@gmail.com\nI am not a programer by craft/work, it is only a hobby so the code isnt perfect :D \nUse at own risk! ^^\n\nThis quickapp also uses the Eventlib made by:\neventLib©️jan@gabrielsson.com\nAnd wouldnt work without it! Thanks!"},"initialInterfaces":["quickApp"],"files":[{"name":"main","isMain":true,"isOpen":true,"content":"\n---@diagnostic disable\n\n--%%name=Outdoor Light Controller\n--%%type=com.fibaro.genericDevice\n\n--%%id=262\n--proxy=\"\"\n\n\n--%%u={label=\"unused1\",text=\"\"}\n\n\n--%%u={{switch=\"bturnoff\",text=\"turnoff\",value=\"false\",onReleased=\"turnoff\"},{switch=\"bturnon\",text=\"turnon\",value=\"false\",onReleased=\"turnon\"}}\n--%%u={{switch=\"bactivatesave11\",text=\"activatesave11\",value=\"false\",onReleased=\"activatesave11\"},{switch=\"bactivatesave22\",text=\"activatesave22\",value=\"false\",onReleased=\"activatesave22\"}}\n--%%u={{switch=\"bactivatesave33\",text=\"activatesave33\",value=\"false\",onReleased=\"activatesave33\"},{switch=\"bactivatesave44\",text=\"activatesave44\",value=\"false\",onReleased=\"activatesave44\"}}\n--%%u={{switch=\"bactivatesave55\",text=\"activatesave55\",value=\"false\",onReleased=\"activatesave55\"},{switch=\"bactivatesave66\",text=\"activatesave66\",value=\"false\",onReleased=\"activatesave66\"}}\n\n\n--%%u={label=\"info_version\",text=\"\"}\n--%%u={label=\"infoLine6\",text=\"\"}\n--%%u={label=\"info_status\",text=\"\"}\n--%%u={label=\"info_pir_enable\",text=\"info_pir_enable\"}\n--%%u={{switch=\"disable\",text=\"disable\",value=\"false\",onReleased=\"disable\"},{switch=\"enable\",text=\"enable\",value=\"false\",onReleased=\"enable\"}}\n\n\n--%%u={label=\"infoLine8\",text=\"\"}\n--%%u={label=\"info_offset_time\",text=\"info_offset_time\"}\n--%%u={{switch=\"offset_sunrise_n\",text=\"offset_sunrise_n\",value=\"false\",onReleased=\"offset_sunrise_n\",onLongPressReleased=\"offset_sunrise_n_l\"},{switch=\"offset_sunrise_p\",text=\"offset_sunrise_p\",value=\"false\",onReleased=\"offset_sunrise_p\",onLongPressReleased=\"offset_sunrise_p_l\"},{button=\"a2\",text=\"\"}}\n--%%u={{switch=\"offset_sunset_n\",text=\"offset_sunset_n\",value=\"false\",onReleased=\"offset_sunset_n\",onLongPressReleased=\"offset_sunset_n_l\"},{switch=\"offset_sunset_p\",text=\"offset_sunset_p\",value=\"false\",onReleased=\"offset_sunset_p\",onLongPressReleased=\"offset_sunset_p_l\"},{button=\"a3\",text=\"\"}}\n\n\n--%%u={label=\"infoLine1\",text=\"\"}\n--%%u={label=\"info_sensor_timer\",text=\"info_sensor_timer\"}\n--%%u={{switch=\"bsensor_timen\",text=\"sensor_timen\",value=\"false\",onReleased=\"sensor_timen\",onLongPressReleased=\"sensor_timen_l\"},{switch=\"bsensor_timep\",text=\"sensor_timep\",value=\"false\",onReleased=\"sensor_timep\",onLongPressReleased=\"sensor_timep_l\"},{button=\"button_ID_15_3\",text=\"\"}}\n--u={{switch=\"bsec_min_sensor\",text=\"sec_min_sensor\",value=\"false\",onReleased=\"sec_min_sensor\"},{button=\"button_ID_14_2\",text=\"\"}}\n\n\n--%%u={label=\"infoLine2\",text=\"\"}\n--%%u={label=\"info_pir_on\",text=\"info_pir_on\"}\n--%%u={select=\"bp1_scene_on\",text=\"Event ON\",onToggled=\"p1_scene_on\",options={}}\n--%%u={label=\"info_pir_off\",text=\"info_pir_off\"}\n--%%u={select=\"bp1_scene_off\",text=\"Event OFF\",onToggled=\"p1_scene_off\",options={}}\n\n\n\n--u={label=\"info_pir_off_delay\",text=\"info_pir_off_delay\"}\n--u={select=\"bp1_scene_off_delay\",text=\"Event OFF Delay\",onToggled=\"p1_scene_off_delay\",options={}}\n--u={label=\"info_delay_timer\",text=\"info_delay_timer\"}\n--u={{switch=\"bdelay_timen\",text=\"delay_timen\",value=\"false\",onReleased=\"delay_timen\"},{switch=\"bdelay_timep\",text=\"delay_timep\",value=\"false\",onReleased=\"delay_timep\"},{button=\"button_ID_15_4\",text=\"\"}}\n--u={{switch=\"bsec_min_delay\",text=\"sec_min_delay\",value=\"false\",onReleased=\"sec_min_delay\"},{button=\"button_ID_14_3\",text=\"\"}}\n\n\n\n\n--%%u={label=\"infoLine3\",text=\"\"}\n--%%u={multi=\"select_light_setup\",text=\"Light List\",onToggled=\"select_light_setup\",options={}}\n--%%u={{switch=\"save_light\",text=\"save_light\",value=\"false\",onReleased=\"save_light\"}}\n--%%u={label=\"info_selectlight\",text=\"info_selectlight\"}\n\n\n--%%u={label=\"infoLine4\",text=\" \"}\n--%%u={{switch=\"save1\",text=\"save1\",value=\"false\",onLongPressReleased=\"save1\"},{switch=\"bactivatesave1\",text=\"activatesave1\",value=\"false\",onReleased=\"activatesave1\"}}\n--%%u={label=\"info_save1\",text=\"info_save1\"}\n--%%u={{switch=\"save2\",text=\"save2\",value=\"false\",onLongPressReleased=\"save2\"},{switch=\"bactivatesave2\",text=\"activatesave2\",value=\"false\",onReleased=\"activatesave2\"}}\n--%%u={label=\"info_save2\",text=\"info_save2\"}\n--%%u={{switch=\"save3\",text=\"save3\",value=\"false\",onLongPressReleased=\"save3\"},{switch=\"bactivatesave3\",text=\"activatesave3\",value=\"false\",onReleased=\"activatesave3\"}}\n--%%u={label=\"info_save3\",text=\"info_save3\"}\n--%%u={{switch=\"save4\",text=\"save4\",value=\"false\",onLongPressReleased=\"save4\"},{switch=\"bactivatesave4\",text=\"activatesave4\",value=\"false\",onReleased=\"activatesave4\"}}\n--%%u={label=\"info_save4\",text=\"info_save4\"}\n--%%u={{switch=\"save5\",text=\"save5\",value=\"false\",onLongPressReleased=\"save5\"},{switch=\"bactivatesave5\",text=\"activatesave5\",value=\"false\",onReleased=\"activatesave5\"}}\n--%%u={label=\"info_save5\",text=\"info_save5\"}\n--%%u={{switch=\"save6\",text=\"save6\",value=\"false\",onLongPressReleased=\"save6\"},{switch=\"bactivatesave6\",text=\"activatesave6\",value=\"false\",onReleased=\"activatesave6\"}}\n--%%u={label=\"info_save6\",text=\"info_save6\"}\n\n\n--%%u={label=\"infoLine9\",text=\"\"}\n--%%u={label=\"info_sunset_select\",text=\"info_sunset_select\"}\n--%%u={select=\"sunset_select\",text=\"sunset_select\",onToggled=\"sunset_select\",options={}}\n--%%u={label=\"info_sunset_select_delay\",text=\"info_sunset_select_delay\"}\n--%%u={select=\"sunset_select_delay\",text=\"sunset_select_delay\",onToggled=\"sunset_select_delay\",options={}}\n--%%u={slider=\"sunset_select_delay_slider\", min=\"1\", max=\"120\", onChanged=\"sunset_select_delay_slider\"}\n--%%u={{switch=\"sunset_pir_disable\",text=\"sunset_pir_disable\",value=\"false\",onReleased=\"sunset_pir_disable\"},{switch=\"sunset_pir_enable\",text=\"sunset_pir_enable\",value=\"false\",onReleased=\"sunset_pir_enable\"},{switch=\"push_sunset\",text=\"push_sunset\",value=\"false\",onReleased=\"push_sunset\"}}\n\n\n--%%u={label=\"infoLine10\",text=\"\"}\n--%%u={label=\"info_sunrise_select\",text=\"info_sunrise_select\"}\n--%%u={select=\"sunrise_select\",text=\"sunrise_select\",onToggled=\"sunrise_select\",options={}}\n--%%u={label=\"info_sunrise_select_delay\",text=\"info_sunrise_select_delay\"}\n--%%u={select=\"sunrise_select_delay\",text=\"sunrise_select_delay\",onToggled=\"sunrise_select_delay\",options={}}\n--%%u={slider=\"sunrise_select_delay_slider\", min=\"1\", max=\"120\", onChanged=\"sunrise_select_delay_slider\"}\n--%%u={{switch=\"sunrise_pir_disable\",text=\"sunrise_pir_disable\",value=\"false\",onReleased=\"sunrise_pir_disable\"},{switch=\"sunrise_pir_enable\",text=\"sunrise_pir_enable\",value=\"false\",onReleased=\"sunrise_pir_enable\"},{switch=\"push_sunrise\",text=\"push_sunrise\",value=\"false\",onReleased=\"push_sunrise\"}}\n\n--%%u={label=\"infoLine12\",text=\"\"}\n--%%u={label=\"info_push\",text=\"info_push\"}\n--%%u={multi=\"push_user\",text=\"push_user\",onToggled=\"push_user\",options={}}\n--%%u={{switch=\"push_device_onoff\",text=\"push_device_onoff\",value=\"false\",onReleased=\"push_device_onoff\"}}\n--%%u={multi=\"push_device\",text=\"push_device\",onToggled=\"push_device\",options={}}\n--%%u={{switch=\"push_save\",text=\"push_save\",value=\"false\",onReleased=\"push_save\"},{switch=\"test_push\",text=\"test_push\",value=\"false\",onReleased=\"test_push\"}}\n\n\n--%%u={label=\"infoLine5\",text=\"\"}\n--%%u={multi=\"select_motion_setup\",text=\"Motion List\",onToggled=\"select_motion_setup\",options={}}\n--%%u={label=\"info_motionsensor\",text=\"info_motionsensor\"}\n\n\n\n\n--u={label=\"infoLine11\",text=\"\"}\n--u={label=\"info_nightmode_on\",text=\"info_nightmode_on\"}\n--u={select=\"nightmode_select_on\",text=\"nightmode_select_on\",onToggled=\"nightmode_select_on\",options={}}\n--u={label=\"info_nightmode_off\",text=\"info_nightmode_off\"}\n--u={select=\"nightmode_select_off\",text=\"nightmode_select_off\",onToggled=\"nightmode_select_off\",options={}}\n--u={{switch=\"nightmode_pir_disable\",text=\"nightmode_pir_disable\",value=\"false\",onReleased=\"nightmode_pir_disable\"},{switch=\"nightmode_pir_enable\",text=\"nightmode_pir_enable\",value=\"false\",onReleased=\"nightmode_pir_enable\"},{button=\"a5\",text=\"\"}}\n--u={label=\"info_nightmode_time\",text=\"info_nightmode_time\"}\n--u={{switch=\"nightmode_n\",text=\"nightmode_n\",value=\"false\",onReleased=\"nightmode_n\",onLongPressReleased=\"nightmode_n_l\"},{switch=\"nightmode_p\",text=\"nightmode_p\",value=\"false\",onReleased=\"nightmode_p\",onLongPressReleased=\"nightmode_p_l\"},{button=\"button_ID_15_4\",text=\"\"}}\n\n\n\n\n\n--%%u={{switch=\"t1\",text=\"Sunset\",value=\"false\",onReleased=\"t1\"},{switch=\"t2\",text=\"Sunrise\",value=\"false\",onReleased=\"t2\"}}\n\n\n\n--%%u={label=\"infoLine7\",text=\"\"}\n--%%u={label=\"s1\",text=\"\"}\n--%%u={label=\"s2\",text=\"\"}\n--%%u={label=\"s3\",text=\"\"}\n--%%u={label=\"s4\",text=\"\"}\n--%%u={{switch=\"Restart\",text=\"Restart\",value=\"false\",onReleased=\"Restart\"},{switch=\"s21\",text=\"s21\",value=\"false\",onReleased=\"s21\"}}\n--%%u={label=\"s5\",text=\"\"}\n--%%u={label=\"s6\",text=\"\"}\n--%%u={label=\"error_status\",text=\"\"}\n\n\n\n\n\n\n----files to import\n--%%file=33.Outdoor Light Controller/33.translation.lua,Translation;\n--%%file=C:\\VSCODE\\fibemu\\3.outdoor light controller/outdoor_light_controller_Eventlib.lua,Eventlib;\n\n\n----\n--%%debug=refresh:false\n\n\n-------Quickapp variables\n--%%var=language:\"en\" \n--%%var=roomID:\"\" \n--%%var=Setup:\"0\" \n--%%var=scene1:\"100%\" \n--%%var=scene2:\"Dim\" \n--%%var=scene3:\"Midnight\" \n--%%var=scene4:\"Evening\" \n--%%var=scene5:\"Scene 5\" \n--%%var=scene6:\"Scene 6\" \n\n--%%var=color1:\"#ff9933\"      ----Orange            #ff9933     --- works on white and black\n--%%var=color2:\"#99ff33\"      ----Green             #99ff33     --- works on white and black\n--%%var=color3:\"#990000\"      ----red               #990000     --- works on white and black \n--%%var=color4:\"#66ffff\"      ----turquoise         #66ffff     --- works on white and black\n\n\n\n\n--color1 =  \"#ff9933\"      ----Orange            #ff9933     --- works on white and black\n--color2 =  \"#99ff33\"      ----Green             #99ff33     --- works on white and black\n--color3 =  \"#990000\"      ----red               #990000     --- works on white and black\n--color4 =  \"#66ffff\"      ----turquoise         #66ffff     --- works on white and black\n--color5 =  \"#ffff33\"      ----yellow            #ffff33     --- works on white and black\n--color6 =  \"#ff6633\"      ----DarkOrange        #ff6633     --- works on white and black\n--color7 =  \"#0000cc\"      ----blue              #0000cc     --- works on white and black\n--color8 =  \"#ff66ff\"      ----Pink              #ff66ff     --- works on white and black\n--color9 =  \"#660066\"      ----purple            #660066     --- works on white and black\n--color10 = \"#000000\"      ----black             #000000     \n--color11 = \"#ffffff\"      ----white             #ffffff     \n\n\nlocal qa_type = \"33. Outdoor Light Controller\"\nlocal version = \"v1.0.0\"\nlocal revision_date = \"01/05/26 12:17:32\"\nlocal quickAppUuid = \"JBS33\"\n\nlocal ERROR_STATUS_MAX_LINES = 20\nlocal LIGHT_HEALTH_CHECK_DELAY_SECONDS = 30\nlocal LIGHT_HEALTH_CHECK_EVENT_CONFIRM = true\nlocal LIGHT_HEALTH_MAX_RETRY_ATTEMPTS = 3\nlocal LIGHT_HEALTH_WAKE_DEAD_ON_RETRY = true\nlocal LIGHT_HEALTH_RETRY_VERIFY_DELAY_SECONDS = 5\nlocal STARTUP_SCENE_MATCH_DELAY_SECONDS = 30\nlocal STATUS_REFRESH_INTERVAL_SECONDS = 300\n\nlocal SUN_STATE_CONFIG = {\n  midnight_sun = \"day\",\n  polar_night = \"night\",\n  offset_overlap = \"day\",\n  run_sunrise_action_in_midnight_sun = false,\n  run_sunset_action_in_midnight_sun = false,\n  run_sunrise_action_in_polar_night = false,\n  run_sunset_action_in_polar_night = false,\n  run_sunrise_action_in_offset_overlap = false,\n  run_sunset_action_in_offset_overlap = false,\n}\n\n\n\n\n-------------------------------------------------------------------------------------------------------------------------------\n-------------------------------------------------------------------------------------------------------------------------------\n-------------------------------------------------------------------------------------------------------------------------------\n--[[Start  off instuctions\n\nIt is a fast way to get Motion Lights up and going. Just upload it to the room and choose from the dropdown menu. \n\nIt is alot like my other Room Light controller, just without the profile handling for small rooms. \nChoose what should happen on/off pir events\n\nChoose the lights and sensor to use from the room the controller is in.\n(can also use the Qvar to the room you want to controll to have the controller in an other room)\nYou can also store 2 custom Scenes (rename the scenes in the Qvars scene1 and scene 2 - standard 100% and Dim) \n\nTo save the scenes just hold down the Save 100% or Save Dim button for 2sec when the lights are set as you want them to be.\n\nScenes also support rgbw2 controller programs and colors :D \n\nLabels can be changed colors with the Qvars color1,color2.. \n(might add support for theme colors)\n\n\nIt also support Language:\nen  -  English\nno  -  Norwegian\nde  -  German  (thanks stycx - https://forum.fibaro.com/profile/57588-stycx/)\npl  -  Polish  (thanks raffsa - https://forum.fibaro.com/profile/35572-raffsa/)\nfr  -  French  (thanks Tony270570 - https://forum.fibaro.com/profile/2410-tony270570/)\n\n\nIf you could help make support for other languages just hit me up on the forum: \nhttps://forum.fibaro.com/profile/50638-brors94/\nOr in this thread:\nhttps://forum.fibaro.com/topic/78508-easy-light-controller/\n\nAlso post in the topic above if you have anu suggestions or wishes :D\n\n\n\nSpecial Thanks to @jgab https://forum.fibaro.com/profile/2168-jgab/ \nNothing could have been done without his Eventlib and guides on the forum!!\n\n\n\n\n\n\n\nChangelog:\n\n\n\n\n\n\n]]  ----End off instuctions\n-------------------------------------------------------------------------------------------------------------------------------\n-------------------------------------------------------------------------------------------------------------------------------\n-------------------------------------------------------------------------------------------------------------------------------\n\n\n\n\n\n-----starttime measure\n  local starttime = os.clock()\n  local Event = Event_std or Event_basic\n  if Event == nil then\n    Event = {}\n    setmetatable(Event, {\n      __call = function()\n        return nil\n      end,\n      __index = function(_, key)\n        if key == \"attachRefreshstate\" then\n          return function()\n            return nil\n          end\n        end\n        return nil\n      end\n    })\n  end\n  local Fontsize = 2\n-------------------------------------------------------------------------------------------------------------------------------\n----jgab eventlib \n  Event.id='start'\n  Event{type='QAstart'}\n  function Event:handler(event)\n  Event:attachRefreshstate()\nend\n -------------------------------------------------------------------------------------------------------------------------------\n ----jgab storage function\nfunction QuickApp:setupStorage()\n   local storage,qa = {},self\n   function storage:__index(key) return qa:internalStorageGet(key) end\n   function storage:__newindex(key,val)\n      if val == nil then qa:internalStorageRemove(key)\n      else qa:internalStorageSet(key,val) end\n    end\n   return setmetatable({},storage) \nend\n\nfunction QuickApp:a1() end\nfunction QuickApp:a2() end\nfunction QuickApp:a3() end\nfunction QuickApp:a4() end\nfunction QuickApp:a5() end\nfunction QuickApp:button_ID_14_2() end\nfunction QuickApp:button_ID_14_3() end\nfunction QuickApp:button_ID_15_3() end\nfunction QuickApp:button_ID_15_4() end\nfunction QuickApp:save1() end\nfunction QuickApp:save2() end\nfunction QuickApp:save3() end\nfunction QuickApp:save4() end\nfunction QuickApp:save5() end\nfunction QuickApp:save6() end\nfunction QuickApp:save_light() end\nfunction QuickApp:push_save() end\nfunction QuickApp:test_push() end\n\n fibaro.debugFlags = fibaro.debugFlags or {}\n fibaro.debugFlags.post = false\n fibaro.debugFlags.sunState = false\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\n--Function ONinit                                     ]]      --[[     tonumber(\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\nfunction QuickApp:onInit()\n  local room_id = tonumber(self:getVariable(\"roomID\"))\n  local quickapp_id = self.id\n  local self_room_id\n  local warned_update_views = {}\n  local inactive_ui_views = {\n    a5 = true,\n    bdelay_timen = true,\n    bdelay_timep = true,\n    bp1_scene_off_delay = true,\n    bsec_min_delay = true,\n    bsec_min_sensor = true,\n    button_ID_14_2 = true,\n    button_ID_14_3 = true,\n    button_ID_15_4 = true,\n    info_delay_timer = true,\n    info_pir_off_delay = true,\n    infoLine11 = true,\n    info_nightmode_off = true,\n    info_nightmode_on = true,\n    info_nightmode_time = true,\n    nightmode_n = true,\n    nightmode_p = true,\n    nightmode_pir_disable = true,\n    nightmode_pir_enable = true,\n    nightmode_select_off = true,\n    nightmode_select_on = true,\n  }\n  local view_state_cache = {}\n  local dedupe_view_properties = {\n    max = true,\n    min = true,\n    step = true,\n    text = true,\n    value = true,\n    visible = true,\n  }\n  local log_throttle_window_seconds = 60\n  local last_log_timestamp_by_key = {}\n  local raw_update_view = self.updateView\n  local color_transit_time = 150\n  local function safe_api_get(path, operation_description)\n    local ok, result = pcall(api.get, path)\n    if ok and type(result) == \"table\" then\n      return result\n    end\n    self:warning((operation_description or \"API request failed\")..\": \"..tostring(path)..\" -> \"..tostring(result))\n    return {}\n  end\n\n  local function build_view_cache_key(view_name, property_name)\n    return tostring(view_name)..\"|\"..tostring(property_name)\n  end\n\n  local function build_view_cache_value(property_value)\n    local property_value_type = type(property_value)\n    if property_value_type == \"string\" then\n      return \"string:\"..property_value\n    end\n    return property_value_type..\":\"..tostring(property_value)\n  end\n\n  local function invalidate_view_cache(view_name, property_name)\n    view_state_cache[build_view_cache_key(view_name, property_name)] = nil\n  end\n\n  function self:updateView(view_name, property_name, property_value)\n    if inactive_ui_views[tostring(view_name)] == true then\n      return true, \"inactive_ui_view\"\n    end\n\n    local cache_key = build_view_cache_key(view_name, property_name)\n    if dedupe_view_properties[tostring(property_name)] == true then\n      local cache_value = build_view_cache_value(property_value)\n      if view_state_cache[cache_key] == cache_value then\n        return true, \"cached_ui_view\"\n      end\n    end\n\n    local ok, result = pcall(raw_update_view, self, view_name, property_name, property_value)\n    if ok then\n      if dedupe_view_properties[tostring(property_name)] == true then\n        view_state_cache[cache_key] = build_view_cache_value(property_value)\n      end\n    else\n      local warning_key = tostring(view_name)..\":\"..tostring(property_name)\n      if warned_update_views[warning_key] ~= true then\n        warned_update_views[warning_key] = true\n        self:warning(\"Skipping UI update for \"..tostring(view_name)..\" \"..tostring(property_name)..\": \"..tostring(result))\n      end\n    end\n    return ok, result\n  end\n\n  local function get_callback_values(args)\n    if type(args) ~= \"table\" then\n      return nil\n    end\n    local values = args.values or args[\"values\"]\n    if type(values) ~= \"table\" then\n      return nil\n    end\n    return values\n  end\n\n  local function get_callback_value(args)\n    local values = get_callback_values(args)\n    if values == nil then\n      return nil\n    end\n    return values[1]\n  end\n\n  local function get_single_callback_value(args)\n    local value = get_callback_value(args)\n    while type(value) == \"table\" do\n      value = value[1]\n      if value == nil then\n        return nil\n      end\n    end\n    return value\n  end\n\n  local function get_multi_callback_value(args)\n    local value = get_callback_value(args)\n    if type(value) ~= \"table\" then\n      return nil\n    end\n    return value\n  end\n\n  local function build_error_trace(label, err)\n    local message = tostring(err)\n    if debug ~= nil and type(debug.traceback) == \"function\" then\n      return tostring(label)..\": \"..debug.traceback(message, 2)\n    end\n    return tostring(label)..\": \"..message\n  end\n\n  local function safe_startup_call(step_name, func)\n    local ok, err = xpcall(func, function(startup_err)\n      return build_error_trace(step_name, startup_err)\n    end)\n    if not ok then\n      self:error(\"Startup step failed: \"..tostring(err))\n    end\n    return ok\n  end\n\n  local function log_throttled(level_name, throttle_key, log_message)\n    local now_timestamp = os.time()\n    local last_timestamp = last_log_timestamp_by_key[throttle_key]\n    if last_timestamp ~= nil and (now_timestamp - last_timestamp) < log_throttle_window_seconds then\n      return\n    end\n\n    last_log_timestamp_by_key[throttle_key] = now_timestamp\n    if level_name == \"warning\" then\n      self:warning(log_message)\n    else\n      self:error(log_message)\n    end\n  end\n\n  local function safe_hub_get_value(device_id, property_name, operation_description)\n    local ok, property_value = pcall(hub.getValue, device_id, property_name)\n    if ok then\n      return property_value\n    end\n    log_throttled(\n      \"error\",\n      \"hub_get:\"..tostring(device_id)..\":\"..tostring(property_name),\n      (operation_description or \"Unable to read device property\")..\" for device \"..tostring(device_id)..\" property \"..tostring(property_name)..\": \"..tostring(property_value)\n    )\n    return nil\n  end\n\n  local function safe_hub_call(device_id, action_name, ...)\n    local ok, call_result = pcall(hub.call, device_id, action_name, ...)\n    if ok then\n      return call_result\n    end\n    log_throttled(\n      \"error\",\n      \"hub_call:\"..tostring(device_id)..\":\"..tostring(action_name),\n      \"Device action failed for device \"..tostring(device_id)..\" action \"..tostring(action_name)..\": \"..tostring(call_result)\n    )\n    return nil\n  end\n\n  local function init_main()\n\n  local quick_app_device = safe_api_get(\"/devices/\"..self.id, \"Unable to read QA device state\")\n  if type(quick_app_device) == \"table\" and quick_app_device.enabled == false then\n    self:debug(self.name, self.id, \"Device is disabled\")\n    return\n  end\n\n  if room_id == nil then\n  local room_lookup_ok, detected_room_id = pcall(hub.getRoomID, quickapp_id)\n  if room_lookup_ok then\n    self_room_id = detected_room_id or 0\n  else\n    self:error(\"Unable to detect room ID for QA \"..tostring(quickapp_id)..\": \"..tostring(detected_room_id))\n    self_room_id = 0\n  end\n  else \n  self_room_id = room_id\n  end\n  local room_name_ok, room_name_result = pcall(hub.getRoomName, self_room_id)\n  local self_room_name = room_name_ok and (room_name_result or \"Unknown room\") or \"Unknown room\"\n  self:debug(\"DeviceId:\",self.id, \"   \" ,\"Name:\", self.name)\n  self:debug(\"Room:\",self_room_id, \"   \" ,\"Room Name:\", self_room_name)\n  self:updateProperty(\"log\", \"QA Started\")\n  self:updateProperty(\"deviceRole\", \"Other\")\n  self:updateProperty(\"categories\",{\"other\"})\n  local function sync_quickapp_uuid()\n    local configured_quickapp_uuid = tostring(quickAppUuid or \"\")\n    local current_quickapp_uuid = tostring(((quick_app_device or {}).properties or {}).quickAppUuid or \"\")\n    if configured_quickapp_uuid == \"\" or current_quickapp_uuid == configured_quickapp_uuid then\n      return\n    end\n\n    local update_ok, update_error = pcall(self.updateProperty, self, \"quickAppUuid\", configured_quickapp_uuid)\n    if not update_ok then\n      self:warning(\"Unable to update quickAppUuid property: \"..tostring(update_error))\n      return\n    end\n\n    pcall(api.put, \"/devices/\"..self.id, {properties = {quickAppUuid = configured_quickapp_uuid}})\n    self:debug(\"quickAppUuid set to \"..configured_quickapp_uuid)\n  end\n  safe_startup_call(\"sync_quickapp_uuid\", sync_quickapp_uuid)\n  self:updateProperty(\"useUiView\",false)\n  self:updateProperty(\"hasUIView\",false)\n  self.store = self:setupStorage()\n  --__TAG = \"QA_Room_Controller\"..\"_\"..tostring(quickapp_id)\n  ------------------description off QA\n  local function userDescription()\n  local line1 = \"Easy Light controller\"\n  local line2 = \"Made by Joachim Brørs Sommerfeld, Norway\"\n  local line3 = \"joachim.brors.sommerfeld@gmail.com\\nI am not a programer by craft/work, it is only a hobby so the code isnt perfect :D \"\n  local line4 = \"Use at own risk! ^^\\n\"\n  local line5 = \"This quickapp also uses the Eventlib made by:\"\n  local line6 = \"eventLib©️jan@gabrielsson.com\"\n  local line7 = \"And wouldnt work without it! Thanks!\"\n  self:updateProperty(\"userDescription\",\"\"..line1..\" \\n\"..line2..\"\\n\"..line3..\"\\n\"..line4..\"\\n\"..line5..\"\\n\"..line6..\"\\n\"..line7..\"\") \nend\n  safe_startup_call(\"userDescription\", userDescription)\n----------------------------------------------------------------\n\n\n-----just to fixs labels/buttons not showing\nlocal labels = {\n\"bturnoff\",\n\"bturnon\",\n\"activatesave11\",\n\"activatesave22\",\n\"activatesave33\",\n\"activatesave44\",\n\"activatesave55\",\n\"activatesave66\",\n\"bactivatesave1\",\n\"bactivatesave2\",\n\"bactivatesave3\",\n\"bactivatesave4\",\n\"bactivatesave5\",\n\"bactivatesave6\",\n\"bactivatesave55\",\n\"bactivatesave66\",\n\"bdelay_timen\",\n\"bdelay_timep\",\n\"bsec_min_delay\",\n\"bsensor_timen\",\n\"bsensor_timep\",\n\"bsec_min_sensor\",\n\"save1\",\n\"save2\",\n\"save5\",\n\"save6\",\n\"save_light\",\n\"push_sunrise\",\n\"push_sunset\",\n\"push_user\",\n\"push_device\",\n\"push_device_onoff\",\n\"push_save\",\n\"test_push\",\n\"sunset_select_delay_slider\",\n\"sunrise_select_delay_slider\",\n\"select_light_setup\",\n\"info_version\",\n\"info_status\",\n\"error_status\",\n\"Restart\",\n\"select_motion_setup\"} \n\n\nfor _,l in ipairs(labels) do self:updateView(l,\"visible\",true) end\n\nlocal labels2 = {\"button_ID_14_2\",\n\"button_ID_15_3\",\n\"button_ID_14_3\",\n\"button_ID_15_4\",\n\"s21\",\n\"a1\",\n\"a2\",\n\"a3\",\n\"a4\",\n\"a5\"\n} \nfor _,l in ipairs(labels2) do self:updateView(l,\"visible\",false) end\n\n\n\n\n--------- first time QA runs\n    local function clone_store_default(default_value)\n      if type(default_value) ~= \"table\" then\n        return default_value\n      end\n\n      local cloned_value = {}\n      for key, value in pairs(default_value) do\n        cloned_value[key] = value\n      end\n      return cloned_value\n    end\n\n    local store_defaults = {\n      lightid_trigger = {},\n      lightid_trigger_select = {},\n      save1_value = {},\n      save2_value = {},\n      save3_value = {},\n      save4_value = {},\n      save5_value = {},\n      save6_value = {},\n      save1_color = {},\n      save2_color = {},\n      save3_color = {},\n      save4_color = {},\n      save5_color = {},\n      save6_color = {},\n      save1_color_string = {},\n      save2_color_string = {},\n      save3_color_string = {},\n      save4_color_string = {},\n      save5_color_string = {},\n      save6_color_string = {},\n      save1_color_program = {},\n      save2_color_program = {},\n      save3_color_program = {},\n      save4_color_program = {},\n      save5_color_program = {},\n      save6_color_program = {},\n      sensor_timer_p1 = 300,\n      sec_min_sensor = \"min\",\n      sunset_args = \"no_action\",\n      sunset_delay_args = \"no_action\",\n      sunset_delay_time = 600,\n      sunrise_args = \"no_action\",\n      sunrise_delay_args = \"no_action\",\n      sunrise_delay_time = 600,\n      enable_status = \"on\",\n      motionsensorid_trigger = {},\n      motionsensorid_trigger_select = {},\n      sunrise_pir_enable = \"on\",\n      sunrise_pir_disable = \"off\",\n      sunset_pir_enable = \"on\",\n      sunset_pir_disable = \"off\",\n      push_sunrise = \"off\",\n      push_sunset = \"off\",\n      push_user_ids = {},\n      push_user_ids_pending = {},\n      push_user_id = \"\",\n      push_user_id_pending = \"\",\n      push_device_ids = {},\n      push_device_ids_pending = {},\n      push_device_id = \"\",\n      push_device_id_pending = \"\",\n      push_device_onoff = \"off\",\n      startup_discovery_cache_ready = \"false\",\n      startup_discovery_cache_version = 0,\n      startup_discovery_room_id = \"\",\n      startup_discovery_cache_built_at = 0,\n      cached_motion_catalog = {},\n      cached_light_catalog = {},\n      cached_push_users = {},\n      cached_push_devices = {},\n      error_status_lines = {},\n      offset_sunrise = 10,\n      offset_sunset = 10,\n      current_scene = \"\",\n      current_scene_action = \"\",\n      pir_status = \"Safe\",\n      p1_scene_on_args = \"no_action\",\n      p1_scene_off_args = \"no_action\",\n    }\n\n    local function ensure_store_default(key, default_value)\n      local current_value = self.store[key]\n      local default_type = type(default_value)\n      if current_value == nil or type(current_value) ~= default_type then\n        if current_value ~= nil and type(current_value) ~= default_type then\n          self:warning(\"Resetting invalid stored value for \"..tostring(key))\n        end\n        self.store[key] = clone_store_default(default_value)\n      end\n    end\n\n    local function reset_store_to_defaults()\n      for key, default_value in pairs(store_defaults) do\n        self.store[key] = clone_store_default(default_value)\n      end\n      self.store.first_time = \"First time Installation is Done\"\n      self:debug(tostring(self.store.first_time))\n    end\n\n    local function ensure_store_defaults()\n      for key, default_value in pairs(store_defaults) do\n        ensure_store_default(key, default_value)\n      end\n    end\n\n    if self.store.first_time == nil then\n      reset_store_to_defaults()\n    end\n\n----------------------------------------------------------------\n    local STARTUP_DISCOVERY_CACHE_VERSION = 1\n    local STARTUP_DISCOVERY_CACHE_MAX_AGE_SECONDS = 7 * 24 * 60 * 60\n    local setup = tostring(self:getVariable(\"Setup\") or \"0\")\n    local refresh_startup_discovery_cache = setup ~= \"0\"\n    if refresh_startup_discovery_cache then\n      self:setVariable(\"Setup\", \"0\")\n    end\n\n    ensure_store_defaults()\n\n    local function normalize_sun_event_delay_time(store_key)\n      local normalized_delay_seconds = tonumber(self.store[store_key])\n\n      if normalized_delay_seconds == nil then\n        normalized_delay_seconds = 600\n      end\n\n      normalized_delay_seconds = math.floor(normalized_delay_seconds + 0.5)\n      if normalized_delay_seconds < 60 then\n        normalized_delay_seconds = 60\n      elseif normalized_delay_seconds > 7200 then\n        normalized_delay_seconds = 7200\n      end\n\n      self.store[store_key] = normalized_delay_seconds\n      return normalized_delay_seconds\n    end\n\n    normalize_sun_event_delay_time(\"sunrise_delay_time\")\n    normalize_sun_event_delay_time(\"sunset_delay_time\")\n\n    local scene1 = self:getVariable(\"scene1\") or \"scene1\"\n    local scene2 = self:getVariable(\"scene2\") or \"scene2\"\n    local scene3 = self:getVariable(\"scene3\") or \"scene3\"\n    local scene4 = self:getVariable(\"scene4\") or \"scene4\"\n    local scene5 = self:getVariable(\"scene5\") or \"scene5\"\n    local scene6 = self:getVariable(\"scene6\") or \"scene6\"\n------label colors \nlocal color1 = self:getVariable(\"color1\") or \"Orange\"  --\"<font color=Orange>\"\ncolor1 = \"<font color=\"..color1..\">\"\nlocal color2 = self:getVariable(\"color2\") or \"green\"  --\"<font color=green>\"\ncolor2 = \"<font color=\"..color2..\">\"\nlocal color3 = self:getVariable(\"color3\") or \"red\"  --\"<font color=red>\"\ncolor3 = \"<font color=\"..color3..\">\"\nlocal color4 = self:getVariable(\"color4\") or \"turquoise\"  ----\"turquoise\"\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n\n    local offset_sunset = self.store.offset_sunset \n    local offset_sunrise = self.store.offset_sunrise\n    self.store.night_or_day = \"day\"\n    local sunrise_time = safe_hub_get_value(1, \"sunriseHour\", \"Unable to read sunrise time\") or \"--:--\"\n    local sunset_time = safe_hub_get_value(1, \"sunsetHour\", \"Unable to read sunset time\") or \"--:--\"\n\n    local enable_status = self.store.enable_status \n\n    local motionsensorid_trigger \n    local motionsensorid_trigger_select\n    if self.store.motionsensorid_trigger ~= nil then\n    motionsensorid_trigger = self.store.motionsensorid_trigger \n    else\n    motionsensorid_trigger = {}\n    end\n    if self.store.motionsensorid_trigger_select ~= nil then\n    motionsensorid_trigger_select = self.store.motionsensorid_trigger_select \n    else\n    motionsensorid_trigger_select = {} \n    end\n    local lightid_trigger \n    local lightid_trigger_select\n    local pending_lightid_trigger_select\n    if self.store.lightid_trigger ~= nil then\n    lightid_trigger = self.store.lightid_trigger \n    else\n    lightid_trigger = {}\n    end\n    if self.store.lightid_trigger_select ~= nil then\n    lightid_trigger_select = self.store.lightid_trigger_select \n    else\n    lightid_trigger_select = {}\n    end\n    local function copy_id_list(source_ids)\n      local copied_ids = {}\n      for index, value in ipairs(source_ids or {}) do\n        copied_ids[index] = tostring(value)\n      end\n      return copied_ids\n    end\n\n    local function build_id_lookup(source_ids)\n      local lookup = {}\n      for _, value in ipairs(source_ids or {}) do\n        local normalized_value = tostring(value)\n        lookup[normalized_value] = normalized_value\n      end\n      return lookup\n    end\n\n    local function selection_signature(source_ids)\n      local signature_parts = copy_id_list(source_ids)\n      table.sort(signature_parts)\n      return table.concat(signature_parts, \",\")\n    end\n\n    local function normalize_catalog_entries(source_entries)\n      local normalized_entries = {}\n      local seen_entry_ids = {}\n\n      if type(source_entries) ~= \"table\" then\n        return normalized_entries\n      end\n\n      for _, source_entry in ipairs(source_entries) do\n        if type(source_entry) == \"table\" then\n          local entry_id = tonumber(source_entry.id) or tostring(source_entry.id or \"\")\n          local normalized_entry_id = tostring(entry_id or \"\")\n          if normalized_entry_id ~= \"\" and seen_entry_ids[normalized_entry_id] ~= true then\n            table.insert(normalized_entries, {\n              id = entry_id,\n              name = tostring(source_entry.name or \"\"),\n            })\n            seen_entry_ids[normalized_entry_id] = true\n          end\n        end\n      end\n\n      return normalized_entries\n    end\n\n    local function read_cached_catalog(store_key)\n      return normalize_catalog_entries(self.store[store_key])\n    end\n\n    local function write_cached_catalog(store_key, source_entries)\n      self.store[store_key] = normalize_catalog_entries(source_entries)\n    end\n\n    local function has_valid_startup_discovery_cache()\n      local cache_built_at = tonumber(self.store.startup_discovery_cache_built_at or 0) or 0\n      local cache_age_seconds = os.time() - cache_built_at\n      return self.store.startup_discovery_cache_ready == \"true\"\n        and tonumber(self.store.startup_discovery_cache_version or 0) == STARTUP_DISCOVERY_CACHE_VERSION\n        and tostring(self.store.startup_discovery_room_id or \"\") == tostring(self_room_id or \"\")\n        and cache_built_at > 0\n        and cache_age_seconds >= 0\n        and cache_age_seconds <= STARTUP_DISCOVERY_CACHE_MAX_AGE_SECONDS\n    end\n\n    local function should_rebuild_startup_discovery_cache()\n      return refresh_startup_discovery_cache or not has_valid_startup_discovery_cache()\n    end\n\n    local function mark_startup_discovery_cache_ready()\n      self.store.startup_discovery_cache_ready = \"true\"\n      self.store.startup_discovery_cache_version = STARTUP_DISCOVERY_CACHE_VERSION\n      self.store.startup_discovery_room_id = tostring(self_room_id or \"\")\n      self.store.startup_discovery_cache_built_at = os.time()\n    end\n\n    if refresh_startup_discovery_cache then\n      self:debug(\"Refreshing startup discovery cache because Setup was set to \"..tostring(setup))\n    elseif has_valid_startup_discovery_cache() then\n      self:debug(\"Using cached startup discovery metadata\")\n    else\n      self:debug(\"Building startup discovery metadata cache\")\n    end\n\n    lightid_trigger_select = copy_id_list(lightid_trigger_select)\n    lightid_trigger = build_id_lookup(lightid_trigger_select)\n    pending_lightid_trigger_select = copy_id_list(lightid_trigger_select)\n    self.store.lightid_trigger = build_id_lookup(lightid_trigger_select)\n    self.store.lightid_trigger_select = copy_id_list(lightid_trigger_select)\n----------------------------------------------------------------\n----------------------------------------------------------------\n----motions sensor update on startup\nlocal motion_ids = {}\nlocal motion_name = {}\nlocal motionsensorid = {}\nlocal motion_sensor_state_by_device_id = {}\nlocal motion_sensor_info_refresh_timer\nlocal room_catalog_scan_cache\n\n  local function device_has_interface(device, interface_name)\n    if type(device) ~= \"table\" or type(device.interfaces) ~= \"table\" then\n      return false\n    end\n\n    for _, candidate_interface in ipairs(device.interfaces) do\n      if tostring(candidate_interface) == tostring(interface_name) then\n        return true\n      end\n    end\n\n    return false\n  end\n\n  local function build_room_catalogs_from_api()\n    if room_catalog_scan_cache ~= nil then\n      return room_catalog_scan_cache.motion_catalog, room_catalog_scan_cache.light_catalog\n    end\n\n    local motion_catalog = {}\n    local light_catalog = {}\n    for _,motion in ipairs(safe_api_get(\"/devices?roomID=\"..self_room_id..\"&enabled=true&visible=true\", \"Unable to scan room devices\")) do\n      if (motion.baseType == \"com.fibaro.FGMS001\")\n        or (motion.type == \"com.fibaro.doorSensor\")\n        or (motion.type == \"com.fibaro.presenceSensor\")\n        or (motion.type == \"com.fibaro.motionSensor\") then\n        table.insert(motion_catalog, {\n          id = motion.id or \"\",\n          name = motion.name or \"\",\n        })\n      end\n      if device_has_interface(motion, \"light\") then\n        if motion.type ~= \"com.fibaro.FGRGBW442\" then\n          table.insert(light_catalog, {\n            id = motion.id or \"\",\n            name = motion.name or \"\",\n          })\n        end\n      end\n    end\n    room_catalog_scan_cache = {\n      motion_catalog = normalize_catalog_entries(motion_catalog),\n      light_catalog = normalize_catalog_entries(light_catalog),\n    }\n    return room_catalog_scan_cache.motion_catalog, room_catalog_scan_cache.light_catalog\n  end\n\n  local function build_motion_catalog_from_api()\n    local motion_catalog = build_room_catalogs_from_api()\n    return normalize_catalog_entries(motion_catalog)\n  end\n\n  local function apply_motion_catalog(motion_catalog)\n    motion_ids = {}\n    motionsensorid = {}\n    motion_name = {}\n\n    for rownumber, motion_entry in ipairs(normalize_catalog_entries(motion_catalog)) do\n      local motion_device_id = tonumber(motion_entry.id) or motion_entry.id or \"\"\n      motion_ids[rownumber] = motion_device_id\n      motionsensorid[rownumber] = motion_device_id\n      motion_name[rownumber] = tostring(motion_entry.name or \"\")\n    end\n  end\n\n  local function update_motion()\n    local motion_catalog\n    if should_rebuild_startup_discovery_cache() then\n      motion_catalog = build_motion_catalog_from_api()\n      write_cached_catalog(\"cached_motion_catalog\", motion_catalog)\n    else\n      motion_catalog = read_cached_catalog(\"cached_motion_catalog\")\n    end\n    apply_motion_catalog(motion_catalog)\n  end\nsafe_startup_call(\"update_motion\", update_motion)\n\n----------------------------------------------------------------\n----------------------------------------------------------------\n----room and lights on startup\n    local light_ids = {}\n    local light_name = {}\n    local light_name_by_id = {}\n    \n    local function build_light_catalog_from_api()\n      local _, light_catalog = build_room_catalogs_from_api()\n      return normalize_catalog_entries(light_catalog)\n    end\n\n    local function apply_light_catalog(light_catalog)\n      light_ids = {}\n      light_name = {}\n      light_name_by_id = {}\n\n      for rownumber, light_entry in ipairs(normalize_catalog_entries(light_catalog)) do\n        local light_device_id = tonumber(light_entry.id) or light_entry.id or \"\"\n        local light_device_name = tostring(light_entry.name or \"\")\n        light_ids[rownumber] = light_device_id\n        light_name[rownumber] = light_device_name\n        light_name_by_id[tostring(light_device_id)] = light_device_name\n      end\n    end\n\n    local function update_light()\n      local light_catalog\n      if should_rebuild_startup_discovery_cache() then\n        light_catalog = build_light_catalog_from_api()\n        write_cached_catalog(\"cached_light_catalog\", light_catalog)\n      else\n        light_catalog = read_cached_catalog(\"cached_light_catalog\")\n      end\n      apply_light_catalog(light_catalog)\n    end\n    safe_startup_call(\"update_light\", update_light)\n\n  local function is_available_light_id(candidate_light_id)\n    for _, available_light_id in ipairs(light_ids or {}) do\n      if tostring(available_light_id) == tostring(candidate_light_id) then\n        return true\n      end\n    end\n    return false\n  end\n\n  local function sanitize_light_selection(selected_ids)\n    local cleaned_ids = {}\n    local seen_ids = {}\n    for _, selected_id in ipairs(copy_id_list(selected_ids)) do\n      if is_available_light_id(selected_id) and seen_ids[selected_id] ~= true then\n        table.insert(cleaned_ids, selected_id)\n        seen_ids[selected_id] = true\n      end\n    end\n    return cleaned_ids\n  end\n\n  lightid_trigger_select = sanitize_light_selection(lightid_trigger_select)\n  lightid_trigger = build_id_lookup(lightid_trigger_select)\n  pending_lightid_trigger_select = copy_id_list(lightid_trigger_select)\n  self.store.lightid_trigger = build_id_lookup(lightid_trigger_select)\n  self.store.lightid_trigger_select = copy_id_list(lightid_trigger_select)\n\n  local function is_available_motion_id(candidate_motion_id)\n    for _, available_motion_id in ipairs(motion_ids or {}) do\n      if tostring(available_motion_id) == tostring(candidate_motion_id) then\n        return true\n      end\n    end\n    return false\n  end\n\n  local function sanitize_motion_selection(selected_ids)\n    local cleaned_ids = {}\n    local seen_ids = {}\n    for _, selected_id in ipairs(copy_id_list(selected_ids)) do\n      if is_available_motion_id(selected_id) and seen_ids[selected_id] ~= true then\n        table.insert(cleaned_ids, selected_id)\n        seen_ids[selected_id] = true\n      end\n    end\n    return cleaned_ids\n  end\n\n  motionsensorid_trigger_select = sanitize_motion_selection(motionsensorid_trigger_select)\n  motionsensorid_trigger = build_id_lookup(motionsensorid_trigger_select)\n  self.store.motionsensorid_trigger = build_id_lookup(motionsensorid_trigger_select)\n  self.store.motionsensorid_trigger_select = copy_id_list(motionsensorid_trigger_select)\n\n\n----------------------------------------------------------------\n------Supported language check \n    local language = self:getVariable(\"language\") or \"en\"\n    if string.lower(language) == \"en\" then\n    self:debug(\"Language: English\")\n    elseif  string.lower(language) == \"no\"  then\n    self:debug(\"Language: Norwegian\")\n    elseif  string.lower(language) == \"de\"  then\n    self:debug(\"Language: German\")\n    elseif  string.lower(language) == \"pl\"  then\n    self:debug(\"Language: Polish\")\n    elseif  string.lower(language) == \"fr\"  then\n    self:debug(\"Language: French\")\n    else\n    language = \"en\"\n    self:warning(\"Language not recognised, English is set\")\n    self:setVariable(\"language\", \"en\")\n    end\n    local translation = {}\n    if lang ~= nil and type(lang.translation) == \"function\" then\n      local ok, translation_result = pcall(function()\n        return lang:translation(language)\n      end)\n      if ok and type(translation_result) == \"table\" then\n        translation = translation_result\n      else\n        self:warning(\"Unable to load translation, using fallback labels\")\n      end\n    else\n      self:warning(\"Translation helper missing, using fallback labels\")\n    end\n    setmetatable(translation, {\n      __index = function(_, key)\n        return tostring(key or \"\")\n      end\n    })\n\nlocal qa_ui_icons = {\n  confirm = \"✅\",\n  decrease = \"➖\",\n  disable = \"⛔\",\n  enable = \"✅\",\n  identifier = \"#\",\n  increase = \"➕\",\n  light = \"💡\",\n  motion = \"🚶\",\n  device = \"📱\",\n  profile = \"👤\",\n  room = \"⌂\",\n  save = \"💾\",\n  scene = \"▶\",\n  test = \"🔔\",\n  sunrise = \"🌅\",\n  sunset = \"🌇\",\n  timer = \"⏱\",\n  turnOff = \"🌙\",\n  turnOn = \"💡\",\n}\n\nlocal function build_icon_text(icon_symbol, plain_text)\n  local icon_text = tostring(icon_symbol or \"\")\n  local plain_caption_text = tostring(plain_text or \"\")\n  if icon_text == \"\" then\n    return plain_caption_text\n  end\n  if plain_caption_text == \"\" then\n    return icon_text\n  end\n  return icon_text..\" \"..plain_caption_text\nend\n\nlocal function build_trailing_icon_text(plain_text, icon_symbol)\n  local plain_caption_text = tostring(plain_text or \"\")\n  local icon_text = tostring(icon_symbol or \"\")\n  if icon_text == \"\" then\n    return plain_caption_text\n  end\n  if plain_caption_text == \"\" then\n    return icon_text\n  end\n  return plain_caption_text..\" \"..icon_text\nend\n\nlocal function format_dropdown_device_option_text(device_id, device_name)\n  local numeric_device_id = tonumber(device_id)\n  local formatted_device_id_text\n  if numeric_device_id ~= nil then\n    formatted_device_id_text = string.format(\"%04d\", numeric_device_id)\n  else\n    formatted_device_id_text = tostring(device_id or \"\")\n  end\n\n  return tostring(translation[\"ID\"])..\": \"..formatted_device_id_text..\" \"..tostring(translation[\"Name\"])..\": \"..tostring(device_name or \"\")\nend\n\nlocal save_light_button_idle_text = build_icon_text(qa_ui_icons.confirm, translation[\"Saved lights\"])\nlocal save_light_button_pending_text = build_icon_text(qa_ui_icons.save, translation[\"Save pending lights\"])\nlocal save_light_button_active_text = build_icon_text(qa_ui_icons.confirm, translation[\"Lights saved\"])\nlocal push_save_button_idle_text = build_icon_text(qa_ui_icons.confirm, translation[\"Saved push targets\"])\nlocal push_save_button_pending_text = build_icon_text(qa_ui_icons.save, translation[\"Save pending push targets\"])\nlocal push_save_button_active_text = build_icon_text(qa_ui_icons.confirm, translation[\"Push targets saved\"])\n\nlocal push_user_name_by_id = {}\nlocal push_user_options = {}\nlocal push_device_name_by_id = {}\nlocal push_device_options = {}\nlocal saved_push_device_name_by_id = {}\nlocal pending_push_user_ids = {}\nlocal pending_push_device_ids = {}\nlocal push_save_feedback_timer\nlocal push_ui_refresh_timer\n\nlocal function append_normalized_id_values(normalized_ids, seen_ids, source_value)\n  if source_value == nil then\n    return\n  end\n\n  if type(source_value) == \"table\" then\n    local has_array_values = false\n    for _, nested_value in ipairs(source_value) do\n      has_array_values = true\n      append_normalized_id_values(normalized_ids, seen_ids, nested_value)\n    end\n\n    if not has_array_values then\n      for _, nested_value in pairs(source_value) do\n        append_normalized_id_values(normalized_ids, seen_ids, nested_value)\n      end\n    end\n    return\n  end\n\n  local normalized_value = tostring(source_value or \"\"):match(\"^%s*(.-)%s*$\") or \"\"\n  if normalized_value == \"\" or normalized_value == \"nil\" or seen_ids[normalized_value] == true then\n    return\n  end\n\n  table.insert(normalized_ids, normalized_value)\n  seen_ids[normalized_value] = true\nend\n\nlocal function normalize_id_list(source_value)\n  local normalized_ids = {}\n  local seen_ids = {}\n  append_normalized_id_values(normalized_ids, seen_ids, source_value)\n  return normalized_ids\nend\n\nlocal function format_id_list_for_log(source_ids)\n  local normalized_ids = normalize_id_list(source_ids)\n  if #normalized_ids == 0 then\n    return \"[]\"\n  end\n  return \"[\"..table.concat(normalized_ids, \",\")..\"]\"\nend\n\nlocal function safe_ui_callback(callback_name, callback_body)\n  local ok, err = xpcall(callback_body, function(callback_err)\n    return build_error_trace(callback_name, callback_err)\n  end)\n  if not ok then\n    self:error(\"UI callback failed: \"..tostring(err))\n  end\n  return ok\nend\n\nlocal function set_saved_push_user_ids(user_ids)\n  local normalized_ids = normalize_id_list(user_ids)\n  self.store.push_user_ids = copy_id_list(normalized_ids)\n  self.store.push_user_id = self.store.push_user_ids[1] or \"\"\nend\n\nlocal function set_saved_push_device_ids(device_ids)\n  local normalized_ids = normalize_id_list(device_ids)\n  self.store.push_device_ids = copy_id_list(normalized_ids)\n  self.store.push_device_id = self.store.push_device_ids[1] or \"\"\nend\n\nlocal function set_pending_push_user_ids(user_ids)\n  pending_push_user_ids = copy_id_list(normalize_id_list(user_ids))\n  self.store.push_user_ids_pending = copy_id_list(pending_push_user_ids)\n  self.store.push_user_id_pending = pending_push_user_ids[1] or \"\"\nend\n\nlocal function set_pending_push_device_ids(device_ids)\n  pending_push_device_ids = copy_id_list(normalize_id_list(device_ids))\n  self.store.push_device_ids_pending = copy_id_list(pending_push_device_ids)\n  self.store.push_device_id_pending = pending_push_device_ids[1] or \"\"\nend\n\nlocal function get_saved_push_user_ids()\n  return normalize_id_list(self.store.push_user_ids or self.store.push_user_id)\nend\n\nlocal function get_saved_push_device_ids()\n  return normalize_id_list(self.store.push_device_ids or self.store.push_device_id)\nend\n\nlocal function initialize_pending_push_targets()\n  set_saved_push_user_ids(self.store.push_user_ids or self.store.push_user_id)\n  set_saved_push_device_ids(self.store.push_device_ids or self.store.push_device_id)\n\n  local initial_pending_push_user_ids = normalize_id_list(self.store.push_user_ids_pending or self.store.push_user_id_pending)\n  local initial_pending_push_device_ids = normalize_id_list(self.store.push_device_ids_pending or self.store.push_device_id_pending)\n\n  if #initial_pending_push_user_ids == 0 then\n    initial_pending_push_user_ids = get_saved_push_user_ids()\n  end\n  if #initial_pending_push_device_ids == 0 then\n    initial_pending_push_device_ids = get_saved_push_device_ids()\n  end\n\n  set_pending_push_user_ids(initial_pending_push_user_ids)\n  set_pending_push_device_ids(initial_pending_push_device_ids)\nend\n\nlocal function sanitize_selection_ids(source_ids, available_name_by_id)\n  local cleaned_ids = {}\n  local seen_ids = {}\n\n  for _, selected_id in ipairs(normalize_id_list(source_ids)) do\n    if available_name_by_id[selected_id] ~= nil and seen_ids[selected_id] ~= true then\n      table.insert(cleaned_ids, selected_id)\n      seen_ids[selected_id] = true\n    end\n  end\n\n  return cleaned_ids\nend\n\nlocal function build_push_user_catalog_from_api()\n  local push_user_catalog = {}\n\n  for _, user in ipairs(safe_api_get(\"/users\", \"Unable to load push notification recipients\")) do\n    local user_id = tonumber(user and user.id)\n    local user_is_enabled = user ~= nil and user.blocked ~= true and user.disabled ~= true\n    local user_name = tostring(user and (user.name or user.email or user.username or user.id) or \"\")\n    if user_id ~= nil and user_id > 0 and user_is_enabled then\n      table.insert(push_user_catalog, {\n        id = user_id,\n        name = user_name,\n      })\n    end\n  end\n\n  return normalize_catalog_entries(push_user_catalog)\nend\n\nlocal function apply_push_user_catalog(push_user_catalog)\n  local available_push_user_options = {}\n  local available_push_user_name_by_id = {}\n\n  for _, push_user_entry in ipairs(normalize_catalog_entries(push_user_catalog)) do\n    local user_id_string = tostring(push_user_entry.id)\n    local user_name = tostring(push_user_entry.name or \"\")\n    available_push_user_name_by_id[user_id_string] = user_name\n    table.insert(available_push_user_options, {\n      text = format_dropdown_device_option_text(push_user_entry.id, user_name),\n      type = \"option\",\n      value = user_id_string,\n    })\n  end\n\n  push_user_name_by_id = available_push_user_name_by_id\n  push_user_options = available_push_user_options\nend\n\nlocal function load_push_user_options()\n  local push_user_catalog\n  if should_rebuild_startup_discovery_cache() then\n    push_user_catalog = build_push_user_catalog_from_api()\n    write_cached_catalog(\"cached_push_users\", push_user_catalog)\n  else\n    push_user_catalog = read_cached_catalog(\"cached_push_users\")\n  end\n\n  apply_push_user_catalog(push_user_catalog)\n\n  if next(push_user_name_by_id) ~= nil then\n    set_saved_push_user_ids(sanitize_selection_ids(get_saved_push_user_ids(), push_user_name_by_id))\n    set_pending_push_user_ids(sanitize_selection_ids(pending_push_user_ids, push_user_name_by_id))\n  elseif #get_saved_push_user_ids() > 0 or #pending_push_user_ids > 0 then\n    self:warning(\"Push user catalog unavailable, keeping stored push user targets\")\n  end\nend\n\nlocal function get_all_available_push_user_ids()\n  local available_push_user_ids = {}\n  for push_user_id, _ in pairs(push_user_name_by_id) do\n    table.insert(available_push_user_ids, tostring(push_user_id))\n  end\n  table.sort(available_push_user_ids, function(left_id, right_id)\n    return (tonumber(left_id) or 0) < (tonumber(right_id) or 0)\n  end)\n  return available_push_user_ids\nend\n\nlocal function load_push_device_metadata_for_user_ids(push_user_ids, operation_description)\n  local available_push_device_catalog = {}\n  local available_push_device_name_by_id = {}\n\n  for _, selected_push_user_id in ipairs(normalize_id_list(push_user_ids)) do\n    local numeric_push_user_id = tonumber(selected_push_user_id)\n    if numeric_push_user_id ~= nil then\n      for _, device in ipairs(safe_api_get(\"/devices?property=[lastLoggedUser,\"..tostring(numeric_push_user_id)..\"]\", operation_description)) do\n        local device_id = tonumber(device and device.id)\n        local device_name = tostring(device and (device.name or device.userDescription or device.id) or \"\")\n        if device_id ~= nil and device_id > 0 then\n          local device_id_string = tostring(device_id)\n          if available_push_device_name_by_id[device_id_string] == nil then\n            available_push_device_name_by_id[device_id_string] = device_name\n            table.insert(available_push_device_catalog, {\n              id = device_id,\n              name = device_name,\n            })\n          end\n        end\n      end\n    end\n  end\n\n  return normalize_catalog_entries(available_push_device_catalog)\nend\n\nlocal function apply_push_device_catalog(push_device_catalog)\n  local available_push_device_options = {}\n  local available_push_device_name_by_id = {}\n\n  for _, push_device_entry in ipairs(normalize_catalog_entries(push_device_catalog)) do\n    local device_id_string = tostring(push_device_entry.id)\n    local device_name = tostring(push_device_entry.name or \"\")\n    available_push_device_name_by_id[device_id_string] = device_name\n    table.insert(available_push_device_options, {\n      text = format_dropdown_device_option_text(push_device_entry.id, device_name),\n      type = \"option\",\n      value = device_id_string,\n    })\n  end\n\n  push_device_options = available_push_device_options\n  push_device_name_by_id = available_push_device_name_by_id\n  saved_push_device_name_by_id = available_push_device_name_by_id\nend\n\nlocal function load_push_device_options()\n  local push_device_catalog\n  if should_rebuild_startup_discovery_cache() then\n    push_device_catalog = load_push_device_metadata_for_user_ids(\n      get_all_available_push_user_ids(),\n      \"Unable to load push devices\"\n    )\n    write_cached_catalog(\"cached_push_devices\", push_device_catalog)\n  else\n    push_device_catalog = read_cached_catalog(\"cached_push_devices\")\n  end\n\n  apply_push_device_catalog(push_device_catalog)\n\n  if next(push_device_name_by_id) ~= nil then\n    set_saved_push_device_ids(sanitize_selection_ids(get_saved_push_device_ids(), saved_push_device_name_by_id))\n    set_pending_push_device_ids(sanitize_selection_ids(pending_push_device_ids, push_device_name_by_id))\n  elseif #get_saved_push_device_ids() > 0 or #pending_push_device_ids > 0 then\n    self:warning(\"Push device catalog unavailable, keeping stored push device targets\")\n  end\nend\n\nlocal function has_pending_push_target_changes()\n  return selection_signature(pending_push_user_ids) ~= selection_signature(get_saved_push_user_ids())\n    or selection_signature(pending_push_device_ids) ~= selection_signature(get_saved_push_device_ids())\nend\n\nlocal function is_store_toggle_on(store_key)\n  return self.store[store_key] == \"on\"\nend\n\nlocal function get_switch_toggle_value(args, store_key)\n  local selected_value = get_single_callback_value(args)\n  if selected_value == true or selected_value == false then\n    return selected_value\n  end\n  if tostring(selected_value) == \"true\" then\n    return true\n  end\n  if tostring(selected_value) == \"false\" then\n    return false\n  end\n  return not is_store_toggle_on(store_key)\nend\n\nlocal function build_push_toggle_text(icon_symbol, store_key, title_text)\n  local push_toggle_state_text = is_store_toggle_on(store_key) and translation[\"Push ON\"] or translation[\"Push OFF\"]\n  if title_text ~= nil and tostring(title_text) ~= \"\" then\n    return build_icon_text(icon_symbol, tostring(title_text))\n  end\n  return build_icon_text(icon_symbol, push_toggle_state_text)\nend\n\nlocal function refresh_push_user_selector()\n  self:updateView(\"push_user\", \"options\", push_user_options)\n  self:updateView(\"push_user\", \"selectedItems\", pending_push_user_ids)\nend\n\nlocal function refresh_push_device_selector()\n  self:updateView(\"push_device\", \"options\", push_device_options)\n  self:updateView(\"push_device\", \"selectedItems\", pending_push_device_ids)\nend\n\nlocal function refresh_push_selectors()\n  refresh_push_user_selector()\n  refresh_push_device_selector()\nend\n\nlocal function append_saved_push_lines(line_parts, icon_symbol, title_text, selected_ids, name_by_id, empty_text)\n  table.insert(line_parts, color1..build_icon_text(icon_symbol, title_text))\n  if #selected_ids == 0 then\n    table.insert(line_parts, color3..empty_text)\n    return\n  end\n\n  for _, selected_id in ipairs(selected_ids) do\n    local selected_name = name_by_id[selected_id] or (\"ID \"..tostring(selected_id))\n    table.insert(line_parts, color2..selected_name..color1..\" (\"..tostring(selected_id)..\")\")\n  end\nend\n\nlocal function info_push()\n  local line_parts = {}\n  append_saved_push_lines(\n    line_parts,\n    qa_ui_icons.profile,\n    translation[\"Push User\"],\n    get_saved_push_user_ids(),\n    push_user_name_by_id,\n    translation[\"No push user selected\"]\n  )\n  append_saved_push_lines(\n    line_parts,\n    qa_ui_icons.device,\n    translation[\"Push Device\"],\n    get_saved_push_device_ids(),\n    saved_push_device_name_by_id,\n    translation[\"No push device selected\"]\n  )\n  table.insert(line_parts, color1..build_icon_text(qa_ui_icons.sunrise, translation[\"Sunrise Push\"])..\": \"..color2..translation[\"Sends push when the sunrise event runs\"])\n  table.insert(line_parts, color1..build_icon_text(qa_ui_icons.sunset, translation[\"Sunset Push\"])..\": \"..color2..translation[\"Sends push when the sunset event runs\"])\n\n  self:updateView(\"info_push\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..table.concat(line_parts, \"\\n\")..\"   </tt></font></section>\")\nend\n\nlocal function refresh_push_toggle_button(view_name, icon_symbol, store_key, title_text)\n  self:updateView(view_name, \"value\", is_store_toggle_on(store_key) and \"true\" or \"false\")\n  self:updateView(view_name, \"text\", build_push_toggle_text(icon_symbol, store_key, title_text))\nend\n\nlocal function refresh_push_save_button(saved_state)\n  if push_save_feedback_timer ~= nil then\n    hub.clearTimeout(push_save_feedback_timer)\n    push_save_feedback_timer = nil\n  end\n\n  if saved_state == true then\n    self:updateView(\"push_save\", \"text\", push_save_button_active_text)\n    self:updateView(\"push_save\", \"value\", \"true\")\n    push_save_feedback_timer = hub.setTimeout(1000, function()\n      push_save_feedback_timer = nil\n      safe_ui_callback(\"refresh_push_save_button_timer\", function()\n        refresh_push_save_button()\n      end)\n    end)\n    return\n  end\n\n  if has_pending_push_target_changes() then\n    self:updateView(\"push_save\", \"text\", push_save_button_pending_text)\n  else\n    self:updateView(\"push_save\", \"text\", push_save_button_idle_text)\n  end\n  self:updateView(\"push_save\", \"value\", \"false\")\nend\n\nlocal function queue_push_ui_refresh(force_options_reload, saved_state)\n  if push_ui_refresh_timer ~= nil then\n    hub.clearTimeout(push_ui_refresh_timer)\n    push_ui_refresh_timer = nil\n  end\n\n  push_ui_refresh_timer = hub.setTimeout(75, function()\n    push_ui_refresh_timer = nil\n    safe_ui_callback(\"queue_push_ui_refresh\", function()\n      if force_options_reload == true then\n        refresh_push_selectors()\n      else\n        self:updateView(\"push_user\", \"selectedItems\", pending_push_user_ids)\n        self:updateView(\"push_device\", \"selectedItems\", pending_push_device_ids)\n      end\n      info_push()\n      refresh_push_save_button(saved_state)\n    end)\n  end)\nend\n\nlocal function build_numeric_id_list(source_ids)\n  local numeric_ids = {}\n  for _, selected_id in ipairs(normalize_id_list(source_ids)) do\n    local numeric_selected_id = tonumber(selected_id)\n    if numeric_selected_id ~= nil then\n      table.insert(numeric_ids, numeric_selected_id)\n    end\n  end\n  return numeric_ids\nend\n\nlocal function send_alert_to_each_target(alert_type, target_ids, notification_text, throttle_key, error_prefix)\n  local alert_sent = false\n\n  for _, target_id in ipairs(build_numeric_id_list(target_ids)) do\n    local ok, push_result = pcall(\n      hub.alert,\n      alert_type,\n      {[1] = target_id},\n      tostring(notification_text or \"\"),\n      false,\n      \"\",\n      false\n    )\n    if not ok then\n      log_throttled(\n        \"warning\",\n        tostring(throttle_key)..\":\"..tostring(target_id),\n        tostring(error_prefix)..\": \"..tostring(push_result)\n      )\n    else\n      alert_sent = true\n    end\n  end\n\n  return alert_sent\nend\n\nlocal function get_push_user_target_ids(use_pending_fallback)\n  local target_ids = get_saved_push_user_ids()\n  if use_pending_fallback == true and #target_ids == 0 then\n    target_ids = normalize_id_list(pending_push_user_ids)\n  end\n  return target_ids\nend\n\nlocal function get_push_device_target_ids(use_pending_fallback)\n  local target_ids = get_saved_push_device_ids()\n  if use_pending_fallback == true and #target_ids == 0 then\n    target_ids = normalize_id_list(pending_push_device_ids)\n  end\n  return target_ids\nend\n\nlocal function safe_send_push_notification(store_key, event_name, notification_text, force_send)\n  if not force_send and not is_store_toggle_on(store_key) then\n    return\n  end\n\n  local push_user_target_ids = get_push_user_target_ids(force_send)\n  local push_device_target_ids = get_push_device_target_ids(force_send)\n  self:debug(\n    \"Push send \"..tostring(event_name)\n      ..\" users=\"..format_id_list_for_log(push_user_target_ids)\n      ..\" devices=\"..format_id_list_for_log(push_device_target_ids)\n      ..\" force=\"..tostring(force_send == true)\n      ..\" devicePush=\"..tostring(is_store_toggle_on(\"push_device_onoff\"))\n  )\n\n  local push_sent = false\n  if send_alert_to_each_target(\n    \"push\",\n    push_user_target_ids,\n    notification_text,\n    \"hub_alert:push:\"..tostring(store_key),\n    \"Push notification failed for \"..tostring(event_name)\n  ) then\n    push_sent = true\n  end\n\n  if force_send or is_store_toggle_on(\"push_device_onoff\") then\n    if send_alert_to_each_target(\n      \"simplePush\",\n      push_device_target_ids,\n      notification_text,\n      \"hub_alert:simplePush:\"..tostring(store_key),\n      \"Device push notification failed for \"..tostring(event_name)\n    ) then\n      push_sent = true\n    end\n  end\n\n  if not push_sent then\n    log_throttled(\"warning\", \"hub_alert:push:\"..tostring(store_key), \"Push notification skipped for \"..tostring(event_name)..\" because no push target is selected\")\n  end\nend\n\nsafe_startup_call(\"initialize_pending_push_targets\", initialize_pending_push_targets)\nsafe_startup_call(\"load_push_user_options\", load_push_user_options)\nsafe_startup_call(\"load_push_device_options\", load_push_device_options)\nsafe_startup_call(\"mark_startup_discovery_cache_ready\", function()\n  mark_startup_discovery_cache_ready()\n  refresh_startup_discovery_cache = false\nend)\nsafe_startup_call(\"refresh_push_selectors\", refresh_push_selectors)\nsafe_startup_call(\"info_push\", info_push)\nsafe_startup_call(\"refresh_push_save_button\", refresh_push_save_button)\n\n\n\n\n\n\n\n----------------------------------------------------------------\n-----scnes dropdown list\n    local update_select_list = {\n        {text = \"\"..translation[\"No Action\"]..\"\", type = \"option\", value = \"no_action\"},\n        {text = \"\"..scene1..\"\", type = \"option\", value = \"scene1\"},\n        {text = \"\"..scene2..\"\", type = \"option\", value = \"scene2\"},\n        {text = \"\"..scene3..\"\", type = \"option\", value = \"scene3\"},\n        {text = \"\"..scene4..\"\", type = \"option\", value = \"scene4\"},\n        {text = \"\"..scene5..\"\", type = \"option\", value = \"scene5\"},\n        {text = \"\"..scene6..\"\", type = \"option\", value = \"scene6\"},\n        {text = \"\"..translation[\"Turn ON\"]..\"\", type = \"option\", value = \"turnOn\"},\n        {text = \"\"..translation[\"Turn OFF\"]..\"\", type = \"option\", value = \"turnOff\"}\n\n\n\n    }\n    self:updateView(\"bp1_scene_on\", \"options\", update_select_list)\n    self:updateView(\"bp1_scene_off\", \"options\", update_select_list)\n    self:updateView(\"bp1_scene_off_delay\", \"options\", update_select_list)\n\n    self:updateView(\"sunset_select\", \"options\", update_select_list)\n    self:updateView(\"sunset_select_delay\", \"options\", update_select_list)\n    self:updateView(\"sunrise_select\", \"options\", update_select_list)\n    self:updateView(\"sunrise_select_delay\", \"options\", update_select_list)\n    self:updateView(\"nightmode_select_on\", \"options\", update_select_list)\n    self:updateView(\"nightmode_select_off\", \"options\", update_select_list)\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n-----label update Lights\nlocal function info_selectlight()\n    local line1 = \"<font size='\"..(Fontsize+2)..\"'>\"..color1..\"\"..translation[\"Room Name: \"]..\"\"..color2..\"\"..build_trailing_icon_text(self_room_name, qa_ui_icons.room)..\"\"\n    local line2 = \"\"..color1..\" \"..translation[\"Room ID: \"]..\"\"..color2..\"\"..build_trailing_icon_text(self_room_id, qa_ui_icons.identifier)..\" <font size='\"..Fontsize..\"'>\\n\"\n    local line3 = \"\"..color1..\"\"\n    local line4 = \"\"\n    local rownumber = 1\n      for _,value in ipairs(light_ids or {}) do\n    --local var = tostring(hub.getValue(light_ids[rownumber], \"value\"))\n    line3 = \"\"..line3..\" \"..color1..\"\"..translation[\"Light Name: \"]..\" \"..color2..\"\"..build_trailing_icon_text(light_name[rownumber], qa_ui_icons.light)..\" \\n \"..color1..\"\"..translation[\"Light id:\"]..\"\"..color2..\"\"..build_trailing_icon_text(light_ids[rownumber], qa_ui_icons.identifier)..\"  \\n\\n \" \n      rownumber = rownumber + 1\n      end \n    if selection_signature(pending_lightid_trigger_select) ~= selection_signature(lightid_trigger_select) then\n      line4 = \"\\n\"..color1..\"\"..build_icon_text(qa_ui_icons.save, translation[\"Pending Light ids:\"])..\"\\n\"\n      for _, pending_light_id in ipairs(pending_lightid_trigger_select or {}) do\n        line4 = \"\"..line4..\"\"..color1..\"\"..translation[\"Light id:\"]..\" \"..color2..\"\"..build_trailing_icon_text(pending_light_id, qa_ui_icons.identifier)..\" \\n\"\n      end\n    end\n    self:updateView(\"info_selectlight\", \"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line1..\"\\n\"..line2..\"\\n\"..line3..\"\\n\"..line4..\"   </tt></font></section>\")\n\n\n\nend\n  safe_startup_call(\"info_selectlight\", info_selectlight)\n----------------------------------------------------------------------------------------------------------\n----update lights choice list on startup\n  local update_light_list = {}\n  local save_light_feedback_timer\n  local function refresh_save_light_button(saved_state)\n    if save_light_feedback_timer ~= nil then\n      hub.clearTimeout(save_light_feedback_timer)\n      save_light_feedback_timer = nil\n    end\n\n    local has_pending_changes = selection_signature(pending_lightid_trigger_select) ~= selection_signature(lightid_trigger_select)\n\n    if saved_state == true then\n      self:updateView(\"save_light\", \"text\", save_light_button_active_text)\n      self:updateView(\"save_light\", \"value\", \"true\")\n      save_light_feedback_timer = hub.setTimeout(1000, function()\n        save_light_feedback_timer = nil\n        refresh_save_light_button()\n      end)\n      return\n    end\n\n    if has_pending_changes then\n      self:updateView(\"save_light\", \"text\", save_light_button_pending_text)\n    else\n      self:updateView(\"save_light\", \"text\", save_light_button_idle_text)\n    end\n    self:updateView(\"save_light\", \"value\", \"false\")\n  end\n\n  local function update_light_list_if()\n    local next_update_light_list = {}\n    for ind,val in ipairs(light_ids) do\n        if light_ids[ind] ~= nil then\n        next_update_light_list[#next_update_light_list + 1] = {text = format_dropdown_device_option_text(light_ids[ind], light_name[ind]), type = \"option\", value = \"\"..light_ids[ind]..\"\"}\n        end\n     \n    end\n    update_light_list = next_update_light_list\n    self:updateView(\"select_light_setup\", \"options\", update_light_list)\n    self:updateView(\"select_light_setup\", \"selectedItems\", pending_lightid_trigger_select)\n    refresh_save_light_button()\n  end \n    safe_startup_call(\"update_light_list_if\", update_light_list_if) \n----------------------------------------------------------------------------------------------------------\n-----dropdown list handler for lights choice\n  local var3 = {}\n  function QuickApp:select_light_setup(args)\n    local selected_values = get_multi_callback_value(args)\n    if selected_values == nil then\n      return\n    end\n    var3 = sanitize_light_selection(selected_values)\n    --print(\"var3\", json.encode(var3))\n\n    pending_lightid_trigger_select = copy_id_list(var3)\n    self:updateView(\"select_light_setup\", \"selectedItems\", var3)\n    info_selectlight()\n    refresh_save_light_button()\n  end\n\n  function QuickApp:save_light(args)\n    lightid_trigger_select = sanitize_light_selection(pending_lightid_trigger_select)\n    pending_lightid_trigger_select = copy_id_list(lightid_trigger_select)\n    lightid_trigger = build_id_lookup(lightid_trigger_select)\n    self.store.lightid_trigger = build_id_lookup(lightid_trigger_select)\n    self.store.lightid_trigger_select = copy_id_list(lightid_trigger_select)\n    self:updateView(\"select_light_setup\", \"selectedItems\", pending_lightid_trigger_select)\n    info_selectlight()\n    info_save1()\n    info_save2()\n    info_save3()\n    info_save4()\n    info_save5()\n    info_save6()\n    refresh_save_light_button(true)\n  end\n\nlocal function get_scene_display_name(scene_no)\n  if tonumber(scene_no) == 1 then return scene1 end\n  if tonumber(scene_no) == 2 then return scene2 end\n  if tonumber(scene_no) == 3 then return scene3 end\n  if tonumber(scene_no) == 4 then return scene4 end\n  if tonumber(scene_no) == 5 then return scene5 end\n  if tonumber(scene_no) == 6 then return scene6 end\n  return \"scene\"..tostring(scene_no)\nend\n\nlocal function get_scene_snapshot_store(scene_no, store_suffix)\n  return self.store[\"save\"..scene_no..\"_\"..store_suffix] or {}\nend\n\nlocal function get_scene_snapshot_value(scene_store, light_device_id, light_position)\n  local light_device_key = tostring(light_device_id)\n  if scene_store[light_device_key] ~= nil then return scene_store[light_device_key] end\n  if scene_store[tonumber(light_device_id)] ~= nil then return scene_store[tonumber(light_device_id)] end\n  if scene_store[light_position] ~= nil then return scene_store[light_position] end\n  if scene_store[tostring(light_position)] ~= nil then return scene_store[tostring(light_position)] end\n  return nil\nend\n\nlocal function normalize_light_value(value)\n  if value == true or value == false then\n    return value\n  end\n  local value_number = tonumber(value)\n  if value_number ~= nil then\n    return math.floor(value_number + 0.5)\n  end\n  local value_text = string.lower(tostring(value or \"\"))\n  if value_text == \"true\" or value_text == \"on\" then return true end\n  if value_text == \"false\" or value_text == \"off\" then return false end\n  return value\nend\n\nlocal function light_values_match(expected_value, actual_value)\n  local normalized_expected = normalize_light_value(expected_value)\n  local normalized_actual = normalize_light_value(actual_value)\n  if normalized_expected == true then\n    return normalized_actual == true or (tonumber(normalized_actual) or 0) > 0\n  end\n  if normalized_expected == false then\n    return normalized_actual == false or (tonumber(normalized_actual) or 0) == 0\n  end\n  local expected_number = tonumber(normalized_expected)\n  local actual_number = tonumber(normalized_actual)\n  if expected_number ~= nil and actual_number ~= nil then\n    return math.abs(expected_number - actual_number) <= 1\n  end\n  return tostring(normalized_expected) == tostring(normalized_actual)\nend\n\nlocal function scene_matches_current_lights(scene_no)\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  if next(selected_light_ids) == nil then\n    return false\n  end\n\n  local scene_value_by_device_id = get_scene_snapshot_store(scene_no, \"value\")\n  for selected_index, selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      local expected_value = get_scene_snapshot_value(scene_value_by_device_id, light_device_id, selected_index)\n      if expected_value == nil then\n        return false\n      end\n      local actual_value = safe_hub_get_value(light_device_id, \"value\", \"Unable to match startup scene\")\n      if actual_value == nil or not light_values_match(expected_value, actual_value) then\n        return false\n      end\n    end\n  end\n  return true\nend\n\nlocal function find_matching_scene_action()\n  for scene_no = 1, 6 do\n    if scene_matches_current_lights(scene_no) then\n      return \"scene\"..tostring(scene_no), get_scene_display_name(scene_no)\n    end\n  end\n  return nil, nil\nend\n\nlocal function get_color_program_name(color_program_id)\n  local color_program_string = tostring(color_program_id)\n  if color_program_string == \"1\" then return translation[\"Fire\"] end\n  if color_program_string == \"2\" then return translation[\"Storm\"] end\n  if color_program_string == \"3\" then return translation[\"RGB\"] end\n  if color_program_string == \"4\" then return translation[\"Aurora\"] end\n  if color_program_string == \"5\" then return translation[\"Police\"] end\n  if color_program_string == \"0\" then return translation[\"No Program\"] end\n  return translation[\"No Program\"]\nend\n\nlocal function get_light_display_name(light_device_id)\n  return light_name_by_id[tostring(light_device_id)] or (\"ID \"..tostring(light_device_id))\nend\n\nlocal add_error_status\nlocal light_health = {generation = 0}\n\nfunction light_health.unregister_event(active_check)\n  if active_check == nil or active_check.event_key == nil then\n    return\n  end\n  pcall(function()\n    Event:disable(active_check.event_key)\n    Event:cancelAll(active_check.event_key)\n  end)\n  active_check.event_key = nil\nend\n\nfunction light_health.clear_active()\n  local active_check = light_health.active_check\n  if active_check == nil then\n    return\n  end\n  if active_check.timer_ref ~= nil then\n    hub.clearTimeout(active_check.timer_ref)\n    active_check.timer_ref = nil\n  end\n  light_health.unregister_event(active_check)\n  light_health.active_check = nil\nend\n\nfunction light_health.is_complete(active_check)\n  for _, is_pending in pairs(active_check.pending_by_device_id or {}) do\n    if is_pending == true then\n      return false\n    end\n  end\n  return true\nend\n\nfunction light_health.format_checked_lights(active_check)\n  local light_lines = {}\n  for _, light_device_id in ipairs(active_check.expected_light_ids or {}) do\n    local light_device_key = tostring(light_device_id)\n    local expected_value = active_check.expected_value_by_device_id[light_device_key]\n    table.insert(\n      light_lines,\n      get_light_display_name(light_device_id)..\"=\"..tostring(expected_value)\n    )\n  end\n  if #light_lines == 0 then\n    return \"\"\n  end\n  return \"\\n  \"..table.concat(light_lines, \"\\n  \")\nend\n\nfunction light_health.finish(active_check, log_text, is_error)\n  if light_health.active_check ~= active_check then\n    return\n  end\n  if active_check.timer_ref ~= nil then\n    hub.clearTimeout(active_check.timer_ref)\n    active_check.timer_ref = nil\n  end\n  light_health.unregister_event(active_check)\n  light_health.active_check = nil\n  if log_text ~= nil then\n    add_error_status(log_text, is_error)\n  end\nend\n\nfunction light_health.handle_event(active_check, event)\n  if light_health.active_check ~= active_check then\n    return\n  end\n  local light_device_id = tonumber(event and event.id)\n  local light_device_key = tostring(light_device_id or \"\")\n  local expected_value = active_check.expected_value_by_device_id[light_device_key]\n  if expected_value == nil then\n    return\n  end\n  if not light_values_match(expected_value, event.value) then\n    return\n  end\n\n  active_check.pending_by_device_id[light_device_key] = nil\n  if light_health.is_complete(active_check) then\n    light_health.finish(\n      active_check,\n      translation[\"Health check\"]..\" \"..tostring(active_check.check_name)..\": \"..translation[\"OK\"]..\" (EventLib)\"..light_health.format_checked_lights(active_check),\n      false\n    )\n  end\nend\n\nfunction light_health.register_event(active_check)\n  if LIGHT_HEALTH_CHECK_EVENT_CONFIRM ~= true or #active_check.expected_light_ids == 0 then\n    return\n  end\n  light_health.generation = light_health.generation + 1\n  active_check.event_key = \"light_health_check_\"..tostring(light_health.generation)\n\n  local register_ok, register_error = pcall(function()\n    Event.id = active_check.event_key\n    Event.tagColor = \"Green\"\n    Event {type='device', id=active_check.expected_light_ids, property='value', value='$value'}\n    function Event:handler(event)\n      light_health.handle_event(active_check, event)\n    end\n  end)\n  if not register_ok then\n    active_check.event_key = nil\n    self:warning(\"Unable to register light health EventLib listener: \"..tostring(register_error))\n  end\nend\n\nfunction light_health.wake_dead_device(light_device_id)\n  if LIGHT_HEALTH_WAKE_DEAD_ON_RETRY ~= true then\n    return\n  end\n\n  local wake_ok, wake_error = pcall(hub.call, light_device_id, \"wakeUpDeadDevice\")\n  if wake_ok then\n    add_error_status(translation[\"Health check\"]..\" \"..get_light_display_name(light_device_id)..\": wakeUpDeadDevice\", true)\n    return\n  end\n  log_throttled(\n    \"warning\",\n    \"hub_call:\"..tostring(light_device_id)..\":wakeUpDeadDevice\",\n    \"Device wake failed for \"..get_light_display_name(light_device_id)..\": \"..tostring(wake_error)\n  )\nend\n\nfunction light_health.schedule_retry_verify(active_check, light_device_ids, retry_attempt)\n  local verify_delay_seconds = tonumber(LIGHT_HEALTH_RETRY_VERIFY_DELAY_SECONDS) or 5\n  if verify_delay_seconds < 1 then\n    verify_delay_seconds = 1\n  end\n\n  hub.setTimeout(verify_delay_seconds * 1000, function()\n    if light_health.active_check ~= active_check then\n      return\n    end\n    if tonumber(active_check.retry_attempt or 0) ~= tonumber(retry_attempt or 0) then\n      return\n    end\n\n    for _, light_device_id in ipairs(light_device_ids or {}) do\n      local light_device_key = tostring(light_device_id)\n      local expected_value = active_check.expected_value_by_device_id[light_device_key]\n      if expected_value ~= nil then\n        local actual_value = safe_hub_get_value(light_device_id, \"value\", \"Unable to verify health retry\")\n        if actual_value == nil then\n          add_error_status(translation[\"Health check\"]..\" \"..get_light_display_name(light_device_id)..\": still unreadable after retry\", true)\n        elseif light_values_match(expected_value, actual_value) then\n          add_error_status(translation[\"Health check\"]..\" \"..get_light_display_name(light_device_id)..\": reading correct after retry (\"..tostring(actual_value)..\")\", false)\n        else\n          add_error_status(\n            translation[\"Health check\"]..\" \"..get_light_display_name(light_device_id)..\": still expected \"\n              ..tostring(expected_value)..\" got \"..tostring(actual_value),\n            true\n          )\n        end\n      end\n    end\n  end)\nend\n\nfunction light_health.retry_pending(active_check, mismatch_light_ids, mismatch_lines)\n  local max_retry_attempts = tonumber(LIGHT_HEALTH_MAX_RETRY_ATTEMPTS) or 3\n  if max_retry_attempts < 0 then\n    max_retry_attempts = 0\n  end\n  active_check.retry_attempt = tonumber(active_check.retry_attempt or 0) or 0\n\n  if active_check.retry_attempt >= max_retry_attempts then\n    light_health.finish(active_check, translation[\"Health check\"]..\" \"..tostring(active_check.check_name)..\": \"..table.concat(mismatch_lines, \"; \"), true)\n    return\n  end\n\n  active_check.retry_attempt = active_check.retry_attempt + 1\n  add_error_status(\n    translation[\"Health check\"]..\" \"..tostring(active_check.check_name)..\": retry \"\n      ..tostring(active_check.retry_attempt)..\"/\"..tostring(max_retry_attempts)..\" - \"..table.concat(mismatch_lines, \"; \"),\n    true\n  )\n\n  for _, light_device_id in ipairs(mismatch_light_ids or {}) do\n    local light_device_key = tostring(light_device_id)\n    active_check.pending_by_device_id[light_device_key] = true\n    light_health.wake_dead_device(light_device_id)\n    local retry_command = (active_check.retry_command_by_device_id or {})[light_device_key]\n    if type(retry_command) == \"function\" then\n      local retry_ok, retry_error = pcall(retry_command)\n      if not retry_ok then\n        self:warning(\"Unable to retry light command for \"..get_light_display_name(light_device_id)..\": \"..tostring(retry_error))\n      end\n    else\n      self:warning(\"No retry command registered for \"..get_light_display_name(light_device_id))\n    end\n  end\n\n  light_health.schedule_timer(active_check)\n  light_health.schedule_retry_verify(active_check, mismatch_light_ids, active_check.retry_attempt)\nend\n\nfunction light_health.schedule_timer(active_check)\n  local delay_seconds = tonumber(LIGHT_HEALTH_CHECK_DELAY_SECONDS) or 30\n  if delay_seconds < 1 then\n    delay_seconds = 1\n  end\n\n  if active_check.timer_ref ~= nil then\n    hub.clearTimeout(active_check.timer_ref)\n    active_check.timer_ref = nil\n  end\n\n  active_check.timer_ref = hub.setTimeout(delay_seconds * 1000, function()\n    if light_health.active_check ~= active_check then\n      return\n    end\n    local mismatch_lines = {}\n    local mismatch_light_ids = {}\n    local checked_count = 0\n    for _, selected_light_id in ipairs(self.store.lightid_trigger_select or {}) do\n      local light_device_id = tonumber(selected_light_id)\n      if light_device_id ~= nil then\n        local light_device_key = tostring(light_device_id)\n        local expected_value = active_check.expected_value_by_device_id[light_device_key]\n        if expected_value ~= nil then\n          checked_count = checked_count + 1\n          local actual_value = safe_hub_get_value(light_device_id, \"value\", \"Unable to health check light value\")\n          if actual_value == nil then\n            table.insert(mismatch_light_ids, light_device_id)\n            table.insert(mismatch_lines, get_light_display_name(light_device_id)..\" unreadable\")\n          elseif not light_values_match(expected_value, actual_value) then\n            table.insert(mismatch_light_ids, light_device_id)\n            table.insert(mismatch_lines, get_light_display_name(light_device_id)..\" expected \"..tostring(expected_value)..\" got \"..tostring(actual_value))\n          elseif LIGHT_HEALTH_CHECK_EVENT_CONFIRM == true and active_check.pending_by_device_id[light_device_key] == true then\n            table.insert(mismatch_light_ids, light_device_id)\n            table.insert(mismatch_lines, get_light_display_name(light_device_id)..\" no EventLib update\")\n          end\n        end\n      end\n    end\n\n    if #mismatch_lines > 0 then\n      light_health.retry_pending(active_check, mismatch_light_ids, mismatch_lines)\n    elseif checked_count > 0 then\n      light_health.finish(\n        active_check,\n        translation[\"Health check\"]..\" \"..tostring(active_check.check_name)..\": \"..translation[\"OK\"]..light_health.format_checked_lights(active_check),\n        false\n      )\n    end\n  end)\nend\n\nlocal function schedule_light_health_check(check_name, expected_value_by_device_id, retry_command_by_device_id)\n  light_health.clear_active()\n\n  local active_check = {\n    check_name = check_name,\n    expected_light_ids = {},\n    expected_value_by_device_id = {},\n    pending_by_device_id = {},\n    retry_attempt = 0,\n    retry_command_by_device_id = retry_command_by_device_id or {},\n  }\n\n  for light_device_id, expected_value in pairs(expected_value_by_device_id or {}) do\n    local numeric_light_device_id = tonumber(light_device_id)\n    if numeric_light_device_id ~= nil and expected_value ~= nil then\n      local light_device_key = tostring(numeric_light_device_id)\n      active_check.expected_value_by_device_id[light_device_key] = expected_value\n      active_check.pending_by_device_id[light_device_key] = true\n      table.insert(active_check.expected_light_ids, numeric_light_device_id)\n    end\n  end\n\n  if #active_check.expected_light_ids == 0 then\n    return\n  end\n\n  light_health.active_check = active_check\n  light_health.register_event(active_check)\n  light_health.schedule_timer(active_check)\nend\n\nlocal function build_color_component_table(color_value)\n  if color_value == nil then\n    return nil\n  end\n\n  if type(color_value) == \"table\" then\n    return {\n      red = tonumber(color_value.red or color_value[1]) or 0,\n      green = tonumber(color_value.green or color_value[2]) or 0,\n      blue = tonumber(color_value.blue or color_value[3]) or 0,\n      warmWhite = tonumber(color_value.warmWhite or color_value.white or color_value[4]) or 0,\n    }\n  end\n\n  local color_value_string = tostring(color_value)\n  if color_value_string == \"\" or string.lower(color_value_string) == \"nil\" then\n    return nil\n  end\n\n  local color_components = {}\n  for component_value in string.gmatch(color_value_string, '([^,]+)') do\n    table.insert(color_components, tonumber(component_value) or 0)\n  end\n\n  if #color_components < 3 then\n    return nil\n  end\n\n  return {\n    red = color_components[1] or 0,\n    green = color_components[2] or 0,\n    blue = color_components[3] or 0,\n    warmWhite = color_components[4] or 0,\n  }\nend\n\nlocal function save_scene_snapshot(scene_no)\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  local scene_value_by_device_id = {}\n  local scene_color_components_by_device_id = {}\n  local scene_color_string_by_device_id = {}\n  local scene_color_program_by_device_id = {}\n\n  if next(selected_light_ids) == nil then\n    self:warning(\"Scene \"..tostring(scene_no)..\" save skipped because no lights are selected\")\n    return\n  end\n\n  for _, selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      local light_device_key = tostring(light_device_id)\n      local current_color_value = safe_hub_get_value(light_device_id, \"color\", \"Unable to save light color\")\n      scene_value_by_device_id[light_device_key] = safe_hub_get_value(light_device_id, \"value\", \"Unable to save light value\")\n      scene_color_components_by_device_id[light_device_key] = build_color_component_table(current_color_value)\n      scene_color_string_by_device_id[light_device_key] = current_color_value ~= nil and tostring(current_color_value) or nil\n      scene_color_program_by_device_id[light_device_key] = safe_hub_get_value(light_device_id, \"currentProgramID\", \"Unable to save light color program\")\n    else\n      self:warning(\"Scene \"..tostring(scene_no)..\" save skipped invalid light ID \"..tostring(selected_light_id))\n    end\n  end\n\n  self.store[\"save\"..scene_no..\"_value\"] = scene_value_by_device_id\n  self.store[\"save\"..scene_no..\"_color\"] = scene_color_components_by_device_id\n  self.store[\"save\"..scene_no..\"_color_string\"] = scene_color_string_by_device_id\n  self.store[\"save\"..scene_no..\"_color_program\"] = scene_color_program_by_device_id\nend\n\nlocal function apply_scene_color(light_device_id, color_component_table, raw_color_value)\n  local normalized_color_components = color_component_table\n  if type(normalized_color_components) ~= \"table\" and raw_color_value ~= nil then\n    normalized_color_components = build_color_component_table(raw_color_value)\n  end\n\n  if type(normalized_color_components) ~= \"table\" then\n    self:warning(\"Skipped RGB apply for light \"..tostring(light_device_id)..\" because color data is invalid: \"..tostring(raw_color_value or color_component_table))\n    return\n  end\n\n  safe_hub_call(\n    light_device_id,\n    \"setColor\",\n    tonumber(normalized_color_components.red) or 0,\n    tonumber(normalized_color_components.green) or 0,\n    tonumber(normalized_color_components.blue) or 0,\n    tonumber(normalized_color_components.warmWhite) or 0\n  )\nend\n\nlocal button_labels_false\n\nlocal function apply_scene_snapshot(scene_no, primary_button_name, secondary_button_name)\n  button_labels_false()\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  local scene_name = get_scene_display_name(scene_no)\n  local scene_value_by_device_id = get_scene_snapshot_store(scene_no, \"value\")\n  local scene_color_components_by_device_id = get_scene_snapshot_store(scene_no, \"color\")\n  local scene_color_string_by_device_id = get_scene_snapshot_store(scene_no, \"color_string\")\n  local scene_color_program_by_device_id = get_scene_snapshot_store(scene_no, \"color_program\")\n  local delayed_program_actions = {}\n  local expected_value_by_device_id = {}\n  local retry_command_by_device_id = {}\n\n  if next(selected_light_ids) == nil then\n    self:warning(\"Scene \"..tostring(scene_name)..\" apply skipped because no lights are selected\")\n    return\n  end\n\n  for selected_index, selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      local stored_light_value = get_scene_snapshot_value(scene_value_by_device_id, light_device_id, selected_index)\n      local stored_light_color_components = get_scene_snapshot_value(scene_color_components_by_device_id, light_device_id, selected_index)\n      local stored_light_color_string = get_scene_snapshot_value(scene_color_string_by_device_id, light_device_id, selected_index)\n      local stored_color_program = get_scene_snapshot_value(scene_color_program_by_device_id, light_device_id, selected_index)\n      local color_program_string = tostring(stored_color_program)\n      local normalized_light_value = tonumber(stored_light_value)\n      local light_device_key = tostring(light_device_id)\n      expected_value_by_device_id[light_device_key] = stored_light_value\n\n      if normalized_light_value == nil and (stored_light_value == true or tostring(stored_light_value) == \"true\") then\n        normalized_light_value = true\n      elseif normalized_light_value == nil and (stored_light_value == false or tostring(stored_light_value) == \"false\") then\n        normalized_light_value = false\n      end\n\n      retry_command_by_device_id[light_device_key] = function()\n        if color_program_string == \"1\" or color_program_string == \"2\" or color_program_string == \"3\" or color_program_string == \"4\" or color_program_string == \"5\" then\n          if normalized_light_value ~= nil and normalized_light_value ~= true and normalized_light_value ~= false then\n            safe_hub_call(light_device_id, \"setValue\", normalized_light_value)\n          elseif normalized_light_value == true then\n            safe_hub_call(light_device_id, \"turnOn\")\n          end\n          hub.setTimeout(color_transit_time, function()\n            safe_hub_call(light_device_id, \"startProgram\", stored_color_program)\n          end)\n          return\n        end\n\n        if stored_light_color_components == nil and stored_light_color_string ~= nil then\n          stored_light_color_components = build_color_component_table(stored_light_color_string)\n        end\n\n        if normalized_light_value == true then\n          safe_hub_call(light_device_id, \"turnOn\")\n        elseif normalized_light_value == false then\n          safe_hub_call(light_device_id, \"turnOff\")\n        elseif normalized_light_value ~= nil then\n          safe_hub_call(light_device_id, \"setValue\", normalized_light_value)\n        end\n\n        if stored_light_color_components ~= nil and normalized_light_value ~= false and normalized_light_value ~= 0 then\n          apply_scene_color(light_device_id, stored_light_color_components, stored_light_color_string)\n        end\n      end\n\n      if color_program_string == \"1\" or color_program_string == \"2\" or color_program_string == \"3\" or color_program_string == \"4\" or color_program_string == \"5\" then\n        if normalized_light_value ~= nil and normalized_light_value ~= true and normalized_light_value ~= false then\n          safe_hub_call(light_device_id, \"setValue\", normalized_light_value)\n        end\n        table.insert(delayed_program_actions, {\n          light_device_id = light_device_id,\n          color_program_id = stored_color_program,\n        })\n      else\n        if stored_light_color_components == nil and stored_light_color_string ~= nil then\n          stored_light_color_components = build_color_component_table(stored_light_color_string)\n        end\n\n        if normalized_light_value == true then\n          safe_hub_call(light_device_id, \"turnOn\")\n        elseif normalized_light_value == false then\n          safe_hub_call(light_device_id, \"turnOff\")\n        elseif normalized_light_value ~= nil then\n          safe_hub_call(light_device_id, \"setValue\", normalized_light_value)\n        end\n\n        if stored_light_color_components ~= nil and normalized_light_value ~= false and normalized_light_value ~= 0 then\n          apply_scene_color(light_device_id, stored_light_color_components, stored_light_color_string)\n        end\n      end\n    else\n      self:warning(\"Scene \"..tostring(scene_name)..\" apply skipped invalid light ID \"..tostring(selected_light_id))\n    end\n  end\n\n  if next(delayed_program_actions) ~= nil then\n    hub.setTimeout(color_transit_time, function()\n      for _, delayed_program_action in ipairs(delayed_program_actions) do\n        safe_hub_call(\n          delayed_program_action.light_device_id,\n          \"startProgram\",\n          delayed_program_action.color_program_id\n        )\n      end\n    end)\n  end\n\n  self.store.current_scene = tostring(scene_name)\n  self.store.current_scene_action = \"scene\"..tostring(scene_no)\n  self:updateProperty(\"log\", tostring(scene_name))\n  if primary_button_name ~= nil then self:updateView(primary_button_name, \"value\", \"true\") end\n  if secondary_button_name ~= nil then self:updateView(secondary_button_name, \"value\", \"true\") end\n  schedule_light_health_check(scene_name, expected_value_by_device_id, retry_command_by_device_id)\nend\n\nlocal function build_scene_snapshot_info(scene_no)\n  local scene_name = get_scene_display_name(scene_no)\n  local line1 = \"\"..color1..\"\"..build_icon_text(qa_ui_icons.save, translation[\"Hold Down to save: \"])..\"\\n <font size='\"..(Fontsize+2)..\"'>\"..color2..\"\"..build_icon_text(qa_ui_icons.scene, scene_name)..\"<font size='\"..Fontsize..\"'>\"\n  local line2 = \"\"..color1..\"\"\n  local selected_light_ids = self.store.lightid_trigger_select or {}\n  local scene_value_by_device_id = get_scene_snapshot_store(scene_no, \"value\")\n  local scene_color_string_by_device_id = get_scene_snapshot_store(scene_no, \"color_string\")\n  local scene_color_program_by_device_id = get_scene_snapshot_store(scene_no, \"color_program\")\n\n  for selected_index, selected_light_id in ipairs(selected_light_ids) do\n    local light_device_id = tonumber(selected_light_id)\n    if light_device_id ~= nil then\n      local light_display_name = light_name_by_id[tostring(light_device_id)] or (\"ID \"..tostring(light_device_id))\n      local stored_light_value = get_scene_snapshot_value(scene_value_by_device_id, light_device_id, selected_index)\n      local stored_color_string = get_scene_snapshot_value(scene_color_string_by_device_id, light_device_id, selected_index)\n      local stored_color_program = get_scene_snapshot_value(scene_color_program_by_device_id, light_device_id, selected_index)\n      local current_value = stored_light_value ~= nil and tostring(stored_light_value) or \"No Data\"\n      local current_color = stored_color_string ~= nil and tostring(stored_color_string) or \"nil\"\n      local program = get_color_program_name(stored_color_program)\n      local current_color_program = \"\"\n\n      if current_color ~= \"nil\" then\n        current_color = \"\"..color1..\"\"..translation[\"Color Value is: \"]..\" \"..color2..\"\"..current_color..\" \"..color1..\"\\n(\"..color3..\"\"..translation[\"Red\"]..\", \"..color2..\"\"..translation[\"Green\"]..\", <font color=Blue>\"..translation[\"Blue\"]..\", <font color=white>\"..translation[\"white\"]..\"\"..color1..\")\"\n        current_color_program = \"\"..color1..\"\"..translation[\"Color Program is:\"]..\" \"..color2..\"\"..program..\" \"..color1..\"\\n\\n\"\n      else\n        current_color = \"\"\n      end\n\n      line2 = \"\"..line2..\" \"..color1..\"\"..translation[\"Light Name: \"]..\" \"..color2..\"\"..light_display_name..\" \\n \"..color1..\"\"..translation[\"Light Value: \"]..\" \"..color2..\"\"..current_value..\" \\n\"..current_color..\" \\n\"..current_color_program..\" \\n\"\n    end\n  end\n\n  return \"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line1..\"\\n\"..line2..\"   </tt></font></section>\"\nend\n\nlocal function refresh_scene_button_texts()\n  self:updateView(\"save1\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene1..\"\"))\n  self:updateView(\"save2\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene2..\"\"))\n  self:updateView(\"save3\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene3..\"\"))\n  self:updateView(\"save4\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene4..\"\"))\n  self:updateView(\"save5\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene5..\"\"))\n  self:updateView(\"save6\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene6..\"\"))\n  self:updateView(\"bactivatesave1\",\"text\",build_icon_text(qa_ui_icons.scene, scene1))\n  self:updateView(\"bactivatesave11\",\"text\",build_icon_text(qa_ui_icons.scene, scene1))\n  self:updateView(\"bactivatesave2\",\"text\",build_icon_text(qa_ui_icons.scene, scene2))\n  self:updateView(\"bactivatesave22\",\"text\",build_icon_text(qa_ui_icons.scene, scene2))\n  self:updateView(\"bactivatesave3\",\"text\",build_icon_text(qa_ui_icons.scene, scene3))\n  self:updateView(\"bactivatesave33\",\"text\",build_icon_text(qa_ui_icons.scene, scene3))\n  self:updateView(\"bactivatesave4\",\"text\",build_icon_text(qa_ui_icons.scene, scene4))\n  self:updateView(\"bactivatesave44\",\"text\",build_icon_text(qa_ui_icons.scene, scene4))\n  self:updateView(\"bactivatesave5\",\"text\",build_icon_text(qa_ui_icons.scene, scene5))\n  self:updateView(\"bactivatesave55\",\"text\",build_icon_text(qa_ui_icons.scene, scene5))\n  self:updateView(\"bactivatesave6\",\"text\",build_icon_text(qa_ui_icons.scene, scene6))\n  self:updateView(\"bactivatesave66\",\"text\",build_icon_text(qa_ui_icons.scene, scene6))\nend\nsafe_startup_call(\"refresh_scene_button_texts\", refresh_scene_button_texts)\n\nlocal scene_button_text_view_names = {\n  \"save1\",\n  \"save2\",\n  \"save3\",\n  \"save4\",\n  \"save5\",\n  \"save6\",\n  \"bactivatesave1\",\n  \"bactivatesave11\",\n  \"bactivatesave2\",\n  \"bactivatesave22\",\n  \"bactivatesave3\",\n  \"bactivatesave33\",\n  \"bactivatesave4\",\n  \"bactivatesave44\",\n  \"bactivatesave5\",\n  \"bactivatesave55\",\n  \"bactivatesave6\",\n  \"bactivatesave66\",\n}\n\nlocal function schedule_scene_button_text_refresh(delay_ms)\n  hub.setTimeout(delay_ms, function()\n    safe_ui_callback(\"refresh_scene_button_texts_timer_\"..tostring(delay_ms), function()\n      for _, view_name in ipairs(scene_button_text_view_names) do\n        invalidate_view_cache(view_name, \"text\")\n      end\n      refresh_scene_button_texts()\n    end)\n  end)\nend\n\nlocal register_motion_sensor_event\nlocal refresh_motion_sensor_state_cache\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----motionsensor label update\nlocal function info_motionsensor()\n    local line1 = \"<font size='\"..(Fontsize+2)..\"'>\"..color1..\"\"..translation[\"Room Name: \"]..\"\"..color2..\"\"..build_trailing_icon_text(self_room_name, qa_ui_icons.room)..\"\"\n    local line2 = \"\"..color1..\" \"..translation[\"Room ID: \"]..\"\"..color2..\"\"..build_trailing_icon_text(self_room_id, qa_ui_icons.identifier)..\" <font size='\"..Fontsize..\"'>\\n\"\n    local line3 = \"\"..color1..\"\"\n    local line4 = \"\"..color1..\"\"..build_icon_text(qa_ui_icons.motion, translation[\"Selected Sensors\"])..\"\\n\"\n    local rownumber = 1\n      for _, motion_device_id in ipairs(motion_ids or {}) do\n        local motion_sensor_state = motion_sensor_state_by_device_id[tostring(motion_device_id)]\n        local motion_sensor_status_text = translation[\"Unknown\"]\n        local motion_sensor_selection_text = translation[\"Not selected\"]\n        if motion_sensor_state == true then\n          motion_sensor_status_text = translation[\"Detected\"]\n        elseif motion_sensor_state == false then\n          motion_sensor_status_text = translation[\"Safe\"]\n        end\n        if motionsensorid_trigger[tostring(motion_device_id)] ~= nil or motionsensorid_trigger[tonumber(motion_device_id)] ~= nil then\n          motion_sensor_selection_text = translation[\"Selected\"]\n        end\n        line3 = \"\"..line3..\" \"\n          ..color1..\"\"..translation[\"Motion Sensor Name: \"]..\" \"..color2..\"\"..build_trailing_icon_text(motion_name[rownumber], qa_ui_icons.motion)\n          ..\" \\n \"..color1..\"\"..translation[\"Motion Sensor id: \"]..\"\"..color2..\"\"..build_trailing_icon_text(motion_device_id, qa_ui_icons.identifier)\n          ..\" \\n \"..color1..\"\"..translation[\"Motion Sensor Status: \"]..\"\"..color2..\"\"..motion_sensor_status_text\n          ..\" \\n \"..color1..\"\"..translation[\"Selection: \"]..\"\"..color2..\"\"..motion_sensor_selection_text\n          ..\"  \\n\\n \"\n      rownumber = rownumber + 1\n      end \n      if next(self.store.motionsensorid_trigger_select or {}) == nil then\n        line4 = \"\"..line4..\"\"..color3..\"\"..translation[\"No sensors selected\"]..\" \\n\"\n      else\n        for _, selected_motion_sensor_id in ipairs(self.store.motionsensorid_trigger_select or {}) do\n          local selected_motion_status_text = translation[\"Unknown\"]\n          if motion_sensor_state_by_device_id[tostring(selected_motion_sensor_id)] == true then\n            selected_motion_status_text = translation[\"Detected\"]\n          elseif motion_sensor_state_by_device_id[tostring(selected_motion_sensor_id)] == false then\n            selected_motion_status_text = translation[\"Safe\"]\n          end\n          line4 = \"\"..line4..\"\"..color1..\"\"..translation[\"Motion Sensor id: \"]..\" \"..color2..\"\"..build_trailing_icon_text(selected_motion_sensor_id, qa_ui_icons.identifier)..\" \"\n            ..color1..\"(\"..color2..\"\"..selected_motion_status_text..\"\"..color1..\")\\n\"\n        end\n      end\n    self:updateView(\"info_motionsensor\", \"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line1..\"\\n\"..line2..\"\\n\"..line3..\"\\n\"..line4..\"   </tt></font></section>\")\nend\n  safe_startup_call(\"info_motionsensor\", info_motionsensor)\n----------------------------------------------------------------------------------------------------------\n-----update motion dropdown list on statup\n  local update_motion_list = {}\n  local function update_motion_list_if()\n    local next_update_motion_list = {}\n    for ind,val in ipairs(motion_ids) do\n        if motion_ids[ind] ~= nil then\n        next_update_motion_list[#next_update_motion_list + 1] = {text = format_dropdown_device_option_text(motion_ids[ind], motion_name[ind]), type = \"option\", value = \"\"..motion_ids[ind]..\"\"}\n        end\n   \n    end\n  update_motion_list = next_update_motion_list\n  self:updateView(\"select_motion_setup\", \"options\", update_motion_list)\n  \n  self:updateView(\"select_motion_setup\", \"selectedItems\", motionsensorid_trigger_select)\n  end \n  safe_startup_call(\"update_motion_list_if\", update_motion_list_if)\n----------------------------------------------------------------------------------------------------------\n-----motionsensor dropdown list handler\n  local var2 = {}\n  function QuickApp:select_motion_setup(args)\n    local selected_values = get_multi_callback_value(args)\n    if selected_values == nil then\n      return\n    end\n    var2 = sanitize_motion_selection(selected_values)\n    --print(\"var2\", json.encode(var2))\n    motionsensorid_trigger = nil\n    motionsensorid_trigger = {}\n    for ind,val in ipairs(var2) do\n    motionsensorid_trigger[val] = val\n    end---for loop\n    self.store.motionsensorid_trigger = motionsensorid_trigger\n    self.store.motionsensorid_trigger_select = copy_id_list(var2)\n    self:updateView(\"select_motion_setup\", \"selectedItems\", var2)\n    info_motionsensor()\n    refresh_motion_sensor_state_cache()\n    register_motion_sensor_event()\n  end\n\nlocal function normalize_motion_value(value)\n  if value == true or value == 1 then return true end\n  if value == false or value == 0 then return false end\n  local normalized_value = string.lower(tostring(value))\n  if normalized_value == \"true\" or normalized_value == \"1\" or normalized_value == \"detected\" or normalized_value == \"open\" or normalized_value == \"opened\" then return true end\n  if normalized_value == \"false\" or normalized_value == \"0\" or normalized_value == \"safe\" or normalized_value == \"close\" or normalized_value == \"closed\" then return false end\n  return nil\nend\n\nlocal function is_selected_motion_sensor(selected_map, sensor_id)\n  local sensor_id_string = tostring(sensor_id)\n  local sensor_id_number = tonumber(sensor_id)\n  if type(selected_map) ~= \"table\" then\n    return false\n  end\n  if selected_map[sensor_id_string] ~= nil then return true end\n  if sensor_id_number ~= nil and selected_map[sensor_id_number] ~= nil then return true end\n  return false\nend\n\nlocal function update_cached_motion_sensor_state(motion_sensor_device_id, motion_sensor_value)\n  local normalized_motion_state = normalize_motion_value(motion_sensor_value)\n  if motion_sensor_device_id ~= nil and normalized_motion_state ~= nil then\n    motion_sensor_state_by_device_id[tostring(motion_sensor_device_id)] = normalized_motion_state\n  end\n  return normalized_motion_state\nend\n\nlocal function is_any_selected_motion_sensor_active()\n  for _, selected_motion_sensor_id in pairs(motionsensorid_trigger or {}) do\n    if motion_sensor_state_by_device_id[tostring(selected_motion_sensor_id)] == true then\n      return true\n    end\n  end\n  return false\nend\n\nrefresh_motion_sensor_state_cache = function()\n  local active_motion_sensor_count = 0\n  motion_sensor_state_by_device_id = {}\n\n  for _, selected_motion_sensor_id in pairs(motionsensorid_trigger or {}) do\n    local motion_sensor_device_id = tonumber(selected_motion_sensor_id)\n    if motion_sensor_device_id ~= nil then\n      local current_motion_sensor_value = safe_hub_get_value(\n        motion_sensor_device_id,\n        \"value\",\n        \"Unable to initialize motion sensor state\"\n      )\n      local normalized_motion_state = update_cached_motion_sensor_state(\n        motion_sensor_device_id,\n        current_motion_sensor_value\n      )\n      if normalized_motion_state == true then\n        active_motion_sensor_count = active_motion_sensor_count + 1\n      end\n    else\n      self:warning(\"Skipped motion sensor state initialization for invalid device ID \"..tostring(selected_motion_sensor_id))\n    end\n  end\n\n  if active_motion_sensor_count > 0 then\n    self.store.pir_status = \"Detected\"\n  else\n    self.store.pir_status = \"Safe\"\n  end\n\n  if info_motionsensor ~= nil then\n    info_motionsensor()\n  end\nend\n\nlocal function queue_motion_sensor_info_refresh(delay_ms)\n  if motion_sensor_info_refresh_timer ~= nil then\n    hub.clearTimeout(motion_sensor_info_refresh_timer)\n    motion_sensor_info_refresh_timer = nil\n  end\n\n  motion_sensor_info_refresh_timer = hub.setTimeout(delay_ms or 250, function()\n    motion_sensor_info_refresh_timer = nil\n    if info_motionsensor ~= nil then\n      info_motionsensor()\n    end\n  end)\nend\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n-----------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----- enable/disable Pir evnets info\nlocal enable_status_fun\nlocal turnon\nlocal turnoff\nlocal check_pir_on_p1\nlocal check_pir_off_p1\nlocal cancel_pir_timers\nlocal fibaro_pir_check_off\nlocal motionsensorid_off\nlocal funpirstatuson\nlocal funPirStatusOff\n\nlocal function info_pir_enable()\n  local line1 = \"\"..color1..\"<font size='\"..Fontsize..\"'>\"..build_icon_text(qa_ui_icons.motion, translation[\"info_pir_enable\"])..\"\"\n  if self.store.enable_status == \"off\" then\n  line1= \"\"..line1..\" \"..color3..\"\"..translation[\"info_pir_enable_off\"]..\" \"\n  else\n  line1= \"\"..line1..\" \"..color2..\"\"..translation[\"info_pir_enable_on\"]..\"\"\n  end\n  self:updateView(\"info_pir_enable\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line1..\"   </tt></font></section>\")\nend\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---enable motion lights\nfunction QuickApp:enable(args)     \n  self.store.enable_status = \"on\"\n  enable_status_fun()\n  if self.store.pir_status == \"Detected\" then \n    check_pir_on_p1()\n  end\n  if self.store.pir_status == \"Safe\" then \n    check_pir_off_p1()\n  end\nend\n  self:updateView(\"enable\", \"text\", build_icon_text(qa_ui_icons.enable, translation[\"enable\"]))\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---disable motion lights\nfunction QuickApp:disable(args)     \n  self.store.enable_status = \"off\"\n\n  enable_status_fun()\n  cancel_pir_timers()\nend\n  self:updateView(\"disable\", \"text\", build_icon_text(qa_ui_icons.disable, translation[\"disable\"]))\n\n----------------------------------------------------------------------------------------------------------\nenable_status_fun = function()\n  if self.store.enable_status == \"off\" then\n    self:updateView(\"enable\", \"value\", \"false\")\n    self:updateView(\"disable\", \"value\", \"true\")\n  else\n    self:updateView(\"enable\", \"value\", \"true\")\n    self:updateView(\"disable\", \"value\", \"false\")\n  end\n  enable_status = self.store.enable_status\n  info_pir_enable()\nend\n  \n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---turnon event/scene\nfunction QuickApp:turnon(args)     \n  turnon()\nend\n\nturnon = function()\n  button_labels_false()\n    local ids = self.store.lightid_trigger_select or {}\n    local expected_value_by_device_id = {}\n    local retry_command_by_device_id = {}\n    if next(ids) == nil then\n      self:warning(\"Turn on skipped because no lights are selected\")\n      return\n    end\n    for _,value in ipairs(ids) do\n      local light_device_id = tonumber(value)\n      if light_device_id ~= nil then\n        safe_hub_call(light_device_id, \"turnOn\")\n        local light_device_key = tostring(light_device_id)\n        expected_value_by_device_id[light_device_key] = true\n        retry_command_by_device_id[light_device_key] = function()\n          safe_hub_call(light_device_id, \"turnOn\")\n        end\n      else\n        self:warning(\"Turn on skipped invalid light ID \"..tostring(value))\n      end\n    end\n    self.store.current_scene = \"\"..translation[\"Turn ON\"]..\"\"\n    self.store.current_scene_action = \"turnOn\"\n    local var = \"\"..translation[\"Turn ON\"]..\"\"\n    self:updateProperty(\"log\", \"\"..var..\"\")\n    self:updateView(\"bturnon\", \"value\", \"true\")    \n    schedule_light_health_check(translation[\"Turn ON\"], expected_value_by_device_id, retry_command_by_device_id)\nend\n  self:updateView(\"bturnon\", \"text\", build_icon_text(qa_ui_icons.turnOn, translation[\"Turn ON\"]))\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----turnoff event/scene\nfunction QuickApp:turnoff(args)    \n  turnoff()\nend \n\nturnoff = function()\n  button_labels_false()\n    local ids = self.store.lightid_trigger_select or {}\n    local expected_value_by_device_id = {}\n    local retry_command_by_device_id = {}\n    if next(ids) == nil then\n      self:warning(\"Turn off skipped because no lights are selected\")\n      return\n    end\n    for _,value in ipairs(ids) do\n      local light_device_id = tonumber(value)\n      if light_device_id ~= nil then\n        safe_hub_call(light_device_id, \"turnOff\")\n        local light_device_key = tostring(light_device_id)\n        expected_value_by_device_id[light_device_key] = false\n        retry_command_by_device_id[light_device_key] = function()\n          safe_hub_call(light_device_id, \"turnOff\")\n        end\n      else\n        self:warning(\"Turn off skipped invalid light ID \"..tostring(value))\n      end\n    end\n    self.store.current_scene = \"\"..translation[\"Turn OFF\"]..\"\"\n    self.store.current_scene_action = \"turnOff\"\n    local var = \"\"..translation[\"Turn OFF\"]..\"\"\n    self:updateProperty(\"log\", \"\"..var..\"\")\n    self:updateView(\"bturnoff\", \"value\", \"true\")  \n    schedule_light_health_check(translation[\"Turn OFF\"], expected_value_by_device_id, retry_command_by_device_id)\nend\nself:updateView(\"bturnoff\", \"text\", build_icon_text(qa_ui_icons.turnOff, translation[\"Turn OFF\"]))\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n-----dropdownlist handler for Pir on event \nfunction QuickApp:p1_scene_on(args)\n  --print(\"args: \", json.encode(args))\n    local selected_value = get_single_callback_value(args)\n    if selected_value ~= nil then \n    self:updateView(\"bp1_scene_on\", \"selectedItem\", \"\"..selected_value..\"\")\n    self.store.p1_scene_on_args = \"\"..selected_value..\"\"\n    self:debug(\"Selected: \" .. selected_value)\n    end\nend\nself:updateView(\"bp1_scene_on\", \"selectedItem\", self.store.p1_scene_on_args)\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n-----dropdown handler for pir off events\nfunction QuickApp:p1_scene_off(args)\n  --print(\"args: \", json.encode(args))\n    --------------\n    local selected_value = get_single_callback_value(args)\n    if selected_value ~= nil then \n    self:updateView(\"bp1_scene_off\", \"selectedItem\", \"\"..selected_value..\"\")\n    self.store.p1_scene_off_args = \"\"..selected_value..\"\"\n    --self:debug(\"Selected: \" .. selected_value)\n    end\nend \nself:updateView(\"bp1_scene_off\", \"selectedItem\", self.store.p1_scene_off_args)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----check for what should happend on the pir on evnet\ncheck_pir_on_p1 = function()\n  --print(\"p1_scene_on_args\", self.store.p1_scene_on_args)\n  if self.store.p1_scene_on_args == \"scene1\" then\n    activatesave1()\n  elseif self.store.p1_scene_on_args == \"scene2\" then\n    activatesave2()\n  elseif self.store.p1_scene_on_args == \"scene3\" then \n    activatesave3()\n  elseif self.store.p1_scene_on_args == \"scene4\" then \n    activatesave4()\n  elseif self.store.p1_scene_on_args == \"scene5\" then \n    activatesave5()\n  elseif self.store.p1_scene_on_args == \"scene6\" then \n    activatesave6()\n  elseif self.store.p1_scene_on_args == \"turnOn\" then\n    turnon()\n  elseif self.store.p1_scene_on_args == \"turnOff\" then\n    turnoff()\n  else    --no_action\n   -- print(\"No action\")\n  end\nend\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----check for what should happend on the pir OFF evnet\ncheck_pir_off_p1 = function()\n  --print(\"p1_scene_off_args: \",self.store.p1_scene_off_args  )\n  if self.store.p1_scene_off_args == \"scene1\" then\n    activatesave1()\n  elseif self.store.p1_scene_off_args == \"scene2\" then \n    activatesave2()\n  elseif self.store.p1_scene_off_args == \"scene3\" then \n    activatesave3()\n  elseif self.store.p1_scene_off_args == \"scene4\" then \n    activatesave4()\n  elseif self.store.p1_scene_off_args == \"scene5\" then \n    activatesave5()\n  elseif self.store.p1_scene_off_args == \"scene6\" then \n    activatesave6()\n  elseif self.store.p1_scene_off_args == \"turnOn\" then\n    turnon()\n  elseif self.store.p1_scene_off_args == \"turnOff\" then\n    turnoff()\n  else    --no_action\n    --print(\"No action\")\n  end\nend\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----- Pir on evnet info\nlocal function info_pir_on()\nlocal line1 = \"\"..color1..\"<font size='\"..Fontsize..\"'>\"..translation[\"Pir ON Event\"]..\"\"\nself:updateView(\"info_pir_on\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line1..\"   </tt></font></section>\")\nend\nsafe_startup_call(\"info_pir_on\", info_pir_on)\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----- Pir off evnet info\nlocal function info_pir_off()\nlocal line1 = \"\"..color1..\"<font size='\"..Fontsize..\"'>\"..translation[\"Pir OFF Event\"]..\"\"\nself:updateView(\"info_pir_off\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line1..\"   </tt></font></section>\")\nend\nsafe_startup_call(\"info_pir_off\", info_pir_off)\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----- Pir off evnet info\nlocal function info_pir_off_delay()\n  local line1 = \"\"..color1..\"<font size='\"..Fontsize..\"'>\"..translation[\"Pir OFF Event Delay\"]..\"\"\n  self:updateView(\"info_pir_off_delay\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line1..\"   </tt></font></section>\")\n  end\n  safe_startup_call(\"info_pir_off_delay\", info_pir_off_delay)\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n-----sensor + button handler\nlocal info_sensor_timer\nlocal update_sec_min_sensor\n\nfunction QuickApp:sensor_timep(args)\n    self:updateView(\"bsensor_timep\", \"value\", \"true\")  \n        self.store.sensor_timer_p1 = self.store.sensor_timer_p1 + 1\n      if self.store.sensor_timer_p1 > 3600 then\n        self.store.sensor_timer_p1 = 0\n      end\n  info_sensor_timer()\n  hub.setTimeout(200, function() self:updateView(\"bsensor_timep\", \"value\", \"false\")  end)\nend\n  self:updateView(\"bsensor_timep\",\"text\",\"➕\")\n---------------------------------------------------------------------------------------------------------\n-----sensor - button handler\nfunction QuickApp:sensor_timen(args)\n    self:updateView(\"bsensor_timen\", \"value\", \"true\")  \n\n        self.store.sensor_timer_p1 = self.store.sensor_timer_p1 - 1\n      if self.store.sensor_timer_p1 < 0 then\n        self.store.sensor_timer_p1 = 3600\n      end\n  info_sensor_timer()\n  hub.setTimeout(200, function()   self:updateView(\"bsensor_timen\", \"value\", \"false\")   end)\nend\n  self:updateView(\"bsensor_timen\",\"text\",\"➖\")\n\n-----sensor + button handler\nfunction QuickApp:sensor_timep_l(args)\n  self:updateView(\"bsensor_timep\", \"value\", \"true\")  \n      self.store.sensor_timer_p1 = self.store.sensor_timer_p1 + 60\n    if self.store.sensor_timer_p1 > 3600 then\n      self.store.sensor_timer_p1 = 0\n    end\ninfo_sensor_timer()\nhub.setTimeout(200, function() self:updateView(\"bsensor_timep\", \"value\", \"false\")  end)\nend\nself:updateView(\"bsensor_timep\",\"text\",\"➕\")\n---------------------------------------------------------------------------------------------------------\n-----sensor - button handler\nfunction QuickApp:sensor_timen_l(args)\n  self:updateView(\"bsensor_timen\", \"value\", \"true\")  \n\n      self.store.sensor_timer_p1 = self.store.sensor_timer_p1 - 60\n    if self.store.sensor_timer_p1 < 0 then\n      self.store.sensor_timer_p1 = 3600\n    end\ninfo_sensor_timer()\nhub.setTimeout(200, function()   self:updateView(\"bsensor_timen\", \"value\", \"false\")   end)\nend\nself:updateView(\"bsensor_timen\",\"text\",\"➖\")\n\n\n\n----------------------------------------------------------------------------------------------------------\n-----sensor min/sec button handler\nlocal sec_min_sensor_counter = 1\nfunction QuickApp:sec_min_sensor(args)\n  self:updateView(\"bsec_min_sensor\", \"value\", \"false\") \n  if (sec_min_sensor_counter== 1) then\n    self.store.sec_min_sensor = \"min\"\n    sec_min_sensor_counter = 2\n  elseif (sec_min_sensor_counter== 2) then\n    self.store.sec_min_sensor = \"minx10\"\n    sec_min_sensor_counter = 3\n  elseif (sec_min_sensor_counter== 3) then\n    self.store.sec_min_sensor = \"sec\"\n    sec_min_sensor_counter = 1\n  else\n    sec_min_sensor_counter = 1\n  end\n  update_sec_min_sensor()\nend\nupdate_sec_min_sensor = function()\n  if self.store.sec_min_sensor == \"min\" then\n    self:updateView(\"bsec_min_sensor\", \"value\", \"true\")  \n    self:updateView(\"bsec_min_sensor\",\"text\",\"\"..translation[\"Min\"]..\"\")\n  elseif self.store.sec_min_sensor == \"minx10\" then\n    self:updateView(\"bsec_min_sensor\", \"value\", \"true\")  \n    self:updateView(\"bsec_min_sensor\",\"text\",\"10 \"..translation[\"Min\"]..\"\")\n  else\n    self:updateView(\"bsec_min_sensor\", \"value\", \"true\")  \n    self:updateView(\"bsec_min_sensor\",\"text\",\"\"..translation[\"Sec\"]..\"\")\n  end\nend\nsafe_startup_call(\"update_sec_min_sensor\", update_sec_min_sensor)\n----------------------------------------------------------------------------------------------------------\n----Sensor time label updater and time converter\ninfo_sensor_timer = function()\nlocal function fmt(v) \n      local val = string.format(\"%02d\",v)\n      return val\n      end\nlocal p1_sec = fmt(tostring(math.fmod (self.store.sensor_timer_p1, 60)))\nlocal p1_min = fmt(tostring(math.floor (self.store.sensor_timer_p1/60)))\n\n  --math.fmod (x, y)\n  local line0 = \"\"..color1..\"\"..build_icon_text(qa_ui_icons.timer, translation[\"Change Delay\"])..\"\"\n  local line1 = \"\"..color1..\"\"..translation[\"Sensor timer is:\"]..\" \"..color2..\"\"..p1_min..\":\"..p1_sec..\"\"\n\n  self:updateView(\"info_sensor_timer\",\"text\",\"  <table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line0..\"\\n\"..line1..\"\\n  </tt></font></section>\")\nend\nsafe_startup_call(\"info_sensor_timer\", info_sensor_timer)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---Handler for saveing values for scene 1\nfunction QuickApp:save1(args)      \n  self:updateView(\"save1\", \"value\", \"false\")\n  save_scene_snapshot(1)\n  info_save1()\n  self:updateView(\"save1\", \"value\", \"true\")\nend \nself:updateView(\"save1\", \"value\", \"true\")   \nself:updateView(\"save1\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene1..\"\"))\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\nfunction QuickApp:activatesave1(args)\n  activatesave1()\nend\n---------------------------------------------------------------------------------\nfunction QuickApp:activatesave11(args)      \n  activatesave1()\nend\n---------------------------------------------------------------------------------\nfunction activatesave1()\n  apply_scene_snapshot(1, \"bactivatesave1\", \"bactivatesave11\")\nend\n--self:updateView(\"bactivatesave1\", \"value\", \"true\")  \nself:updateView(\"bactivatesave1\",\"text\",build_icon_text(qa_ui_icons.scene, scene1))\nself:updateView(\"bactivatesave11\",\"text\",build_icon_text(qa_ui_icons.scene, scene1))\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n--------------------------------------------------------------------------------\nfunction info_save1()\n  self:updateView(\"info_save1\",\"text\", build_scene_snapshot_info(1))\nend\nsafe_startup_call(\"info_save1\", info_save1)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---Handler for saveing values for scene 2\nfunction QuickApp:save2(args)      \n  self:updateView(\"save2\", \"value\", \"false\")\n  save_scene_snapshot(2)\n  info_save2()\n  self:updateView(\"save2\", \"value\", \"true\")\nend \nself:updateView(\"save2\", \"value\", \"true\")   \nself:updateView(\"save2\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene2..\"\"))\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\nfunction QuickApp:activatesave2(args)      \n\nactivatesave2()\nend\n---------------------------------------------------------------------------------\nfunction QuickApp:activatesave22(args)      \n\nactivatesave2()\nend\n---------------------------------------------------------------------------------\nfunction activatesave2()\n  apply_scene_snapshot(2, \"bactivatesave2\", \"bactivatesave22\")\nend\n--self:updateView(\"bactivatesave2\", \"value\", \"true\")  \nself:updateView(\"bactivatesave2\",\"text\",build_icon_text(qa_ui_icons.scene, scene2))\nself:updateView(\"bactivatesave22\",\"text\",build_icon_text(qa_ui_icons.scene, scene2))\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n--------------------------------------------------------------------------------\nfunction info_save2()\n  self:updateView(\"info_save2\",\"text\", build_scene_snapshot_info(2))\nend\nsafe_startup_call(\"info_save2\", info_save2)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---Handler for saveing values for scene 3\nfunction QuickApp:save3(args)      \n  self:updateView(\"save3\", \"value\", \"false\")\n  save_scene_snapshot(3)\n  info_save3()\n  self:updateView(\"save3\", \"value\", \"true\")\n  end \n  self:updateView(\"save3\", \"value\", \"true\")   \n  self:updateView(\"save3\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene3..\"\"))\n  ---------------------------------------------------------------------------------\n  ---------------------------------------------------------------------------------\n  ---------------------------------------------------------------------------------\n  function QuickApp:activatesave3(args)\n    activatesave3()\n  end\n  ---------------------------------------------------------------------------------\n  function QuickApp:activatesave31(args)      \n    activatesave3()\n  end\n  ---------------------------------------------------------------------------------\n  function QuickApp:activatesave33(args)\n    activatesave3()\n  end\n  ---------------------------------------------------------------------------------\n  function activatesave3()\n    apply_scene_snapshot(3, \"bactivatesave3\", \"bactivatesave33\")\n  end\n  --self:updateView(\"bactivatesave3\", \"value\", \"true\")  \n  self:updateView(\"bactivatesave3\",\"text\",build_icon_text(qa_ui_icons.scene, scene3))\n  self:updateView(\"bactivatesave33\",\"text\",build_icon_text(qa_ui_icons.scene, scene3))\n  ---------------------------------------------------------------------------------\n  ---------------------------------------------------------------------------------\n  --------------------------------------------------------------------------------\n  function info_save3()\n  self:updateView(\"info_save3\",\"text\", build_scene_snapshot_info(3))\n  end\n  safe_startup_call(\"info_save3\", info_save3)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---Handler for saveing values for scene 4\nfunction QuickApp:save4(args)      \n  self:updateView(\"save4\", \"value\", \"false\")\n  save_scene_snapshot(4)\n  info_save4()\n  self:updateView(\"save4\", \"value\", \"true\")\n  end \n  self:updateView(\"save4\", \"value\", \"true\")   \n  self:updateView(\"save4\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene4..\"\"))\n  ---------------------------------------------------------------------------------\n  ---------------------------------------------------------------------------------\n  ---------------------------------------------------------------------------------\n  function QuickApp:activatesave4(args)\n    activatesave4()\n  end\n  ---------------------------------------------------------------------------------\n  function QuickApp:activatesave41(args)      \n    activatesave4()\n  end\n  ---------------------------------------------------------------------------------\n  function QuickApp:activatesave44(args)\n    activatesave4()\n  end\n  ---------------------------------------------------------------------------------\n  function activatesave4()\n    apply_scene_snapshot(4, \"bactivatesave4\", \"bactivatesave44\")\n  end\n  --self:updateView(\"bactivatesave4\", \"value\", \"true\")  \n  self:updateView(\"bactivatesave4\",\"text\",build_icon_text(qa_ui_icons.scene, scene4))\n  self:updateView(\"bactivatesave44\",\"text\",build_icon_text(qa_ui_icons.scene, scene4))\n  ---------------------------------------------------------------------------------\n  ---------------------------------------------------------------------------------\n  --------------------------------------------------------------------------------\n  function info_save4()\n  self:updateView(\"info_save4\",\"text\", build_scene_snapshot_info(4))\n  end\n  safe_startup_call(\"info_save4\", info_save4)\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---Handler for saveing values for scene 5\nfunction QuickApp:save5(args)\n  self:updateView(\"save5\", \"value\", \"false\")\n  save_scene_snapshot(5)\n  info_save5()\n  self:updateView(\"save5\", \"value\", \"true\")\nend\nself:updateView(\"save5\", \"value\", \"true\")\nself:updateView(\"save5\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene5..\"\"))\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\nfunction QuickApp:activatesave5(args)\n  activatesave5()\nend\n---------------------------------------------------------------------------------\nfunction QuickApp:activatesave55(args)\n  activatesave5()\nend\n---------------------------------------------------------------------------------\nfunction activatesave5()\n  apply_scene_snapshot(5, \"bactivatesave5\", \"bactivatesave55\")\nend\nself:updateView(\"bactivatesave5\",\"text\",build_icon_text(qa_ui_icons.scene, scene5))\nself:updateView(\"bactivatesave55\",\"text\",build_icon_text(qa_ui_icons.scene, scene5))\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n--------------------------------------------------------------------------------\nfunction info_save5()\n  self:updateView(\"info_save5\",\"text\", build_scene_snapshot_info(5))\nend\nsafe_startup_call(\"info_save5\", info_save5)\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---Handler for saveing values for scene 6\nfunction QuickApp:save6(args)\n  self:updateView(\"save6\", \"value\", \"false\")\n  save_scene_snapshot(6)\n  info_save6()\n  self:updateView(\"save6\", \"value\", \"true\")\nend\nself:updateView(\"save6\", \"value\", \"true\")\nself:updateView(\"save6\",\"text\",build_icon_text(qa_ui_icons.save, translation[\"Save\"]..\" \"..scene6..\"\"))\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\nfunction QuickApp:activatesave6(args)\n  activatesave6()\nend\n---------------------------------------------------------------------------------\nfunction QuickApp:activatesave66(args)\n  activatesave6()\nend\n---------------------------------------------------------------------------------\nfunction activatesave6()\n  apply_scene_snapshot(6, \"bactivatesave6\", \"bactivatesave66\")\nend\nself:updateView(\"bactivatesave6\",\"text\",build_icon_text(qa_ui_icons.scene, scene6))\nself:updateView(\"bactivatesave66\",\"text\",build_icon_text(qa_ui_icons.scene, scene6))\n---------------------------------------------------------------------------------\n---------------------------------------------------------------------------------\n--------------------------------------------------------------------------------\nfunction info_save6()\n  self:updateView(\"info_save6\",\"text\", build_scene_snapshot_info(6))\nend\nsafe_startup_call(\"info_save6\", info_save6)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n------jgab eventlib handler and filters\nlocal motion_sensor_event_handler_key\nlocal motion_sensor_event_generation = 0\n\nlocal function handle_motion_sensor_event(event)\n  local motion_sensor_id = event.id\n  local motion_sensor_state = update_cached_motion_sensor_state(motion_sensor_id, event.value)\n  self:debug(\"Sensor ID: \", motion_sensor_id, \"value: \", event.value)\n\n  if not is_selected_motion_sensor(motionsensorid_trigger, motion_sensor_id) then\n    return\n  end\n\n  queue_motion_sensor_info_refresh(250)\n\n  if motion_sensor_state == true then\n    cancel_pir_timers()\n    if self.store.pir_status ~= \"Detected\" then\n      funpirstatuson()\n    end\n  elseif motion_sensor_state == false then\n    fibaro_pir_check_off()\n  else\n    self:debug(\"Ignoring unsupported motion sensor value from \"..tostring(motion_sensor_id)..\": \"..tostring(event.value))\n  end\nend\n\nregister_motion_sensor_event = function()\n  if motion_sensor_event_handler_key ~= nil then\n    pcall(function()\n      Event:disable(motion_sensor_event_handler_key)\n      Event:cancelAll(motion_sensor_event_handler_key)\n    end)\n  end\n\n  local stored_selected_motion_sensor_ids = normalize_id_list(self.store.motionsensorid_trigger_select or {})\n  local selected_motion_sensor_ids = build_numeric_id_list(stored_selected_motion_sensor_ids)\n  if #stored_selected_motion_sensor_ids == 0 then\n    self:debug(\"Motion event registration skipped because no sensors are selected\")\n    return\n  end\n  if #selected_motion_sensor_ids == 0 then\n    self:warning(\"Motion event registration skipped because no valid numeric sensor IDs are selected: \"..format_id_list_for_log(stored_selected_motion_sensor_ids))\n    return\n  end\n\n  motion_sensor_event_generation = motion_sensor_event_generation + 1\n  motion_sensor_event_handler_key = \"motion_sensor_event_\"..tostring(motion_sensor_event_generation)\n  self:debug(\"Registering motion sensor events for \"..format_id_list_for_log(selected_motion_sensor_ids))\n\n  Event.id = motion_sensor_event_handler_key\n  Event.tagColor = \"Orange\"\n  Event {type='device', id={selected_motion_sensor_ids}, property='value', value='$value'}\n  function Event:handler(event)\n    handle_motion_sensor_event(event)\n  end\nend\n\nsafe_startup_call(\"register_motion_sensor_event\", register_motion_sensor_event)\n\nsafe_startup_call(\"refresh_motion_sensor_state_cache\", refresh_motion_sensor_state_cache)\n\n------------------------------------------------------------------------------------------------\n  local p1_pir_timer\n  local p1_pir_timer_delay\n  cancel_pir_timers = function()\n  if p1_pir_timer ~= nil then\n    hub.clearTimeout(p1_pir_timer)\n    p1_pir_timer = nil\n  end\n  if p1_pir_timer_delay ~= nil then\n    hub.clearTimeout(p1_pir_timer_delay)\n    p1_pir_timer_delay = nil\n  end\n  end\n------------------------------------------------------------------------------------------------\nfibaro_pir_check_off = function()\n  cancel_pir_timers()\n  p1_pir_timer = hub.setTimeout(self.store.sensor_timer_p1 *1000, function()\n  p1_pir_timer = nil\n  if is_any_selected_motion_sensor_active() then\n    return\n  end\n  motionsensorid_off()\n  end)\nend----function \n------------------------------------------------------------------------------------------------\nmotionsensorid_off = function()\n  if not is_any_selected_motion_sensor_active() and self.store.pir_status ~= \"Safe\" then\n          funPirStatusOff()\n  end\nend\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----status of pir \nfunpirstatuson = function()\n  self.store.pir_status = \"Detected\"\n  if enable_status == \"on\" then check_pir_on_p1() end ---if enable_status == \"on\" then\nend\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n----status of pir \nfunPirStatusOff = function()\n  self.store.pir_status = \"Safe\"\n  if enable_status == \"on\" then check_pir_off_p1() end ---if enable_status == \"on\" then\nend\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\n----info_offset_time\nself.runtime = self.runtime or {}\nlocal sun_runtime = self.runtime.sun_runtime or {}\nself.runtime.sun_runtime = sun_runtime\nlocal sun_actions = {}\nlocal sun_event_delay_config = {\n  min_minutes = 1,\n  max_minutes = 120,\n  default_seconds = 600,\n}\n\nlocal function clear_scheduled_timer(timer_ref)\n  if timer_ref ~= nil then\n    hub.clearTimeout(timer_ref)\n  end\n  return nil\nend\n\nlocal function parse_clock_time(time_text)\n  local hour_text, minute_text = tostring(time_text or \"\"):match(\"^(%d%d?):(%d%d)$\")\n  if hour_text == nil or minute_text == nil then\n    return nil, nil\n  end\n  return tonumber(hour_text), tonumber(minute_text)\nend\n\nlocal function normalize_sun_state(state_name, fallback_state)\n  if state_name == \"day\" or state_name == \"night\" then\n    return state_name\n  end\n  return fallback_state or \"day\"\nend\n\nlocal function get_clock_minutes(time_text)\n  local hour_value, minute_value = parse_clock_time(time_text)\n  if hour_value == nil or minute_value == nil then\n    return nil\n  end\n  return (hour_value * 60) + minute_value\nend\n\nlocal function normalize_day_minutes(day_minutes)\n  local minutes_per_day = 24 * 60\n  local normalized_minutes = tonumber(day_minutes) or 0\n  normalized_minutes = normalized_minutes % minutes_per_day\n  if normalized_minutes < 0 then\n    normalized_minutes = normalized_minutes + minutes_per_day\n  end\n  return normalized_minutes\nend\n\nlocal function infer_missing_sun_state()\n  local current_month = tonumber(os.date(\"%m\")) or 1\n  if current_month >= 4 and current_month <= 9 then\n    return normalize_sun_state(SUN_STATE_CONFIG.midnight_sun, \"day\"), \"midnight_sun\"\n  end\n  return normalize_sun_state(SUN_STATE_CONFIG.polar_night, \"night\"), \"polar_night\"\nend\n\nlocal function calculateSunState(now_timestamp)\n  local sunrise_minutes = get_clock_minutes(sunrise_time)\n  local sunset_minutes = get_clock_minutes(sunset_time)\n  if sunrise_minutes == nil or sunset_minutes == nil then\n    return infer_missing_sun_state()\n  end\n\n  local adjusted_sunrise = normalize_day_minutes(sunrise_minutes + (tonumber(offset_sunrise) or 0))\n  local adjusted_sunset = normalize_day_minutes(sunset_minutes + (tonumber(offset_sunset) or 0))\n  if adjusted_sunrise >= adjusted_sunset then\n    return normalize_sun_state(SUN_STATE_CONFIG.offset_overlap, \"day\"), \"offset_overlap\"\n  end\n\n  local now_date = os.date(\"*t\", now_timestamp or os.time())\n  local now_minutes = (now_date.hour * 60) + now_date.min\n  if now_minutes >= adjusted_sunrise and now_minutes < adjusted_sunset then\n    return \"day\", \"normal\"\n  end\n  return \"night\", \"normal\"\nend\n\nlocal function refresh_sun_state()\n  local sun_state, sun_state_reason = calculateSunState()\n  self.store.night_or_day = sun_state\n  self.runtime = self.runtime or {}\n  self.runtime.sun_state_reason = sun_state_reason\n  if fibaro.debugFlags.sunState == true and (self.runtime.last_logged_sun_state ~= sun_state or self.runtime.last_logged_sun_state_reason ~= sun_state_reason) then\n    self:debug(\"Sun state: \"..tostring(sun_state)..\" (\"..tostring(sun_state_reason)..\")\")\n    self.runtime.last_logged_sun_state = sun_state\n    self.runtime.last_logged_sun_state_reason = sun_state_reason\n  end\n  return sun_state, sun_state_reason\nend\nsafe_startup_call(\"refresh_sun_state\", refresh_sun_state)\n\nlocal function hydrate_error_status_lines()\n  self.runtime = self.runtime or {}\n  self.runtime.error_status_lines = normalize_id_list(self.store.error_status_lines or {})\n  while #self.runtime.error_status_lines > ERROR_STATUS_MAX_LINES do\n    table.remove(self.runtime.error_status_lines)\n  end\nend\nsafe_startup_call(\"hydrate_error_status_lines\", hydrate_error_status_lines)\n\nlocal function update_error_status_label()\n  local runtime = self.runtime or {}\n  local status_lines = runtime.error_status_lines or {}\n  local text\n  if #status_lines == 0 then\n    text = color2..translation[\"Status log ready\"]\n  else\n    text = table.concat(status_lines, \"\\n\")\n  end\n  text = text..\"\\n\"..string.rep(\"-\\n\", ERROR_STATUS_MAX_LINES)\n  self:updateView(\"error_status\", \"text\", \"<table width=350px border=0><td align=left><section align='left'><font size='\"..Fontsize..\"'><tt>\"..text..\"</tt></font></section>\")\nend\n\nlocal function update_version_label()\n  local line = color1..tostring(qa_type)..\" \"..color2..\"Version: \"..tostring(version)\n  self:updateView(\"info_version\", \"text\", \"<table width=350px border=0><td align=left><section align='left'><font size='\"..Fontsize..\"'><tt>\"..line..\"</tt></font></section>\")\nend\n\nadd_error_status = function(message_text, is_warning)\n  self.runtime = self.runtime or {}\n  self.runtime.error_status_lines = self.runtime.error_status_lines or {}\n  local line_color = is_warning and color3 or color2\n  local line = line_color..os.date(\"%H:%M\")..\" \"..tostring(message_text)\n  table.insert(self.runtime.error_status_lines, 1, line)\n  while #self.runtime.error_status_lines > ERROR_STATUS_MAX_LINES do\n    table.remove(self.runtime.error_status_lines)\n  end\n  self.store.error_status_lines = copy_id_list(self.runtime.error_status_lines)\n  update_error_status_label()\nend\n\nfunction sun_actions.get_sun_state_reason_text(reason_text)\n  local reason_labels = {\n    normal = translation[\"normal\"],\n    midnight_sun = translation[\"midnight sun\"],\n    polar_night = translation[\"polar night\"],\n    offset_overlap = translation[\"offset overlap\"],\n  }\n  return reason_labels[tostring(reason_text)] or translation[\"unknown\"]\nend\n\nfunction sun_actions.get_adjusted_sun_event_minutes(time_text, offset_minutes)\n  local clock_minutes = get_clock_minutes(time_text)\n  if clock_minutes == nil then\n    return nil\n  end\n  return normalize_day_minutes(clock_minutes + (tonumber(offset_minutes) or 0))\nend\n\nfunction sun_actions.format_minutes_as_clock(day_minutes)\n  local normalized_minutes = normalize_day_minutes(day_minutes)\n  local hour_value = math.floor(normalized_minutes / 60)\n  local minute_value = normalized_minutes % 60\n  return string.format(\"%02d:%02d\", hour_value, minute_value)\nend\n\nfunction sun_actions.get_next_sun_event_text()\n  local sunrise_minutes = sun_actions.get_adjusted_sun_event_minutes(sunrise_time, offset_sunrise)\n  local sunset_minutes = sun_actions.get_adjusted_sun_event_minutes(sunset_time, offset_sunset)\n  if sunrise_minutes == nil and sunset_minutes == nil then\n    return translation[\"No valid sun event\"]\n  end\n\n  local now_date = os.date(\"*t\")\n  local now_minutes = (now_date.hour * 60) + now_date.min\n  local next_name = nil\n  local next_minutes = nil\n  local next_delta = nil\n  local candidates = {\n    { name = translation[\"Sunrise\"], minutes = sunrise_minutes },\n    { name = translation[\"Sunset\"], minutes = sunset_minutes },\n  }\n  for _, candidate in ipairs(candidates) do\n    if candidate.minutes ~= nil then\n      local delta_minutes = candidate.minutes - now_minutes\n      if delta_minutes <= 0 then\n        delta_minutes = delta_minutes + (24 * 60)\n      end\n      if next_delta == nil or delta_minutes < next_delta then\n        next_name = candidate.name\n        next_minutes = candidate.minutes\n        next_delta = delta_minutes\n      end\n    end\n  end\n  return tostring(next_name)..\" \"..translation[\"at\"]..\" \"..sun_actions.format_minutes_as_clock(next_minutes)\nend\n\nfunction sun_actions.info_status()\n  local sun_state, sun_state_reason = refresh_sun_state()\n  local last_action_text = ((self.runtime or {}).last_sun_action_text) or translation[\"No sun action yet\"]\n  local line = color1..translation[\"Sun state: \"]..color2..tostring(translation[sun_state] or sun_state)\n  line = line..\"\\n\"..color1..translation[\"Mode: \"]..color2..sun_actions.get_sun_state_reason_text(sun_state_reason)\n  line = line..\"\\n\"..color1..translation[\"Last action: \"]..color2..last_action_text\n  line = line..\"\\n\"..color1..translation[\"Next action: \"]..color2..sun_actions.get_next_sun_event_text()\n  self:updateView(\"info_status\", \"text\", \"<table width=350px border=0><td align=left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line..\" </tt></font></section>\")\nend\n\nfunction sun_actions.refresh_status_views()\n  sun_actions.info_status()\n  update_error_status_label()\nend\n\nfunction sun_actions.schedule_status_refresh()\n  sun_runtime.status_refresh_timer = clear_scheduled_timer(sun_runtime.status_refresh_timer)\n  local refresh_interval_seconds = tonumber(STATUS_REFRESH_INTERVAL_SECONDS) or 300\n  if refresh_interval_seconds < 60 then\n    refresh_interval_seconds = 60\n  end\n  sun_runtime.status_refresh_timer = hub.setTimeout(refresh_interval_seconds * 1000, function()\n    sun_runtime.status_refresh_timer = nil\n    sun_actions.refresh_status_views()\n    sun_actions.schedule_status_refresh()\n  end)\nend\n\nfunction sun_actions.get_sun_event_delay_seconds(variable_name)\n  local configured_delay_seconds = tonumber(self.store[variable_name])\n  if configured_delay_seconds == nil then\n    configured_delay_seconds = sun_event_delay_config.default_seconds\n  end\n  configured_delay_seconds = math.floor(configured_delay_seconds + 0.5)\n  if configured_delay_seconds < (sun_event_delay_config.min_minutes * 60) then\n    configured_delay_seconds = sun_event_delay_config.min_minutes * 60\n  elseif configured_delay_seconds > (sun_event_delay_config.max_minutes * 60) then\n    configured_delay_seconds = sun_event_delay_config.max_minutes * 60\n  end\n  self.store[variable_name] = configured_delay_seconds\n  return configured_delay_seconds\nend\n\nfunction sun_actions.get_sun_event_delay_minutes(variable_name)\n  return math.floor(sun_actions.get_sun_event_delay_seconds(variable_name) / 60)\nend\n\nfunction sun_actions.set_sun_event_delay_minutes(variable_name, delay_minutes)\n  local normalized_delay_minutes = tonumber(delay_minutes)\n  if normalized_delay_minutes == nil then\n    normalized_delay_minutes = sun_event_delay_config.min_minutes\n  end\n\n  normalized_delay_minutes = math.floor(normalized_delay_minutes + 0.5)\n  if normalized_delay_minutes < sun_event_delay_config.min_minutes then\n    normalized_delay_minutes = sun_event_delay_config.min_minutes\n  elseif normalized_delay_minutes > sun_event_delay_config.max_minutes then\n    normalized_delay_minutes = sun_event_delay_config.max_minutes\n  end\n\n  self.store[variable_name] = normalized_delay_minutes * 60\n  return normalized_delay_minutes\nend\n\nfunction sun_actions.refresh_sun_event_delay_slider(slider_view_name, variable_name)\n  local delay_minutes = sun_actions.get_sun_event_delay_minutes(variable_name)\n  self:updateView(slider_view_name, \"min\", tostring(sun_event_delay_config.min_minutes))\n  self:updateView(slider_view_name, \"max\", tostring(sun_event_delay_config.max_minutes))\n  self:updateView(slider_view_name, \"step\", \"1\")\n  self:updateView(slider_view_name, \"value\", tostring(delay_minutes))\nend\n\nfunction sun_actions.execute_sun_event_action(configured_action_name)\n  if configured_action_name == \"scene1\" then\n    activatesave1()\n    return true\n  elseif configured_action_name == \"scene2\" then\n    activatesave2()\n    return true\n  elseif configured_action_name == \"scene3\" then\n    activatesave3()\n    return true\n  elseif configured_action_name == \"scene4\" then\n    activatesave4()\n    return true\n  elseif configured_action_name == \"scene5\" then\n    activatesave5()\n    return true\n  elseif configured_action_name == \"scene6\" then\n    activatesave6()\n    return true\n  elseif configured_action_name == \"turnOn\" then\n    turnon()\n    return true\n  elseif configured_action_name == \"turnOff\" then\n    turnoff()\n    return true\n  end\n  return false\nend\n\nfunction sun_actions.get_sun_action_config_key(event_name, sun_state_reason)\n  if sun_state_reason == \"normal\" then\n    return nil\n  end\n  return \"run_\"..tostring(event_name)..\"_action_in_\"..tostring(sun_state_reason)\nend\n\nfunction sun_actions.should_run_sun_action(event_name, sun_state_reason)\n  local config_key = sun_actions.get_sun_action_config_key(event_name, sun_state_reason)\n  if config_key == nil then\n    return true\n  end\n  return SUN_STATE_CONFIG[config_key] == true\nend\n\nfunction sun_actions.run_configured_sun_action(event_name, action_phase, configured_action_name)\n  local _, sun_state_reason = refresh_sun_state()\n  local readable_event_name = tostring(event_name)\n  local readable_phase = tostring(action_phase or \"action\")\n  if configured_action_name == nil or configured_action_name == \"no_action\" then\n    self.runtime.last_sun_action_text = readable_event_name..\" \"..readable_phase..\": no action\"\n    sun_actions.refresh_status_views()\n    return false\n  end\n\n  if not sun_actions.should_run_sun_action(readable_event_name, sun_state_reason) then\n    local skip_text = translation[readable_event_name]..\" \"..translation[readable_phase]..\" \"..translation[\"skipped in\"]..\" \"..sun_actions.get_sun_state_reason_text(sun_state_reason)\n    self.runtime.last_sun_action_text = skip_text\n    add_error_status(skip_text, true)\n    sun_actions.refresh_status_views()\n    return false\n  end\n\n  local action_ran = sun_actions.execute_sun_event_action(configured_action_name)\n  local status_text = translation[readable_event_name]..\" \"..translation[readable_phase]..\": \"..tostring(configured_action_name)\n  self.runtime.last_sun_action_text = status_text\n  add_error_status(status_text, false)\n  sun_actions.refresh_status_views()\n  return action_ran\nend\n\nfunction sun_actions.schedule_delayed_sun_event_action(timer_ref_name, configured_action_name, delay_seconds, event_name, action_callback)\n  if timer_ref_name == \"sunrise\" then\n    sun_runtime.sunrise_delay_action_timer = clear_scheduled_timer(sun_runtime.sunrise_delay_action_timer)\n  else\n    sun_runtime.sunset_delay_action_timer = clear_scheduled_timer(sun_runtime.sunset_delay_action_timer)\n  end\n\n  if configured_action_name == nil or configured_action_name == \"no_action\" then\n    return\n  end\n\n  local normalized_delay_seconds = tonumber(delay_seconds) or 0\n  if normalized_delay_seconds <= 0 then\n    action_callback()\n    return\n  end\n\n  self:debug(\"Scheduling \"..tostring(event_name)..\" delayed action in \"..tostring(normalized_delay_seconds)..\" seconds\")\n  local timer_ref = hub.setTimeout(normalized_delay_seconds * 1000, function()\n    if timer_ref_name == \"sunrise\" then\n      sun_runtime.sunrise_delay_action_timer = nil\n    else\n      sun_runtime.sunset_delay_action_timer = nil\n    end\n    action_callback()\n  end)\n\n  if timer_ref_name == \"sunrise\" then\n    sun_runtime.sunrise_delay_action_timer = timer_ref\n  else\n    sun_runtime.sunset_delay_action_timer = timer_ref\n  end\nend\n\nfunction sun_actions.schedule_daily_offset_event(event_name, time_text, offset_minutes, event_callback)\n  local event_hour, event_minute = parse_clock_time(time_text)\n  if event_hour == nil or event_minute == nil then\n    self:warning(\"Skipped \"..tostring(event_name)..\" scheduling because time is invalid: \"..tostring(time_text))\n    add_error_status(translation[\"Skipped\"]..\" \"..tostring(event_name)..\": \"..translation[\"invalid time\"]..\" \"..tostring(time_text), true)\n    return nil\n  end\n\n  local now_timestamp = os.time()\n  local now_date = os.date(\"*t\", now_timestamp)\n  local target_timestamp = os.time({\n    year = now_date.year,\n    month = now_date.month,\n    day = now_date.day,\n    hour = event_hour,\n    min = event_minute,\n    sec = 0,\n  }) + ((tonumber(offset_minutes) or 0) * 60)\n\n  if target_timestamp <= now_timestamp then\n    target_timestamp = target_timestamp + (24 * 60 * 60)\n  end\n\n  local delay_ms = math.max(1000, math.floor((target_timestamp - now_timestamp) * 1000))\n  self:debug(\"Scheduling \"..tostring(event_name)..\" for \"..os.date(\"%Y-%m-%d %H:%M\", target_timestamp))\n  return hub.setTimeout(delay_ms, event_callback)\nend\n\nfunction sun_actions.info_offset_time()\n  refresh_sun_state()\n  local day_status_text = translation[self.store.night_or_day]\n  local line = \"\"..color1..\"\"..translation[\"Status of the day is: \"]..\"\"..color2..\"\"..day_status_text..\"\"\n  line = \"\"..line..\"\\n\"..color1..\"\"..build_icon_text(qa_ui_icons.sunrise, translation[\"Sunrise Offset is:\"])..\" \"..color2..\"\"..offset_sunrise..\"\"..color1..\" \"..translation[\"Min\"]\n  line = \"\"..line..\"\\n\"..color1..\"\"..build_icon_text(qa_ui_icons.sunrise, translation[\"Sunrise is at:\"])..\" \"..color2..\"\"..sunrise_time..\"\"..color1..\"\"\n  line = \"\"..line..\"\\n\"..color1..\"\"..build_icon_text(qa_ui_icons.sunset, translation[\"Sunset Offset is:\"])..\" \"..color2..\"\"..offset_sunset..\"\"..color1..\" \"..translation[\"Min\"]\n  line = \"\"..line..\"\\n\"..color1..\"\"..build_icon_text(qa_ui_icons.sunset, translation[\"Sunset is at:\"])..\" \"..color2..\"\"..sunset_time..\"\"..color1..\"\"\n  self:updateView(\"info_offset_time\", \"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line..\"  </tt></font></section>\")\n  sun_actions.info_status()\nend\n\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\n\nsun_actions.schedule_next_sunset_event = function()\n  sun_runtime.sunset_event_timer = clear_scheduled_timer(sun_runtime.sunset_event_timer)\n  local latest_sunset_time = safe_hub_get_value(1, \"sunsetHour\", \"Unable to schedule sunset event\")\n  if latest_sunset_time ~= nil then\n    sunset_time = latest_sunset_time\n  end\n\n  sun_runtime.sunset_event_timer = sun_actions.schedule_daily_offset_event(\"sunset event\", sunset_time, offset_sunset, function()\n    sun_runtime.sunset_event_timer = nil\n    self:debug(\"sunset with offset\")\n    sun_actions.Sunset_event()\n    sun_actions.schedule_next_sunset_event()\n  end)\nend\n\n------------------------------------------\nfunction QuickApp:t1()\n  --Event:post {type='cron'}\n\n\n\n  sun_actions.Sunset_event()\n  sun_actions.info_offset_time()\nend\n\n-----------------------------------\nsun_actions.Sunset_event = function()\n  local _, sun_state_reason = refresh_sun_state()\n  local text = \"\"..translation[\"sunset with offset: \"]..\"\"..os.date(\"%H:%M\")..\"\"\n  text = \"\"..text..\"\\n\"..translation[\"sunset time: \"]..\"\"..sunset_time..\"\"\n  safe_send_push_notification(\"push_sunset\", \"sunset\", text)\n\n  if sun_actions.should_run_sun_action(\"sunset\", sun_state_reason) then\n    sun_actions.sunset_args()\n    sun_actions.schedule_delayed_sun_event_action(\n      \"sunset\",\n      self.store.sunset_delay_args,\n      sun_actions.get_sun_event_delay_seconds(\"sunset_delay_time\"),\n      \"sunset\",\n      sun_actions.sunset_args_delay\n    )\n  else\n    sun_actions.run_configured_sun_action(\"sunset\", \"event\", self.store.sunset_args)\n  end\n  if   self.store.sunset_pir_disable == \"on\" then\n    self.store.enable_status = \"off\"\n  end\n  if   self.store.sunset_pir_enable == \"on\" then\n    self.store.enable_status = \"on\"\n  end\n  info_pir_enable()\n  enable_status_fun()\nend\n\n---------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------\nsun_actions.sunset_args = function()\n  sun_actions.run_configured_sun_action(\"sunset\", \"event\", self.store.sunset_args)\nend\n\nsun_actions.sunset_args_delay = function()\n  sun_actions.run_configured_sun_action(\"sunset\", \"delay\", self.store.sunset_delay_args)\nend\n\n\n\n------------------------------------------\n------------------------------------------\nfunction QuickApp:offset_sunset_n()\n  offset_sunset = offset_sunset - 1\n  if offset_sunset < -59 then offset_sunset = 59 end\n  sun_actions.info_offset_time()\n  self.store.offset_sunset = offset_sunset\n  sun_actions.schedule_next_sunset_event()\nend\n------------------------------------------\nfunction QuickApp:offset_sunset_p()\n  offset_sunset = offset_sunset + 1\n  if offset_sunset > 59 then offset_sunset = -59 end\n  sun_actions.info_offset_time()\n  self.store.offset_sunset = offset_sunset\n  sun_actions.schedule_next_sunset_event()\nend\n------------------------------------------\nfunction QuickApp:offset_sunset_n_l()\n  offset_sunset = offset_sunset - 10\n  if offset_sunset < -59 then offset_sunset = 59 end\n  sun_actions.info_offset_time()\n  self.store.offset_sunset = offset_sunset\n  sun_actions.schedule_next_sunset_event()\nend\n------------------------------------------\nfunction QuickApp:offset_sunset_p_l()\n  offset_sunset = offset_sunset + 10\n  if offset_sunset > 59 then offset_sunset = 0 end\n  sun_actions.info_offset_time()\n  self.store.offset_sunset = offset_sunset\n  sun_actions.schedule_next_sunset_event()\nend\n\n\n\n\n\n\n\n\n\n\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\n\n\nsafe_startup_call(\"register_midnight_event\", function()\nEvent.id='_'\nEvent{type='cron', time='1 0 * * *'}\nfunction Event:handler(event)\n  self:debug(\"Midnight\")\n  sun_actions.midnight()\nend\nend)\n\n\nsun_actions.midnight = function()\n  sunrise_time = safe_hub_get_value(1, \"sunriseHour\", \"Unable to refresh sunrise time\") or \"--:--\"\n  sunset_time = safe_hub_get_value(1, \"sunsetHour\", \"Unable to refresh sunset time\") or \"--:--\"\n  refresh_sun_state()\n  sun_actions.info_offset_time()\n  if sun_actions.refresh_sun_event_schedules ~= nil then\n    sun_actions.refresh_sun_event_schedules()\n  end\nend\nsafe_startup_call(\"midnight\", sun_actions.midnight)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\n\nsun_actions.schedule_next_sunrise_event = function()\n  sun_runtime.sunrise_event_timer = clear_scheduled_timer(sun_runtime.sunrise_event_timer)\n  local latest_sunrise_time = safe_hub_get_value(1, \"sunriseHour\", \"Unable to schedule sunrise event\")\n  if latest_sunrise_time ~= nil then\n    sunrise_time = latest_sunrise_time\n  end\n\n  sun_runtime.sunrise_event_timer = sun_actions.schedule_daily_offset_event(\"sunrise event\", sunrise_time, offset_sunrise, function()\n    sun_runtime.sunrise_event_timer = nil\n    self:debug(\"sunrise with offset\")\n    sun_actions.Sunrise_event()\n    sun_actions.schedule_next_sunrise_event()\n  end)\nend\n\nsun_actions.refresh_sun_event_schedules = function()\n  sun_actions.schedule_next_sunrise_event()\n  sun_actions.schedule_next_sunset_event()\nend\n-----------------------------------\nsun_actions.Sunrise_event = function()\n  local _, sun_state_reason = refresh_sun_state()\n\n  local text = \"\"..translation[\"Sunrise with offset: \"]..\"\"..os.date(\"%H:%M\")..\"\"\n  text = \"\"..text..\"\\n\"..translation[\"Sunrise time: \"]..\"\"..sunrise_time..\"\"\n\n  safe_send_push_notification(\"push_sunrise\", \"sunrise\", text)\n\n  if sun_actions.should_run_sun_action(\"sunrise\", sun_state_reason) then\n    sun_actions.sunrise_args()\n    sun_actions.schedule_delayed_sun_event_action(\n      \"sunrise\",\n      self.store.sunrise_delay_args,\n      sun_actions.get_sun_event_delay_seconds(\"sunrise_delay_time\"),\n      \"sunrise\",\n      sun_actions.sunrise_args_delay\n    )\n  else\n    sun_actions.run_configured_sun_action(\"sunrise\", \"event\", self.store.sunrise_args)\n  end\n  if   self.store.sunrise_pir_disable == \"on\" then\n    self.store.enable_status = \"off\"\n  end\n  if   self.store.sunrise_pir_enable == \"on\" then\n    self.store.enable_status = \"on\"\n  end\n  info_pir_enable()\n  enable_status_fun()\nend\n\n---------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------\nsun_actions.sunrise_args = function()\n  sun_actions.run_configured_sun_action(\"sunrise\", \"event\", self.store.sunrise_args)\nend\n\nsun_actions.sunrise_args_delay = function()\n  sun_actions.run_configured_sun_action(\"sunrise\", \"delay\", self.store.sunrise_delay_args)\nend\n\n\n\n\n\n\n\n------------------------------------------\nfunction QuickApp:offset_sunrise_n()\n  offset_sunrise = offset_sunrise - 1\n  if offset_sunrise < -59 then offset_sunrise = 59 end\n  sun_actions.info_offset_time()\n  self.store.offset_sunrise = offset_sunrise\n  sun_actions.schedule_next_sunrise_event()\nend\n------------------------------------------\nfunction QuickApp:offset_sunrise_p()\n  offset_sunrise = offset_sunrise + 1\n  if offset_sunrise > 59 then offset_sunrise = -59 end\n  sun_actions.info_offset_time()\n  self.store.offset_sunrise = offset_sunrise\n  sun_actions.schedule_next_sunrise_event()\nend\n------------------------------------------\nfunction QuickApp:offset_sunrise_n_l()\n  offset_sunrise = offset_sunrise - 10\n  if offset_sunrise < -59 then offset_sunrise = 59 end\n  sun_actions.info_offset_time()\n  self.store.offset_sunrise = offset_sunrise\n  sun_actions.schedule_next_sunrise_event()\nend\n------------------------------------------\nfunction QuickApp:offset_sunrise_p_l()\n  offset_sunrise = offset_sunrise + 10\n  if offset_sunrise > 59 then offset_sunrise = -59 end\n  sun_actions.info_offset_time()\n  self.store.offset_sunrise = offset_sunrise\n  sun_actions.schedule_next_sunrise_event()\nend\n\n------------------------------------------\nfunction QuickApp:t2()\n  sun_actions.Sunrise_event()\n\n\n\n  sun_actions.info_offset_time()\nend\n\nsafe_startup_call(\"schedule_sunrise_event\", sun_actions.schedule_next_sunrise_event)\nsafe_startup_call(\"schedule_sunset_event\", sun_actions.schedule_next_sunset_event)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n--------------------------------------------------------------------------------------------------------------------------------\n--------------------------------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n----- \nfunction sun_actions.info_sunset_select()\n  local line = \"\"..color1..\"\"..build_icon_text(qa_ui_icons.sunset, translation[\"Choose what should happen on sunset Event\"])\n  self:updateView(\"info_sunset_select\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line..\"   </tt></font></section>\")\n  end\n  safe_startup_call(\"info_sunset_select\", sun_actions.info_sunset_select)\n\nfunction sun_actions.info_sunset_select_delay()\n  local delay_minutes = sun_actions.get_sun_event_delay_minutes(\"sunset_delay_time\")\n  local line = \"\"..color1..\"\"..build_icon_text(qa_ui_icons.sunset, translation[\"Choose what should happen on sunset Delay Event\"])..\" \"..color2..\"(\"..tostring(delay_minutes)..\" \"..translation[\"Min\"]..\")\"\n  self:updateView(\"info_sunset_select_delay\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line..\"   </tt></font></section>\")\nend\nsafe_startup_call(\"info_sunset_select_delay\", sun_actions.info_sunset_select_delay)\nsafe_startup_call(\"refresh_sunset_select_delay_slider\", function()\n  sun_actions.refresh_sun_event_delay_slider(\"sunset_select_delay_slider\", \"sunset_delay_time\")\nend)\n\n----------------------------------------------------------------------------------------------------------\n-----\nfunction QuickApp:sunset_select(args)\n  --print(\"args: \", json.encode(args))\n    local selected_value = get_single_callback_value(args)\n    if selected_value ~= nil then \n    self:updateView(\"sunset_select\", \"selectedItem\", \"\"..selected_value..\"\")\n    self.store.sunset_args = \"\"..selected_value..\"\"\n    self:debug(\"Selected: \" .. selected_value)\n    end\nend\nself:updateView(\"sunset_select\", \"selectedItem\", self.store.sunset_args)\n\nfunction QuickApp:sunset_select_delay(args)\n    local selected_value = get_single_callback_value(args)\n    if selected_value ~= nil then\n    self:updateView(\"sunset_select_delay\", \"selectedItem\", \"\"..selected_value..\"\")\n    self.store.sunset_delay_args = \"\"..selected_value..\"\"\n    self:debug(\"Selected sunset delay: \" .. selected_value)\n    end\nend\nself:updateView(\"sunset_select_delay\", \"selectedItem\", self.store.sunset_delay_args)\n\nfunction QuickApp:sunset_select_delay_slider(args)\n  local delay_minutes = sun_actions.set_sun_event_delay_minutes(\"sunset_delay_time\", get_single_callback_value(args))\n  self:updateView(\"sunset_select_delay_slider\", \"value\", tostring(delay_minutes))\n  sun_actions.info_sunset_select_delay()\n  self:debug(\"Selected sunset delay minutes: \" .. tostring(delay_minutes))\nend\n\n----------------------------------------------------------------------------------------------------------\n-----\nfunction sun_actions.info_sunrise_select()\n  local line = \"\"..color1..\"\"..build_icon_text(qa_ui_icons.sunrise, translation[\"Choose what should happen on Sunrise Event\"])\n  self:updateView(\"info_sunrise_select\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line..\"   </tt></font></section>\")\n  end\n  safe_startup_call(\"info_sunrise_select\", sun_actions.info_sunrise_select)\n\nfunction sun_actions.info_sunrise_select_delay()\n  local delay_minutes = sun_actions.get_sun_event_delay_minutes(\"sunrise_delay_time\")\n  local line = \"\"..color1..\"\"..build_icon_text(qa_ui_icons.sunrise, translation[\"Choose what should happen on Sunrise Delay Event\"])..\" \"..color2..\"(\"..tostring(delay_minutes)..\" \"..translation[\"Min\"]..\")\"\n  self:updateView(\"info_sunrise_select_delay\",\"text\",\"<table width= 350px border = 0px><td align =left><section align='left'><font size='\"..Fontsize..\"'><tt> \"..line..\"   </tt></font></section>\")\nend\nsafe_startup_call(\"info_sunrise_select_delay\", sun_actions.info_sunrise_select_delay)\nsafe_startup_call(\"refresh_sunrise_select_delay_slider\", function()\n  sun_actions.refresh_sun_event_delay_slider(\"sunrise_select_delay_slider\", \"sunrise_delay_time\")\nend)\n\n----------------------------------------------------------------------------------------------------------\n-----\nfunction QuickApp:sunrise_select(args)\n  --print(\"args: \", json.encode(args))\n    local selected_value = get_single_callback_value(args)\n    if selected_value ~= nil then \n    self:updateView(\"sunrise_select\", \"selectedItem\", \"\"..selected_value..\"\")\n    self.store.sunrise_args = \"\"..selected_value..\"\"\n    self:debug(\"Selected: \" .. selected_value)\n    end\nend\nself:updateView(\"sunrise_select\", \"selectedItem\", self.store.sunrise_args)\n\nfunction QuickApp:sunrise_select_delay(args)\n    local selected_value = get_single_callback_value(args)\n    if selected_value ~= nil then\n    self:updateView(\"sunrise_select_delay\", \"selectedItem\", \"\"..selected_value..\"\")\n    self.store.sunrise_delay_args = \"\"..selected_value..\"\"\n    self:debug(\"Selected sunrise delay: \" .. selected_value)\n    end\nend\nself:updateView(\"sunrise_select_delay\", \"selectedItem\", self.store.sunrise_delay_args)\n\nfunction QuickApp:sunrise_select_delay_slider(args)\n  local delay_minutes = sun_actions.set_sun_event_delay_minutes(\"sunrise_delay_time\", get_single_callback_value(args))\n  self:updateView(\"sunrise_select_delay_slider\", \"value\", tostring(delay_minutes))\n  sun_actions.info_sunrise_select_delay()\n  self:debug(\"Selected sunrise delay minutes: \" .. tostring(delay_minutes))\nend\n\nfunction QuickApp:push_user(args)\n  safe_ui_callback(\"push_user\", function()\n    local selected_values = get_multi_callback_value(args)\n    if selected_values == nil then\n      return\n    end\n\n    set_pending_push_user_ids(sanitize_selection_ids(selected_values, push_user_name_by_id))\n    queue_push_ui_refresh(true, false)\n  end)\nend\n\nfunction QuickApp:push_device(args)\n  safe_ui_callback(\"push_device\", function()\n    local selected_values = get_multi_callback_value(args)\n    if selected_values == nil then\n      return\n    end\n\n    set_pending_push_device_ids(sanitize_selection_ids(selected_values, push_device_name_by_id))\n    queue_push_ui_refresh(false, false)\n  end)\nend\n\nfunction QuickApp:push_save(args)\n  safe_ui_callback(\"push_save\", function()\n    set_saved_push_user_ids(pending_push_user_ids)\n    set_saved_push_device_ids(pending_push_device_ids)\n    load_push_device_options()\n    queue_push_ui_refresh(true, true)\n  end)\nend\n\nfunction QuickApp:push_device_onoff(args)\n  self.store.push_device_onoff = get_switch_toggle_value(args, \"push_device_onoff\") and \"on\" or \"off\"\n  refresh_push_toggle_button(\"push_device_onoff\", qa_ui_icons.device, \"push_device_onoff\")\nend\nsafe_startup_call(\"refresh_push_device_onoff_button\", function()\n  refresh_push_toggle_button(\"push_device_onoff\", qa_ui_icons.device, \"push_device_onoff\")\nend)\n\nfunction QuickApp:test_push(args)\n  self:updateView(\"test_push\", \"value\", \"true\")\n\n  local sunrise_test_text = \"\"..translation[\"Sunrise with offset: \"]..\"\"..os.date(\"%H:%M\")..\"\"\n  sunrise_test_text = \"\"..sunrise_test_text..\"\\n\"..translation[\"Sunrise time: \"]..\"\"..sunrise_time..\"\"\n\n  local sunset_test_text = \"\"..translation[\"sunset with offset: \"]..\"\"..os.date(\"%H:%M\")..\"\"\n  sunset_test_text = \"\"..sunset_test_text..\"\\n\"..translation[\"sunset time: \"]..\"\"..sunset_time..\"\"\n\n  safe_send_push_notification(\"push_sunrise\", \"test sunrise\", sunrise_test_text, true)\n  safe_send_push_notification(\"push_sunset\", \"test sunset\", sunset_test_text, true)\n\n  hub.setTimeout(1000, function()\n    self:updateView(\"test_push\", \"value\", \"false\")\n  end)\nend\nself:updateView(\"test_push\", \"text\", build_icon_text(qa_ui_icons.test, translation[\"Test Push\"]))\n\nfunction QuickApp:push_sunrise(args)\n  self.store.push_sunrise = get_switch_toggle_value(args, \"push_sunrise\") and \"on\" or \"off\"\n  refresh_push_toggle_button(\"push_sunrise\", qa_ui_icons.sunrise, \"push_sunrise\", translation[\"Sunrise Push\"])\n  info_push()\nend\nsafe_startup_call(\"refresh_push_sunrise_button\", function()\n  refresh_push_toggle_button(\"push_sunrise\", qa_ui_icons.sunrise, \"push_sunrise\", translation[\"Sunrise Push\"])\nend)\n\nfunction QuickApp:push_sunset(args)\n  self.store.push_sunset = get_switch_toggle_value(args, \"push_sunset\") and \"on\" or \"off\"\n  refresh_push_toggle_button(\"push_sunset\", qa_ui_icons.sunset, \"push_sunset\", translation[\"Sunset Push\"])\n  info_push()\nend\nsafe_startup_call(\"refresh_push_sunset_button\", function()\n  refresh_push_toggle_button(\"push_sunset\", qa_ui_icons.sunset, \"push_sunset\", translation[\"Sunset Push\"])\nend)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n\n  function QuickApp:sunrise_pir_disable(args)\n    local selected_value = get_callback_value(args)\n    if selected_value == true then\n    self.store.sunrise_pir_disable = \"on\"\n    self.store.sunrise_pir_enable = \"off\"\n    elseif selected_value == false then\n    self.store.sunrise_pir_disable = \"off\"\n    else\n    return\n    end\n    sun_actions.sunrise_pir()\n  end\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\nfunction QuickApp:sunrise_pir_enable(args)\n    local selected_value = get_callback_value(args)\n    if selected_value == true then\n      self.store.sunrise_pir_enable = \"on\"\n      self.store.sunrise_pir_disable = \"off\"\n    elseif selected_value == false then\n     self.store.sunrise_pir_enable = \"off\"\n    else\n    return\n    end\n    sun_actions.sunrise_pir()\nend\n----------------------------------------------------------------------------------------------------------\n\n\nsun_actions.sunrise_pir = function()\n  if self.store.sunrise_pir_enable == \"on\" then\n  self:updateView(\"sunrise_pir_enable\", \"value\", \"true\")\n  else\n  self:updateView(\"sunrise_pir_enable\", \"value\", \"false\")\n  end\n  if self.store.sunrise_pir_disable == \"on\" then\n  self:updateView(\"sunrise_pir_disable\", \"value\", \"true\")\n  else\n  self:updateView(\"sunrise_pir_disable\", \"value\", \"false\")\n  end\nend\nsafe_startup_call(\"sunrise_pir\", sun_actions.sunrise_pir)\nself:updateView(\"sunrise_pir_enable\", \"text\", build_icon_text(qa_ui_icons.sunrise, translation[\"Enable Pir\"]))\nself:updateView(\"sunrise_pir_disable\", \"text\", build_icon_text(qa_ui_icons.sunrise, translation[\"Disable Pir\"]))\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n\nfunction QuickApp:sunset_pir_disable(args)\n  local selected_value = get_callback_value(args)\n  if selected_value == true then\n  self.store.sunset_pir_disable = \"on\"\n  self.store.sunset_pir_enable = \"off\"\n  elseif selected_value == false then\n  self.store.sunset_pir_disable = \"off\"\n  else\n  return\n  end\n  sun_actions.sunset_pir()\nend\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\nfunction QuickApp:sunset_pir_enable(args)\n  local selected_value = get_callback_value(args)\n  if selected_value == true then\n    self.store.sunset_pir_enable = \"on\"\n    self.store.sunset_pir_disable = \"off\"\n  elseif selected_value == false then\n   self.store.sunset_pir_enable = \"off\"\n  else\n  return\n  end\n  sun_actions.sunset_pir()\nend\n----------------------------------------------------------------------------------------------------------\n\n\nsun_actions.sunset_pir = function()\nif self.store.sunset_pir_enable == \"on\" then\nself:updateView(\"sunset_pir_enable\", \"value\", \"true\")\nelse\nself:updateView(\"sunset_pir_enable\", \"value\", \"false\")\nend\nif self.store.sunset_pir_disable == \"on\" then\nself:updateView(\"sunset_pir_disable\", \"value\", \"true\")\nelse\nself:updateView(\"sunset_pir_disable\", \"value\", \"false\")\nend\nend\nsafe_startup_call(\"sunset_pir\", sun_actions.sunset_pir)\nself:updateView(\"sunset_pir_enable\", \"text\", build_icon_text(qa_ui_icons.sunset, translation[\"Enable Pir\"]))\nself:updateView(\"sunset_pir_disable\", \"text\", build_icon_text(qa_ui_icons.sunset, translation[\"Disable Pir\"]))\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n\nfunction QuickApp:Restart()\n  self:setVariable(\"Setup\", \"1\")\n  plugin.restart()\nend\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n  \n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n----------------------------------------------------------------------------------------------------------\n----------------------------------------------------------------------------------------------------------\n---all labels false\nbutton_labels_false = function()\n  self:updateView(\"bactivatesave1\", \"value\", \"false\")  \n  self:updateView(\"bactivatesave11\", \"value\", \"false\")   \n  self:updateView(\"bactivatesave2\", \"value\", \"false\")  \n  self:updateView(\"bactivatesave22\", \"value\", \"false\")   \n  self:updateView(\"bactivatesave3\", \"value\", \"false\")  \n  self:updateView(\"bactivatesave33\", \"value\", \"false\")   \n  self:updateView(\"bactivatesave4\", \"value\", \"false\")  \n  self:updateView(\"bactivatesave44\", \"value\", \"false\")    \n  self:updateView(\"bactivatesave5\", \"value\", \"false\")  \n  self:updateView(\"bactivatesave55\", \"value\", \"false\")   \n  self:updateView(\"bactivatesave6\", \"value\", \"false\")  \n  self:updateView(\"bactivatesave66\", \"value\", \"false\")    \n  self:updateView(\"bturnoff\", \"value\", \"false\") \n  self:updateView(\"bturnon\", \"value\", \"false\") \n  end\n\nfunction sun_actions.restore_active_scene_button()\n  button_labels_false()\n  local active_action = tostring(self.store.current_scene_action or \"\")\n  if active_action == \"\" then\n    local stored_scene_name = tostring(self.store.current_scene or \"\")\n    local scene_name_actions = {\n      [tostring(scene1)] = \"scene1\",\n      [tostring(scene2)] = \"scene2\",\n      [tostring(scene3)] = \"scene3\",\n      [tostring(scene4)] = \"scene4\",\n      [tostring(scene5)] = \"scene5\",\n      [tostring(scene6)] = \"scene6\",\n      [tostring(translation[\"Turn ON\"])] = \"turnOn\",\n      [tostring(translation[\"Turn OFF\"])] = \"turnOff\",\n    }\n    active_action = scene_name_actions[stored_scene_name] or \"\"\n    if active_action ~= \"\" then\n      self.store.current_scene_action = active_action\n    end\n  end\n  local active_scene_buttons = {\n    scene1 = {\"bactivatesave1\", \"bactivatesave11\"},\n    scene2 = {\"bactivatesave2\", \"bactivatesave22\"},\n    scene3 = {\"bactivatesave3\", \"bactivatesave33\"},\n    scene4 = {\"bactivatesave4\", \"bactivatesave44\"},\n    scene5 = {\"bactivatesave5\", \"bactivatesave55\"},\n    scene6 = {\"bactivatesave6\", \"bactivatesave66\"},\n    turnOn = {\"bturnon\"},\n    turnOff = {\"bturnoff\"},\n  }\n  local view_names = active_scene_buttons[active_action]\n  if view_names == nil then\n    return\n  end\n  for _, view_name in ipairs(view_names) do\n    self:updateView(view_name, \"value\", \"true\")\n  end\nend\n\nfunction sun_actions.schedule_startup_scene_match()\n  local delay_seconds = tonumber(STARTUP_SCENE_MATCH_DELAY_SECONDS) or 30\n  if delay_seconds < 1 then\n    delay_seconds = 1\n  end\n\n  hub.setTimeout(delay_seconds * 1000, function()\n    local matched_action, matched_scene_name = find_matching_scene_action()\n    if matched_action ~= nil then\n      self.store.current_scene_action = matched_action\n      self.store.current_scene = tostring(matched_scene_name or matched_action)\n      sun_actions.restore_active_scene_button()\n      add_error_status(translation[\"Startup scene match\"]..\": \"..tostring(matched_scene_name or matched_action), false)\n    else\n      sun_actions.restore_active_scene_button()\n      add_error_status(translation[\"Startup scene match\"]..\": \"..translation[\"no saved scene matched current lights\"], true)\n    end\n  end)\nend\n\nfunction sun_actions.init_status_runtime()\n  safe_startup_call(\"enable_status_fun\", enable_status_fun)\n  safe_startup_call(\"update_version_label\", update_version_label)\n  safe_startup_call(\"info_offset_time\", sun_actions.info_offset_time)\n  safe_startup_call(\"info_status\", sun_actions.info_status)\n  safe_startup_call(\"update_error_status_label\", update_error_status_label)\n  safe_startup_call(\"schedule_status_refresh\", sun_actions.schedule_status_refresh)\n  safe_startup_call(\"restore_active_scene_button\", sun_actions.restore_active_scene_button)\n  safe_startup_call(\"schedule_startup_scene_match\", sun_actions.schedule_startup_scene_match)\nend\n\nfunction sun_actions.init_main_control_labels()\n  self:updateView(\"select_light_setup\", \"text\", build_icon_text(qa_ui_icons.light, translation[\"Light List\"]))\n  self:updateView(\"select_motion_setup\", \"text\", build_icon_text(qa_ui_icons.motion, translation[\"Sensors\"]))\n  self:updateView(\"push_user\", \"text\", build_icon_text(qa_ui_icons.profile, translation[\"Push User\"]))\n  self:updateView(\"push_device\", \"text\", build_icon_text(qa_ui_icons.device, translation[\"Push Device\"]))\n  self:updateView(\"t1\", \"text\", build_icon_text(qa_ui_icons.sunset, translation[\"Sunset\"]))\n  self:updateView(\"t2\", \"text\", build_icon_text(qa_ui_icons.sunrise, translation[\"Sunrise\"]))\n  self:updateView(\"offset_sunset_n\", \"text\", qa_ui_icons.decrease)\n  self:updateView(\"offset_sunrise_n\", \"text\", qa_ui_icons.decrease)\n  self:updateView(\"offset_sunrise_p\", \"text\", qa_ui_icons.increase)\n  self:updateView(\"offset_sunset_p\", \"text\", qa_ui_icons.increase)\nend\n\nfunction sun_actions.init_separator_labels()\n  local separator_markup = \"<hr width=350px color=\"..color4..\" size=6px />\"\n  for _, info_line_name in ipairs({\n    \"infoLine1\", \"infoLine2\", \"infoLine3\", \"infoLine4\",\n    \"infoLine5\", \"infoLine6\", \"infoLine7\", \"infoLine8\",\n    \"infoLine9\", \"infoLine10\", \"infoLine11\", \"infoLine12\",\n  }) do\n    self:updateView(info_line_name, \"text\", separator_markup)\n  end\nend\n\nfunction sun_actions.init_deferred_scene_button_text_refresh()\n  schedule_scene_button_text_refresh(250)\n  schedule_scene_button_text_refresh(1000)\n  schedule_scene_button_text_refresh(2500)\nend\n\nfunction sun_actions.init_final_ui()\n  sun_actions.init_status_runtime()\n  sun_actions.init_main_control_labels()\n  sun_actions.init_separator_labels()\n  sun_actions.init_deferred_scene_button_text_refresh()\nend\n\n\n---------------------------------------------------------------------------------------------------------------------\n---------------------------------------------------------------------------------------------------------------------\n------update label for lines between the \"groups of functions in the QA view\"  \n\n\nsafe_startup_call(\"init_final_ui\", sun_actions.init_final_ui)\n\n\n--➕➖\n\n\n\n\n\n---------------------------------------------------------------------------------------------------------------------\n---startup timer. \nself:debug(\"ID:\"..quickapp_id..\" Name; \"..self.name..\" has started in the room: \"..self_room_name..\"\")\nself:debug(\"\"..quickapp_id..\" Used: \"..tostring(os.clock()-starttime)..\" sec to start\")\n\nend\n\nlocal ok, err = xpcall(init_main, function(init_err)\n  return build_error_trace(\"onInit\", init_err)\nend)\nif not ok then\n  self:error(err)\nend\n\nend --oninit\n\n\n\n\n\n"},{"name":"Translation","isMain":false,"isOpen":true,"content":"\nlocal qa_type = \"33. Outdoor Light Controller Language\"\nlocal version = \"v1.0.0\"\nlocal revision_date = \"01/05/26 01:41:10\"\n\nclass \"lang\"\nfunction lang:translation(language)\ntranslation = {\n  en = {\n    [\"Room Name: \"] = \"Room Name: \",\n    [\"Room ID: \"] = \"Room ID: \",\n    [\"Color Value is: \"] = \"Color Value is: \",\n    [\"Red\"] = \"Red\",\n    [\"Green\"] = \"Green\",\n    [\"Blue\"] = \"Blue\",\n    [\"white\"] = \"white\",\n    [\"Fire\"] = \"Fire\",\n    [\"Storm\"] = \"Storm\",\n    [\"RGB\"] = \"RGB\",\n    [\"Aurora\"] = \"Aurora\",\n    [\"Police\"] = \"Police\",\n    [\"No Program\"] = \"No Program\",\n    [\"Color Program is:\"] = \"Color Program is:\",\n    [\"Light Name: \"] = \"Light Name: \",\n    [\"Light Value: \"] = \"Light Value: \",\n    [\"Light id:\"] = \"Light id: \",\n    [\"Light\"] = \"Lights that is active: \",\n    [\"Pir Status is:\"] = \"Pir Status is:\",\n    [\"Safe\"] = \"Safe\",\n    [\"Detected\"] = \"Detected\",\n    [\"Active Profile is:\"] = \"Active Profile is:\",\n    [\"Change Delay\"] = \"Change Delay on Motion Sensor: \\n(not s2 inputs delay)\",\n    [\"Sensor timer is:\"] = \"Sensor timer is:\",\n    [\"Max time\"] = \"Max time 20min(+Deadband of sensor)\",\n    [\"Set fade\"] = \"Set fade rate and steps: \",\n    [\"Slow Off is:\"] = \"Slow Off is:\",\n    [\"Steps for Off: \"] = \"Steps for Off: \",\n    [\"Slow ON is: \"] = \"Slow ON is: \",\n    [\"Steps for ON: \"] = \"Steps for ON: \",\n    [\"Change: ON Steps\"] = \"Change: ON Steps\",\n    [\"Change: ON Time\"] = \"Change: ON Time\",\n    [\"Change: Off Steps\"] = \"Change: Off Steps\",\n    [\"Change: Off Time\"] = \"Change: Off Time\",\n    [\"Min\"] = \"Min\",\n    [\"Sec\"] = \"Sec\",\n    [\"Hold Down to save: \"] = \"Hold Down to save: \",\n    [\"Turn ON\"] = \"Turn ON\",\n    [\"Turn OFF\"] = \"Turn OFF\",\n    [\"Turn ON slow\"] = \"Turn ON slow\",\n    [\"Turn OFF slow\"] = \"Turn OFF slow\",\n    [\"No Action\"] = \"No Action\",\n    [\"Setup for Profile:\"] = \"Setup for Profile:\",\n    [\"Pir ON\"] = \"Pir ON\",\n    [\"Pir ON Event\"] = \"Choose what should happen on <font color=green>Pir ON Event\",\n    [\"Pir OFF Event\"] = \"Choose what should happen on <font color=red>Pir OFF Event\",\n    [\"Pir OFF Event Delay\"] = \"Choose what should happen on <font color=red>Pir OFF Event Delay\",\n    [\"Change Delay Timer:\"] = \"Change Delay on:\\n<font color=red>Pir OFF Event Delay\\n<font color=orange>Delay OFF Timer is:\",\n    [\"Pir Trigger ON\"] = \"Pir Trigger ON is set to: \",\n    [\"Pir Trigger Delay ON\"] = \"Pir Trigger Delay ON is set to:\", \n    [\"Pir Trigger Delay\"] = \"Pir Trigger Time Delay is set to:\",\n    [\"Pir OFF\"] = \"Pir OFF\",\n    [\"Pir Trigger OFF\"] = \"Pir Trigger OFF is set to: \",\n    [\"Pir Trigger Delay OFF\"] = \"Pir Trigger Delay OFF is set to:\", \n    [\"Profile Change\"] = \"Profile Change\",\n    [\"Profile Change is\"] = \"Profile Change is set to: \",\n    [\"Profile Change Delay\"] = \"Profile Change Delay is set to: \",\n    [\"Profile Change Time\"] = \"Profile Change Time Delay is set to:\",\n    [\"Follow Pir Status\"] = \"Follow Pir Status\",\n    [\"Not follow Pir status\"] =   \"Not follow Pir status\",\n    [\"Motion Sensor Name: \"] = \"Motion Sensor Name: \",\n    [\"Motion Sensor id: \"] = \"Motion Sensor id: \",\n    [\"Motion Sensors\"] = \"Motion Sensors that is active: \",\n    [\"Profil this device\"] = \"Change Profile Only on this device:\",\n    [\"setup: Bedroom\"] = \"Setup: Bedroom\", \n    [\"setup: Hallway\"] = \"Setup: Hallway\", \n    [\"setup: Living Room\"] = \"Setup: Living Room\", \n    [\"Setup\"] = \"Setup basic motion profiles\", \n    [\"update\"] = \"Update IDs\",   \n\n\n\n\n\n\n\n    [\"enable\"] = \"Enable\",   \n    [\"disable\"] = \"Disable\",   \n    [\"info_pir_enable\"] = \"Hold down buttons to Enable or Disable the motionsensor events, Status:\",   \n    [\"info_pir_enable_on\"] = \"Pir Events Enabled\",  \n    [\"info_pir_enable_off\"] = \"Pir Events Disabled\",  \n    [\"Status log ready\"] = \"Status log ready\",\n    [\"Sun state: \"] = \"Sun state: \",\n    [\"Mode: \"] = \"Mode: \",\n    [\"Last action: \"] = \"Last action: \",\n    [\"Next action: \"] = \"Next action: \",\n    [\"No sun action yet\"] = \"No sun action yet\",\n    [\"No valid sun event\"] = \"No valid sun event\",\n    [\"normal\"] = \"normal\",\n    [\"midnight sun\"] = \"midnight sun\",\n    [\"polar night\"] = \"polar night\",\n    [\"offset overlap\"] = \"offset overlap\",\n    [\"unknown\"] = \"unknown\",\n    [\"Sunrise\"] = \"Sunrise\",\n    [\"Sunset\"] = \"Sunset\",\n    [\"at\"] = \"at\",\n    [\"event\"] = \"event\",\n    [\"delay\"] = \"delay\",\n    [\"no action\"] = \"no action\",\n    [\"skipped in\"] = \"skipped in\",\n    [\"Skipped\"] = \"Skipped\",\n    [\"invalid time\"] = \"invalid time\",\n    [\"sunrise\"] = \"sunrise\",\n    [\"sunset\"] = \"sunset\",\n    [\"day\"] = \"day\",\n    [\"night\"] = \"night\",\n    [\"Sunrise Push\"] = \"Sunrise Push\",\n    [\"Sunset Push\"] = \"Sunset Push\",\n    [\"Sends push when the sunrise event runs\"] = \"Sends push when the sunrise event runs\",\n    [\"Sends push when the sunset event runs\"] = \"Sends push when the sunset event runs\",\n    [\"Health check\"] = \"Health check\",\n    [\"OK\"] = \"OK\",\n    [\"Startup scene match\"] = \"Startup scene match\",\n    [\"no saved scene matched current lights\"] = \"no saved scene matched current lights\",\n\n\n    },\n    no = {\n    [\"Room Name: \"] = \"Rom Navn: \",\n    [\"Room ID: \"] = \"Rom ID: \",\n    [\"Color Value is: \"] = \"Farge Nivå er: \",\n    [\"Red\"] = \"Rød\",\n    [\"Green\"] = \"Grønn\",\n    [\"Blue\"] = \"Blå\",\n    [\"white\"] = \"Hvit\",\n    [\"Fire\"] = \"Brann\",\n    [\"Storm\"] = \"Storm\",\n    [\"RGB\"] = \"RGB\",\n    [\"Aurora\"] = \"Aurora\",\n    [\"Police\"] = \"Politi\",\n    [\"No Program\"] = \"Ingen Program\",\n    [\"Color Program is:\"] = \"Farge Programmet er:\",\n    [\"Light Name: \"] = \"Lys Navn: \",\n    [\"Light Value: \"] = \"Lys Styrke: \",\n    [\"Light id:\"] = \"Lys id: \",\n    [\"Light\"] = \"Lys som er aktiv: \",\n    [\"Pir Status is:\"] = \"Pir Status er:\",\n    [\"Safe\"] = \"Ingen Bevegelse\",\n    [\"Detected\"] = \"Bevegelse\",\n    [\"Active Profile is:\"] = \"Aktiv Profil er:\",\n    [\"Change Delay\"] = \"Skift tiden på bevegelses sensoren: \\n(Ikke for s2 input sensor)\",\n    [\"Sensor timer is:\"] = \"Sensor tiden er:\",\n    [\"Max time\"] = \"Max tid er 20min(+dødbåndet av sensor)\",\n    [\"Set fade\"] = \"oppsett for tid og steg: \",\n    [\"Slow Off is:\"] = \"Sakte av er: \",\n    [\"Steps for Off: \"] = \"steg for sakte av: \",\n    [\"Slow ON is: \"] = \"Sakte på er: \",\n    [\"Steps for ON: \"] = \"steg for sakte på: \",\n    [\"Change: ON Steps\"] = \"Endre: På Steg\",\n    [\"Change: ON Time\"] = \"Endre: På Tid\",\n    [\"Change: Off Steps\"] = \"Endre: AV Steg\",\n    [\"Change: Off Time\"] = \"Endre: Av Tid\",\n    [\"Min\"] = \"Min\",\n    [\"Sec\"] = \"Sec\",\n    [\"Hold Down to save: \"] = \"Hold for å lagre: \",\n    [\"Turn ON\"] = \"Skru På\",\n    [\"Turn OFF\"] = \"Skru Av\",\n    [\"Turn ON slow\"] = \"Skru På Sakte\",\n    [\"Turn OFF slow\"] = \"Skru Av Sakte\",\n    [\"No Action\"] = \"Ingen ting\",\n    [\"Setup for Profile:\"] = \"Oppsett for Profil:\",\n    [\"Pir ON\"] = \"Pir På\",\n    [\"Pir ON Event\"] = \"Velg hva som skjer ved Pir går På Event\",\n    [\"Pir OFF Event\"] = \"Velg hva som skjer ved Pir går Av Event\",\n    [\"Pir OFF Event Delay\"] = \"Velg hva som skjer ved Pir går Av Event med forsinkelse\",\n    [\"Change Delay Timer:\"] = \"Skift forsinkelse for:\\n<font color=red>Pir AV Event Forsinkelse\\n<font color=orange>Forsinkelse AV Timer er:\",\n    [\"Pir Trigger ON\"] = \"Pir aktiv På er satt til: \",\n    [\"Pir Trigger Delay ON\"] = \"Pir aktiv forsinkelse På er satt til: \", \n    [\"Pir Trigger Delay\"] = \"Pir aktiv tids forsinkelse er satt til:\",\n    [\"Pir OFF\"] = \"Pir Av\",\n    [\"Pir Trigger OFF\"] = \"Pir inaktiv Av er satt til: \",\n    [\"Pir Trigger Delay OFF\"] = \"Pir inaktiv forsinkelse Av er satt til: \", \n    [\"Profile Change\"] = \"Profil Skifte\",\n    [\"Profile Change is\"] = \"Profil Skifte er satt til: \",\n    [\"Profile Change Delay\"] = \"Profil Skifte forsinkelse er satt til: \",\n    [\"Profile Change Time\"] = \"Profil Skifte tids forsinkelse er satt til:\",\n    [\"Follow Pir Status\"] = \"Følg Pir Status\",\n    [\"Not follow Pir status\"] =   \"ikke Følg Pir status\",\n    [\"Motion Sensor Name: \"] = \"Pir Sensor Navn: \",\n    [\"Motion Sensor id: \"] = \"Pir Sensor ID: \",\n    [\"Motion Sensors\"] = \"Pir Sensors som er aktive: \",\n    [\"Profil this device\"] = \"Skift Profil kun på denne enheten: \",\n    [\"setup: Bedroom\"] = \"Oppsett: Soverom\", \n    [\"setup: Hallway\"] = \"Oppsett: Vindfang\", \n    [\"setup: Living Room\"] = \"Oppsett: Stue\", \n    [\"Setup\"] = \"Oppsett for standard Profiler\", \n    [\"update\"] = \"Oppdater ID\", \n\n\n\n\n    [\"enable\"] = \"Aktiver\",   \n    [\"disable\"] = \"Deaktiver\",   \n    [\"info_pir_enable\"] = \"Hold ned Kanppene for å Aktiver eller Deaktiver Bevegelsessensor Events, Status:\",   \n    [\"info_pir_enable_on\"] = \"Pir Events Aktivert\",  \n    [\"info_pir_enable_off\"] = \"Pir Events Deaktivert\",  \n    [\"Status log ready\"] = \"Statuslogg klar\",\n    [\"Sun state: \"] = \"Solstatus: \",\n    [\"Mode: \"] = \"Modus: \",\n    [\"Last action: \"] = \"Siste handling: \",\n    [\"Next action: \"] = \"Neste handling: \",\n    [\"No sun action yet\"] = \"Ingen solhandling enda\",\n    [\"No valid sun event\"] = \"Ingen gyldig solhendelse\",\n    [\"normal\"] = \"normal\",\n    [\"midnight sun\"] = \"midnattssol\",\n    [\"polar night\"] = \"morketid\",\n    [\"offset overlap\"] = \"offset-overlapp\",\n    [\"unknown\"] = \"ukjent\",\n    [\"Sunrise\"] = \"Soloppgang\",\n    [\"Sunset\"] = \"Solnedgang\",\n    [\"at\"] = \"kl\",\n    [\"event\"] = \"hendelse\",\n    [\"delay\"] = \"forsinkelse\",\n    [\"no action\"] = \"ingen handling\",\n    [\"skipped in\"] = \"hoppet over i\",\n    [\"Skipped\"] = \"Hoppet over\",\n    [\"invalid time\"] = \"ugyldig tid\",\n    [\"sunrise\"] = \"soloppgang\",\n    [\"sunset\"] = \"solnedgang\",\n    [\"day\"] = \"dag\",\n    [\"night\"] = \"natt\",\n    [\"Sunrise Push\"] = \"Soloppgang push\",\n    [\"Sunset Push\"] = \"Solnedgang push\",\n    [\"Sends push when the sunrise event runs\"] = \"Sender push nar soloppgangshendelsen kjorer\",\n    [\"Sends push when the sunset event runs\"] = \"Sender push nar solnedgangshendelsen kjorer\",\n    [\"Health check\"] = \"Helsesjekk\",\n    [\"OK\"] = \"OK\",\n    [\"Startup scene match\"] = \"Oppstart scene-sjekk\",\n    [\"no saved scene matched current lights\"] = \"ingen lagret scene matcher gjeldende lys\",\n\n\n    },\n    de = {\n    [\"Room Name: \"] = \"Raumname: \",\n    [\"Room ID: \"] = \"Raum ID: \",\n    [\"Color Value is: \"] = \"Farbwert ist: \",\n    [\"Red\"] = \"Rot\",\n    [\"Green\"] = \"Grün\",\n    [\"Blue\"] = \"Blau\",\n    [\"white\"] = \"Weiß\",\n    [\"Fire\"] = \"Feuer\",\n    [\"Storm\"] = \"Sturm\",\n    [\"RGB\"] = \"RGB\",\n    [\"Aurora\"] = \"Aurora\",\n    [\"Police\"] = \"Polizei\",\n    [\"No Program\"] = \"Kein Programm\",\n    [\"Color Program is:\"] = \"Farbprogramm ist:\",\n    [\"Light Name: \"] = \"Lichtname: \",\n    [\"Light Value: \"] = \"Lichtwert: \",\n    [\"Light id:\"] = \"Licht ID: \",\n    [\"Light\"] = \"Aktives Licht: \",\n    [\"Pir Status is:\"] = \"Pir Status ist:\",\n    [\"Safe\"] = \"Sicher\",\n    [\"Detected\"] = \"Erkannt\",\n    [\"Active Profile is:\"] = \"Aktives Profil ist:\",\n    [\"Change Delay\"] = \"Ändern der Verzögerung am Bewegungssensor: \\n(nicht s2 Eingangsverzögerung)\",\n    [\"Sensor timer is:\"] = \"Sensorzeit ist:\",\n    [\"Max time\"] = \"Max Zeit 20min(+Blindzeit des Sensors)\",\n    [\"Set fade\"] = \"Setzen von Ausblenderate und -schritte: \",\n    [\"Slow Off is:\"] = \"Langsam Ausschalten ist:\",\n    [\"Steps for Off: \"] = \"Schritte fürs Ausschalten: \",\n    [\"Slow ON is: \"] = \"Langsam Anschalten ist: \",\n    [\"Steps for ON: \"] = \"Schritte fürs Anschalten: \",\n    [\"Change: ON Steps\"] = \"Ändern: Schritte fürs Anschalten\",\n    [\"Change: ON Time\"] = \"Ändern: Anschaltzeit\",\n    [\"Change: Off Steps\"] = \"Ändern: Schritte fürs Ausschalten\",\n    [\"Change: Off Time\"] = \"Ändern: Ausschaltzeit\",\n    [\"Min\"] = \"Min\",\n    [\"Sec\"] = \"Sek\",\n    [\"Hold Down to save: \"] = \"Halten zum Speichern: \",\n    [\"Turn ON\"] = \"Anschalten\",\n    [\"Turn OFF\"] = \"Ausschalten\",\n    [\"Turn ON slow\"] = \"Langsam Anschalten\",\n    [\"Turn OFF slow\"] = \"Langsam Ausschalten\",\n    [\"No Action\"] = \"Keine Aktion\",\n    [\"Setup for Profile:\"] = \"Setup für Profil:\",\n    [\"Pir ON\"] = \"Pir An\",\n    [\"Pir ON Event\"] = \"Auswählen was passieren soll bei <font color=green>Pir An Event\",\n    [\"Pir OFF Event\"] = \"Auswählen was passieren soll bei <font color=red>Pir Aus Event\",\n    [\"Pir OFF Event Delay\"] = \"Auswählen was passieren soll bei <font color=red>Pir Aus Event mit Verzögerung\",\n    [\"Change Delay Timer:\"] = \"Ändern der Verzögerung auf:\\n<font color=red>Pir Aus Event mit Verzögerung\\n<font color=orange>Ausschaltverzögerung ist:\",\n    [\"Pir Trigger ON\"] = \"Pir Trigger An ist gesetzt auf: \",\n    [\"Pir Trigger Delay ON\"] = \"Pir Trigger Anschaltverzögerung ist gesetzt auf:\", \n    [\"Pir Trigger Delay\"] = \"Pir Trigger Zeitverzögerung ist gesetzt auf:\",\n    [\"Pir OFF\"] = \"Pir Aus\",\n    [\"Pir Trigger OFF\"] = \"Pir Trigger Aus ist gesetzt auf: \",\n    [\"Pir Trigger Delay OFF\"] = \"Pir Trigger Ausschaltverzögerung ist gesetzt auf:\", \n    [\"Profile Change\"] = \"Profilwechsel\",\n    [\"Profile Change is\"] = \"Profilwechsel ist gesetzt auf: \",\n    [\"Profile Change Delay\"] = \"Profilwechselverzögerung ist gesetzt auf: \",\n    [\"Profile Change Time\"] = \"Profilwechsel Zeitverzögerung ist gesetzt auf:\",\n    [\"Follow Pir Status\"] = \"Pir Status folgen\",\n    [\"Not follow Pir status\"] =   \"Pir status nicht folgen\",\n    [\"Motion Sensor Name: \"] = \"Bewegungssensorname: \",\n    [\"Motion Sensor id: \"] = \"Bewegungssensor ID: \",\n    [\"Motion Sensors\"] = \"Aktiver Bewegungssensor: \",\n    [\"Profil this device\"] = \"Profil nur für dieses Gerät ändern:\",\n    [\"setup: Bedroom\"] = \"Einrichtung: Schlafzimmer\", \n    [\"setup: Hallway\"] = \"Einrichtung: Flur\", \n    [\"setup: Living Room\"] = \"Einrichtung: Wohnzimmer\", \n    [\"Setup\"] = \"Einrichtung grundlegender Bewegungsprofile\", \n    [\"update\"] = \"IDs updaten\", \n\n\n    [\"enable\"] = \"aktivieren\",   \n    [\"disable\"] = \"deaktivieren\",   \n    [\"info_pir_enable\"] = \"Halten Sie die Tasten gedrückt, um die Bewegungssensorereignisse zu aktivieren oder zu deaktivieren. Status:\",   \n    [\"info_pir_enable_on\"] = \"Pir-Ereignisse aktiviert\",  \n    [\"info_pir_enable_off\"] = \"Pir-Ereignisse deaktivieren\",  \n\n\n\n\n\n    },\n    pl = {\n    [\"Room Name: \"] = \"Nazwa pokoju: \",\n    [\"Room ID: \"] = \"ID pokoju: \",\n    [\"Color Value is: \"] = \"Wartość koloru to: \",\n    [\"Red\"] = \"Czerwony\",\n    [\"Green\"] = \"Zielony\",\n    [\"Blue\"] = \"Niebieski\",\n    [\"white\"] = \"biały\",\n    [\"Fire\"] = \"Ogień\",\n    [\"Storm\"] = \"Burza\",\n    [\"RGB\"] = \"RGB\",\n    [\"Aurora\"] = \"Aurora\",\n    [\"Police\"] = \"Policja\",\n    [\"No Program\"] = \"Brak programu\",\n    [\"Color Program is:\"] = \"Program koloru to:\",\n    [\"Light Name: \"] = \"Nazwa światła: \",\n    [\"Light Value: \"] = \"Wartość światła: \",\n    [\"Light id:\"] = \"ID światła: \",\n    [\"Light\"] = \"Światła aktywne: \",\n    [\"Pir Status is:\"] = \"Status PIR: \",\n    [\"Safe\"] = \"Bezpiecznie\",\n    [\"Detected\"] = \"Wykryto\",\n    [\"Active Profile is:\"] = \"Aktywny profil: \",\n    [\"Change Delay\"] = \"Opóźnienie zmiany na czujniku ruchu: \\n(nie dotyczy opóźnienia wejść S2)\",\n    [\"Sensor timer is:\"] = \"Czasomierz czujnika to: \",\n    [\"Max time\"] = \"Maksymalny czas 20min (+ martwa strefa czujnika)\",\n    [\"Set fade\"] = \"Ustaw prędkość zanikania i kroki: \",\n    [\"Slow Off is:\"] = \"Wolne wyłączanie: \",\n    [\"Steps for Off: \"] = \"Kroki wyłączania: \",\n    [\"Slow ON is: \"] = \"Wolne włączanie: \",\n    [\"Steps for ON: \"] = \"Kroki włączania: \",\n    [\"Change: ON Steps\"] = \"Zmień: kroki włączania\",\n    [\"Change: ON Time\"] = \"Zmień: czas włączania\",\n    [\"Change: Off Steps\"] = \"Zmień: kroki wyłączania\",\n    [\"Change: Off Time\"] = \"Zmień: czas wyłączania\",\n    [\"Min\"] = \"Min\",\n    [\"Sec\"] = \"Sek\",\n    [\"Hold Down to save: \"] = \"Przytrzymaj, aby zapisać: \",\n    [\"Turn ON\"] = \"Włącz\",\n    [\"Turn OFF\"] = \"Wyłącz\",\n    [\"Turn ON slow\"] = \"Włącz powoli\",\n    [\"Turn OFF slow\"] = \"Wyłącz powoli\",\n    [\"No Action\"] = \"Brak akcji\",\n    [\"Setup for Profile:\"] = \"Ustawienia dla profilu: \",\n    [\"Pir ON\"] = \"Pir włączony\",\n    [\"Pir ON Event\"] = \"Wybierz, co ma się wydarzyć po <font color=green>Włączeniu PIR\",\n    [\"Pir OFF Event\"] = \"Wybierz, co ma się wydarzyć po <font color=red>Wyłączeniu PIR\",\n    [\"Pir OFF Event Delay\"] = \"Wybierz, co ma się wydarzyć po <font color=red>Wyłączeniu PIR z opóźnieniem\",\n    [\"Change Delay Timer:\"] = \"Zmień opóźnienie na:\\n<font color=red>Opóźnienie zdarzenia Pir OFF\\n<font color=orange>Opóźnienie wyłączenia Timer jest:\",\n    [\"Pir Trigger ON\"] = \"Ustawienie wyzwolenia PIR ON: \",\n    [\"Pir Trigger Delay ON\"] = \"Opóźnienie wyzwolenia PIR ON: \",\n    [\"Pir Trigger Delay\"] = \"Opóźnienie wyzwolenia PIR: \",\n    [\"Pir OFF\"] = \"Pir wyłączony\",\n    [\"Pir Trigger OFF\"] = \"Ustawienie wyzwolenia PIR OFF: \",\n    [\"Pir Trigger Delay OFF\"] = \"Opóźnienie wyzwolenia PIR OFF: \",\n    [\"Profile Change\"] = \"Zmiana profilu\",\n    [\"Profile Change is\"] = \"Zmiana profilu ustawiona na: \",\n    [\"Profile Change Delay\"] = \"Opóźnienie zmiany profilu ustawione na: \",\n    [\"Profile Change Time\"] = \"Czas opóźnienia zmiany profilu: \",\n    [\"Follow Pir Status\"] = \"Śledź status PIR\",\n    [\"Not follow Pir status\"] = \"Nie śledź statusu PIR\",\n    [\"Motion Sensor Name: \"] = \"Nazwa czujnika ruchu: \",\n    [\"Motion Sensor id: \"] = \"ID czujnika ruchu: \",\n    [\"Motion Sensors\"] = \"Aktywne czujniki ruchu: \",\n    [\"Profil this device\"] = \"Zmień profil tylko na tym urządzeniu: \",\n    [\"setup: Bedroom\"] = \"Ustawienia: Sypialnia\",\n    [\"setup: Hallway\"] = \"Ustawienia: Korytarz\",\n    [\"setup: Living Room\"] = \"Ustawienia: Salon\",\n    [\"Setup\"] = \"Podstawowe ustawienia profili ruchu\",\n    [\"update\"] = \"Aktualizuj ID\",\n\n\n\n    [\"enable\"] = \"Włączać\",   \n    [\"disable\"] = \"Wyłączyć\",   \n    [\"info_pir_enable\"] = \"Przytrzymaj przyciski, aby włączyć lub wyłączyć zdarzenia czujnika ruchu, Stan:\",   \n    [\"info_pir_enable_on\"] = \"Zdarzenia Pir włączone\",  \n    [\"info_pir_enable_off\"] = \"Zdarzenia Pir wyłączone\",  \n\n\n    },\n    fr = {\n      [\"Room Name: \"] = \"Nom de la pièce : \",\n      [\"Room ID: \"] = \"ID de la pièce : \",\n      [\"Color Value is: \"] = \"La valeur de la couleur est : \",\n      [\"Red\"] = \"Rouge\",\n      [\"Green\"] = \"Vert\",\n      [\"Blue\"] = \"Bleu\",\n      [\"white\"] = \"Blanc\",\n      [\"Fire\"] = \"Feu\",\n      [\"Strom\"] = \"Tempête\",\n      [\"RGB\"] = \"RVB\",\n      [\"Aurora\"] = \"Aurore\",\n      [\"Police\"] = \"Police\",\n      [\"No Program\"] = \"Aucun programme\",\n      [\"Color Program is:\"] = \"Le programme de couleur est :\",\n      [\"Light Name: \"] = \"Nom de la lumière : \",\n      [\"Light Value: \"] = \"Valeur de la lumière : \",\n      [\"Light id:\"] = \"ID de la lumière : \",\n      [\"Light\"] = \"Lumières actives : \",\n      [\"Pir Status is:\"] = \"Le statut PIR est :\",\n      [\"Safe\"] = \"Aucun mouvement détecté\",\n      [\"Detected\"] = \"Mouvement détecté\",\n      [\"Active Profile is:\"] = \"Le profil actif est :\",\n      [\"Change Delay\"] = \"Changer le délai du détecteur de mouvement :\\n(pas le délai des entrées S2)\",\n      [\"Sensor timer is:\"] = \"Le minuteur du capteur est :\",\n      [\"Max time\"] = \"Temps max 20min (+ délai mort du capteur)\",\n      [\"Set fade\"] = \"Définir le taux et les étapes d'atténuation : \",\n      [\"Slow Off is:\"] = \"Extinction lente activée :\",\n      [\"Steps for Off: \"] = \"Étapes pour éteindre : \",\n      [\"Slow ON is: \"] = \"Allumage lent activé : \",\n      [\"Steps for ON: \"] = \"Étapes pour allumer : \",\n      [\"Change: ON Steps\"] = \"Changer : Étapes d'allumage\",\n      [\"Change: ON Time\"] = \"Changer : Temps d'allumage\",\n      [\"Change: Off Steps\"] = \"Changer : Étapes d'extinction\",\n      [\"Change: Off Time\"] = \"Changer : Temps d'extinction\",\n      [\"Min\"] = \"Min\",\n      [\"Sec\"] = \"Sec\",\n      [\"Hold Down to save: \"] = \"Maintenez pour sauvegarder : \",\n      [\"Turn ON\"] = \"Allumer\",\n      [\"Turn OFF\"] = \"Éteindre\",\n      [\"Turn ON slow\"] = \"Allumer lentement\",\n      [\"Turn OFF slow\"] = \"Éteindre lentement\",\n      [\"No Action\"] = \"Aucune action\",\n      [\"Setup for Profile:\"] = \"Configuration pour le profil :\",\n      [\"Pir ON\"] = \"PIR activé\",\n      [\"Pir ON Event\"] = \"Choisissez ce qui doit se passer lors de l'<font color=green>activation du PIR\",\n      [\"Pir OFF Event\"] = \"Choisissez ce qui doit se passer lors de la <font color=red>désactivation du PIR\",\n      [\"Pir OFF Event Delay\"] = \"Choisissez ce qui doit se passer <font color=red>Délai d'événement Pir OFF\",\n      [\"Change Delay Timer:\"] = \"Modifier le délai d'activation:\\n<font color=red>Délai d'événement Pir OFF\\n<font color=orange>La minuterie d'arrêt différé est:\",\n      [\"Pir Trigger ON\"] = \"Déclenchement PIR activé défini sur : \",\n      [\"Pir Trigger Delay ON\"] = \"Délai de déclenchement PIR activé défini sur :\",\n      [\"Pir Trigger Delay\"] = \"Temps de délai de déclenchement PIR défini sur :\",\n      [\"Pir OFF\"] = \"PIR désactivé\",\n      [\"Pir Trigger OFF\"] = \"Déclenchement PIR désactivé défini sur : \",\n      [\"Pir Trigger Delay OFF\"] = \"Délai de déclenchement PIR désactivé défini sur :\",\n      [\"Profile Change\"] = \"Changement de profil\",\n      [\"Profile Change is\"] = \"Changement de profil défini sur : \",\n      [\"Profile Change Delay\"] = \"Délai de changement de profil défini sur : \",\n      [\"Profile Change Time\"] = \"Temps de délai de changement de profil défini sur :\",\n      [\"Follow Pir Status\"] = \"Suivre le statut PIR\",\n      [\"Not follow Pir status\"] = \"Ne pas suivre le statut PIR\",\n      [\"Motion Sensor Name: \"] = \"Nom du capteur de mouvement : \",\n      [\"Motion Sensor id: \"] = \"ID du capteur de mouvement : \",\n      [\"Motion Sensors\"] = \"Capteurs de mouvement actifs : \",\n      [\"Profil this device\"] = \"Changer le profil uniquement sur cet appareil :\",\n      [\"setup: Bedroom\"] = \"Configuration : Chambre\",\n      [\"setup: Hallway\"] = \"Configuration : Couloir\",\n      [\"setup: Living Room\"] = \"Configuration : Salon\",\n      [\"Setup\"] = \"Configurer les profils de mouvement de base\",\n      [\"update\"] = \"Mettre à jour les IDs\",\n\n\n      [\"enable\"] = \"Activer\",   \n      [\"disable\"] = \"Désactiver\",   \n      [\"info_pir_enable\"] = \"Maintenez les boutons enfoncés pour activer ou désactiver les événements du capteur de mouvement, État :\",   \n      [\"info_pir_enable_on\"] = \"Événements Pir activés\",  \n      [\"info_pir_enable_off\"] = \"Événements Pir désactivés\",  \n  \n\n\n    },}----translate \n  translation = translation[language]\n  return translation\nend\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n"},{"name":"Eventlib","isMain":false,"isOpen":false,"content":"------- examples/EventLib.lua ----------\r\n--[[\r\nEventLib - Advanced Event Handling Library for Fibaro HC3\r\nCopyright (c) 2024 Jan Gabrielsson\r\nEmail: jan@gabrielsson.com\r\n\r\nFeatures:\r\n  - Pattern matching with variable extraction ($var) and constraints ($var>10)\r\n  - Multiple event types: device, timer, cron, global variables, custom events, etc.\r\n  - Time specifications: relative (+/HH:MM), absolute (HH:MM), sunrise/sunset\r\n  - State tracking with trueFor() for debouncing and time-based conditions\r\n  - Event transformation and filtering\r\n  - Resource helpers (DEV, GLOB) for cleaner code\r\n  - Two API styles: Event_basic (functional) and Event_std (object-oriented)\r\n  - Automatic cleanup and resource management\r\n\r\nUsage:\r\n  Event = Event_std\r\n\r\n  Event.id = \"MyHandler\"\r\n  Event{type='device', id=123, property='value'}\r\n  function Event:handler(event)\r\n    self:debug(\"Device changed to: \" .. event.value)\r\n  end\r\n\r\n                    GNU GENERAL PUBLIC LICENSE\r\n                       Version 3, 29 June 2007\r\n\r\n Copyright (C) 2007 Free Software Foundation, Inc. <https://fsf.org/>\r\n Everyone is permitted to copy and distribute verbatim copies\r\n of this license document, but changing it is not allowed.\r\n--]]\r\nlocal _version = \"0.52\"\r\nlocal _author = \"jan@gabrielsson.com\"\r\nlocal _trigger = {}\r\nlocal _builtin = {}\r\nlocal _handler = {}\r\nlocal _eMap = {}\r\nlocal post,handleEvent,trueFor,again,toTime,transformEvent\r\nlocal _inited = false\r\nlocal Event\r\n\r\nfibaro.debugFlags = fibaro.debugFlags or {}\r\n\r\nlocal fmt = string.format\r\nlocal function map(f, t) local r = {}; for _,v in ipairs(t) do r[#r+1]= f(v) end  return r end\r\nlocal function equal(e1,e2)\r\n  if e1==e2 then return true\r\n  else\r\n    if type(e1) ~= 'table' or type(e2) ~= 'table' then return false\r\n    else\r\n      for k1,v1 in pairs(e1) do if e2[k1] == nil or not equal(v1,e2[k1]) then return false end end\r\n      for k2,_  in pairs(e2) do if e1[k2] == nil then return false end end\r\n      return true\r\n    end\r\n  end\r\nend\r\nlocal function copy(t) if type(t) ~= 'table' then return t end local r = {} for k,v in pairs(t) do r[k] = copy(v) end return r end\r\nlocal function append(a,...) \r\n  local r = copy(a); \r\n  for _,b in ipairs({...}) do \r\n    for _,v in ipairs(b) do r[#r+1]=v end \r\n  end\r\nreturn r end\r\n\r\nlocal function color(col,str) return fmt('<font color=\"%s\">%s</font>',col,str) end\r\nlocal function timeStr(time) \r\n  if type(time) == 'string' then time = toTime(time) end\r\n  -- Consider times under 35 days as relative times that need current time added\r\n  local MAX_RELATIVE_TIME = 35*24*3600  -- 35 days in seconds\r\n  if time < MAX_RELATIVE_TIME then time=time+os.time() end\r\n  return os.date(\"%H:%M:%S\",time),time\r\nend\r\n\r\nlocal function DEBUG(tag,...) \r\n  if fibaro.debugFlags[tag] then fibaro.trace(__TAG,color('skyblue',fmt(...))) end \r\nend\r\n\r\ntable.map = map\r\ntable.copy = copy\r\ntable.equal = equal\r\ntable.append = append\r\nfibaro.color = color\r\n\r\n---------------- Lua Table to String ---------------\r\nlocal function encTsort(a,b) return a[1] < b[1] end\r\nlocal sortKeys = {\"type\",\"device\",\"deviceID\",\"id\",\"value\",\"oldValue\",\"val\",\"key\",\"arg\",\"event\",\"events\",\"msg\",\"res\"}\r\nlocal sortOrder,sortF={},nil\r\nfor i,s in ipairs(sortKeys) do sortOrder[s]=\"\\n\"..string.char(i+64)..\" \"..s end\r\nlocal function encEsort(a,b)\r\n  a,b=a[1],b[1]; a,b = sortOrder[a] or a, sortOrder[b] or b\r\n  return a < b\r\nend\r\nfunction table.maxn(t) local c=0 for _ in pairs(t) do c=c+1 end return c end\r\nlocal encT={}\r\nencT['nil'] = function(n,out) out[#out+1]='nil' end\r\nfunction encT.number(n,out) out[#out+1]=tostring(n) end\r\nfunction encT.userdata(u,out) out[#out+1]=tostring(u) end\r\nfunction encT.thread(t,out) out[#out+1]=tostring(t) end\r\nencT['function'] = function(f,out) out[#out+1]=tostring(f) end\r\nfunction encT.string(str,out) out[#out+1]='\"' out[#out+1]=str out[#out+1]='\"' end\r\nfunction encT.boolean(b,out) out[#out+1]=b and \"true\" or \"false\" end\r\nfunction encT.table(t,out)\r\n  local mt = getmetatable(t) if t and t.__tostring then return tostring(t) end\r\n  if next(t)==nil then return \"{}\" -- Empty table\r\n  elseif t[1]==nil then -- key value table\r\n    local r = {}; for k,v in pairs(t) do r[#r+1]={k,v} end table.sort(r,sortF)\r\n    out[#out+1]='{'\r\n    local e = r[1]\r\n    out[#out+1]=e[1]; out[#out+1]='='; encT[type(e[2])](e[2],out)\r\n    for i=2,table.maxn(r) do local e = r[i]; out[#out+1]=','; out[#out+1]=e[1]; out[#out+1]='='; encT[type(e[2])](e[2],out) end\r\n    out[#out+1]='}'\r\n  else -- array table\r\n    out[#out+1]='['\r\n    encT[type(t[1])](t[1],out)\r\n    for i=2,table.maxn(t) do out[#out+1]=',' encT[type(t[ i])](t[i],out) end\r\n    out[#out+1]=']'\r\n  end\r\nend\r\n\r\nlocal function encode(o,sort)\r\n  local out = {}\r\n  sortF = (not sort) and encEsort or encTsort\r\n  encT[type(o)](o,out)\r\n  return table.concat(out)\r\nend\r\n\r\n---------------- SunCalc -----------------\r\nlocal function sunturnTime(date, rising, latitude, longitude, zenith, local_offset)\r\n  local rad,deg,floor = math.rad,math.deg,math.floor\r\n  local frac = function(n) return n - floor(n) end\r\n  local cos = function(d) return math.cos(rad(d)) end\r\n  local acos = function(d) return deg(math.acos(d)) end\r\n  local sin = function(d) return math.sin(rad(d)) end\r\n  local asin = function(d) return deg(math.asin(d)) end\r\n  local tan = function(d) return math.tan(rad(d)) end\r\n  local atan = function(d) return deg(math.atan(d)) end\r\n\r\n  local function day_of_year(date2)\r\n    local n1 = floor(275 * date2.month / 9)\r\n    local n2 = floor((date2.month + 9) / 12)\r\n    local n3 = (1 + floor((date2.year - 4 * floor(date2.year / 4) + 2) / 3))\r\n    return n1 - (n2 * n3) + date2.day - 30\r\n  end\r\n\r\n  local function fit_into_range(val, min, max)\r\n    local range,count = max - min,nil\r\n    if val < min then count = floor((min - val) / range) + 1; return val + count * range\r\n    elseif val >= max then count = floor((val - max) / range) + 1; return val - count * range\r\n    else return val end\r\n  end\r\n\r\n  -- Convert the longitude to hour value and calculate an approximate time\r\n  local n,lng_hour,t =  day_of_year(date), longitude / 15,nil\r\n  if rising then t = n + ((6 - lng_hour) / 24) -- Rising time is desired\r\n  else t = n + ((18 - lng_hour) / 24) end -- Setting time is desired\r\n  local M = (0.9856 * t) - 3.289 -- Calculate the Sun^s mean anomaly\r\n  -- Calculate the Sun^s true longitude\r\n  local L = fit_into_range(M + (1.916 * sin(M)) + (0.020 * sin(2 * M)) + 282.634, 0, 360)\r\n  -- Calculate the Sun^s right ascension\r\n  local RA = fit_into_range(atan(0.91764 * tan(L)), 0, 360)\r\n  -- Right ascension value needs to be in the same quadrant as L\r\n  local Lquadrant = floor(L / 90) * 90\r\n  local RAquadrant = floor(RA / 90) * 90\r\n  RA = RA + Lquadrant - RAquadrant; RA = RA / 15 -- Right ascension value needs to be converted into hours\r\n  local sinDec = 0.39782 * sin(L) -- Calculate the Sun's declination\r\n  local cosDec = cos(asin(sinDec))\r\n  local cosH = (cos(zenith) - (sinDec * sin(latitude))) / (cosDec * cos(latitude)) -- Calculate the Sun^s local hour angle\r\n  if rising and cosH > 1 then return -1 --\"N/R\" -- The sun never rises on this location on the specified date\r\n  elseif cosH < -1 then return -1 end --\"N/S\" end -- The sun never sets on this location on the specified date\r\n\r\n  local H -- Finish calculating H and convert into hours\r\n  if rising then H = 360 - acos(cosH)\r\n  else H = acos(cosH) end\r\n  H = H / 15\r\n  local T = H + RA - (0.06571 * t) - 6.622 -- Calculate local mean time of rising/setting\r\n  local UT = fit_into_range(T - lng_hour, 0, 24) -- Adjust back to UTC\r\n  local LT = UT + local_offset -- Convert UT value to local time zone of latitude/longitude\r\n---@diagnostic disable-next-line: missing-fields\r\n  return os.time({day = date.day,month = date.month,year = date.year,hour = floor(LT),min = math.modf(frac(LT) * 60)})\r\nend\r\n\r\n---@diagnostic disable-next-line: param-type-mismatch\r\nlocal function getTimezone() local now = os.time() return os.difftime(now, os.time(os.date(\"!*t\", now))) end\r\n\r\nlocal function sunCalc(time)\r\n  local hc3Location = api.get(\"/settings/location\")\r\n  local lat = hc3Location.latitude or 0\r\n  local lon = hc3Location.longitude or 0\r\n  local utc = getTimezone() / 3600\r\n  local zenith,zenith_twilight = 90.83, 96.0 -- sunset/sunrise 90°50′, civil twilight 96°0′\r\n\r\n  local date = os.date(\"*t\",time or os.time())\r\n  if date.isdst then utc = utc + 1 end\r\n  local rise_time = os.date(\"*t\", sunturnTime(date, true, lat, lon, zenith, utc))\r\n  local set_time = os.date(\"*t\", sunturnTime(date, false, lat, lon, zenith, utc))\r\n  local rise_time_t = os.date(\"*t\", sunturnTime(date, true, lat, lon, zenith_twilight, utc))\r\n  local set_time_t = os.date(\"*t\", sunturnTime(date, false, lat, lon, zenith_twilight, utc))\r\n  local sunrise = fmt(\"%.2d:%.2d\", rise_time.hour, rise_time.min)\r\n  local sunset = fmt(\"%.2d:%.2d\", set_time.hour, set_time.min)\r\n  local sunrise_t = fmt(\"%.2d:%.2d\", rise_time_t.hour, rise_time_t.min)\r\n  local sunset_t = fmt(\"%.2d:%.2d\", set_time_t.hour, set_time_t.min)\r\n  return sunrise, sunset, sunrise_t, sunset_t\r\nend\r\n\r\n----------------- Cron ------------------\r\nlocal function dateTest(dateStr0)\r\n  local days = {sun=1,mon=2,tue=3,wed=4,thu=5,fri=6,sat=7}\r\n  local months = {jan=1,feb=2,mar=3,apr=4,may=5,jun=6,jul=7,aug=8,sep=9,oct=10,nov=11,dec=12}\r\n  local last,month = {31,28,31,30,31,30,31,31,30,31,30,31},nil\r\n\r\n  local function seq2map(seq) local s = {} for _,v in ipairs(seq) do s[v] = true end return s; end\r\n\r\n  local function flatten(seq,res) -- flattens a table of tables\r\n    res = res or {}\r\n    if type(seq) == 'table' then for _,v1 in ipairs(seq) do flatten(v1,res) end else res[#res+1] = seq end\r\n    return res\r\n  end\r\n\r\n  local function _assert(test,msg,...) if not test then error(fmt(msg,...),3) end end\r\n\r\n  local function expandDate(w1,md)\r\n    local function resolve(id)\r\n      local res\r\n      if id == 'last' then month = md res=last[md] \r\n      elseif id == 'lastw' then month = md res=last[md]-6 \r\n      else res= type(id) == 'number' and id or days[id] or months[id] or tonumber(id) end\r\n      _assert(res,\"Bad date specifier '%s'\",id) return res\r\n    end\r\n    local step = tonumber(1)\r\n    local w,m = w1[1],w1[2]\r\n    local start,stop = w:match(\"(%w+)%p(%w+)\")\r\n    if (start == nil) then return resolve(w) end\r\n    start,stop = resolve(start), resolve(stop)\r\n    local res,res2 = {},{}\r\n    if w:find(\"/\") then\r\n      if not w:find(\"-\") then -- 10/2\r\n        step=stop; stop = m.max\r\n      else step=tonumber((w:match(\"/(%d+)\"))) end\r\n    end\r\n    step = tonumber(step)\r\n    _assert(start>=m.min and start<=m.max and stop>=m.min and stop<=m.max,\"illegal date intervall\")\r\n    while (start ~= stop) do -- 10-2\r\n      res[#res+1] = start\r\n      start = start+1; if start>m.max then start=m.min end  \r\n    end\r\n    res[#res+1] = stop\r\n    if step > 1 then for i=1,#res,step do res2[#res2+1]=res[i] end; res=res2 end\r\n    return res\r\n  end\r\n\r\n  local function parseDateStr(dateStr) --,last)\r\n    local seq = string.split(dateStr,\" \")   -- min,hour,day,month,wday\r\n    assert(seq,\"Bad date string '%s'\",dateStr)\r\n    local lim = {{min=0,max=59},{min=0,max=23},{min=1,max=31},{min=1,max=12},{min=1,max=7},{min=2000,max=3000}}\r\n    for i=1,6 do if seq[i]=='*' or seq[i]==nil then seq[i]=tostring(lim[i].min)..\"-\"..lim[i].max end end\r\n    seq = map(function(w) return string.split(w,\",\") end, seq)   -- split sequences \"3,4\"\r\n    local month0 = os.date(\"*t\",os.time()).month\r\n    seq = map(function(t) local m = table.remove(lim,1);\r\n        return flatten(map(function (g) return expandDate({g,m},month0) end, t))\r\n      end, seq) -- expand intervalls \"3-5\"\r\n    return map(seq2map,seq)\r\n  end\r\n  local sun,offs,day,sunPatch = dateStr0:match(\"^(sun%a+) ([%+%-]?%d+)\")\r\n  if sun then\r\n    sun = sun..\"Hour\"\r\n    dateStr0=dateStr0:gsub(\"sun%a+ [%+%-]?%d+\",\"0 0\")\r\n    sunPatch=function(dateSeq)\r\n      local h,m = (fibaro.getValue(1,sun)):match(\"(%d%d):(%d%d)\")\r\n      dateSeq[1]={[(tonumber(h)*60+tonumber(m)+tonumber(offs))%60]=true}\r\n      dateSeq[2]={[math.floor((tonumber(h)*60+tonumber(m)+tonumber(offs))/60)]=true}\r\n    end\r\n  end\r\n  local dateSeq = parseDateStr(dateStr0)\r\n  return function(currDate) -- Pretty efficient way of testing dates...\r\n    local t = currDate or os.date(\"*t\",os.time())\r\n    if month and month~=t.month then dateSeq=parseDateStr(dateStr0) end -- Recalculate 'last' every month\r\n    if sunPatch and (month and month~=t.month or day~=t.day) then sunPatch(dateSeq) day=t.day end -- Recalculate sunset/sunrise\r\n    return\r\n    dateSeq[1][t.min] and    -- min     0-59\r\n    dateSeq[2][t.hour] and   -- hour    0-23\r\n    dateSeq[3][t.day] and    -- day     1-31\r\n    dateSeq[4][t.month] and  -- month   1-12\r\n    dateSeq[5][t.wday] or false      -- weekday 1-7, 1=sun, 7=sat\r\n  end\r\nend\r\n\r\nlocal cronItems = {}\r\nlocal cronRef,nxt = nil,0\r\nlocal function addCronItem(event) -- {type='cron',id=k, time='* * * * *'}\r\n  local dateTest = dateTest(event.time)\r\n  cronItems[dateTest] = event\r\n  local function loop()\r\n    local date = os.date(\"*t\",os.time())\r\n    for dateTest,event in pairs(cronItems) do\r\n      if dateTest(date) then post(event) end\r\n    end\r\n    nxt = nxt + 60\r\n    cronRef = setTimeout(loop,1000*(nxt-os.time()))\r\n  end\r\n  if cronRef == nil then\r\n    nxt = (os.time() // 60 + 1) *60\r\n    cronRef = setTimeout(loop,1000*(nxt-os.time())) \r\n  end\r\nend \r\n\r\n------------------ Time ---------------------------------\r\nlocal function midnight() local t = os.date(\"*t\"); t.hour,t.min,t.sec = 0,0,0; return os.time(t) end\r\n\r\n--- Convert time string to seconds\r\n-- Supports formats: \"HH:MM\", \"HH:MM:SS\", \"sunrise\", \"sunset\", \"sunrise+/-offset\"\r\n-- @param hmstr string Time string to parse\r\n-- @param ns boolean If true, calculate next sunrise/sunset\r\n-- @return number Time in seconds\r\nlocal function hm2sec(hmstr,ns)\r\n  if type(hmstr) ~= 'string' then \r\n    error(fmt(\"hm2sec expects string, got %s\", type(hmstr)), 2) \r\n  end\r\n  local offs,sun\r\n  sun,offs = hmstr:match(\"^(%a+)([+-]?%d*)\")\r\n  if sun and (sun == 'sunset' or sun == 'sunrise') then\r\n    if ns then\r\n      local sunrise,sunset = sunCalc(os.time()+24*3600)\r\n      hmstr,offs = sun=='sunrise' and sunrise or sunset, tonumber(offs) or 0\r\n    else\r\n      hmstr,offs = fibaro.getValue(1,sun..\"Hour\"), tonumber(offs) or 0\r\n    end\r\n  end\r\n  local sg,h,m,s = hmstr:match(\"^(%-?)(%d+):(%d+):?(%d*)\")\r\n  if not (h and m) then \r\n    error(fmt(\"Invalid time format '%s'. Expected 'HH:MM', 'HH:MM:SS', 'sunrise', or 'sunset'\", hmstr), 2) \r\n  end\r\n  return (sg == '-' and -1 or 1)*(tonumber(h)*3600+tonumber(m)*60+(tonumber(s) or 0)+(tonumber(offs or 0))*60)\r\nend\r\n\r\n--- Convert time specification to absolute time in seconds\r\n-- Supports multiple formats:\r\n--   number: absolute time\r\n--   \"+/HH:MM\": relative time from now\r\n--   \"n/HH:MM\": next occurrence (today or tomorrow)\r\n--   \"t/HH:MM\": today at HH:MM\r\n--   \"h/SS\": seconds into next hour\r\n--   \"m/SS\": seconds into next minute\r\n--   \"HH:MM\": time as seconds from midnight\r\n-- @param time string|number Time specification\r\n-- @return number Absolute time in seconds since epoch\r\nfunction toTime(time)\r\n  if type(time) == 'number' then return time end\r\n  if type(time) ~= 'string' then\r\n    error(fmt(\"toTime expects string or number, got %s\", type(time)), 2)\r\n  end\r\n  if #time < 2 then\r\n    error(fmt(\"Invalid time string '%s'. Too short\", time), 2)\r\n  end\r\n  local p = time:sub(1,2)\r\n  if p == '+/' then return hm2sec(time:sub(3))+os.time()\r\n  elseif p == 'n/' then\r\n    local t1,t2 = midnight()+hm2sec(time:sub(3),true),os.time()\r\n    return t1 > t2 and t1 or t1+24*60*60\r\n  elseif p == 't/' then return  hm2sec(time:sub(3))+midnight()\r\n  elseif p == 'h/' then\r\n    local t1,t2 = hm2sec(time:sub(3))//60,os.date(\"*t\")\r\n    local t0 = t2.min*60+t2.sec\r\n    t2.min,t2.sec = 0,0\r\n    local th = os.time(t2)\r\n    return (t1 >= t0 and th+t1 or th+t1+3600)\r\n  elseif p == 'm/' then\r\n    local t1,t2 = tonumber(time:sub(3)),os.date(\"*t\")\r\n    return 60-t2.sec+t1+os.time()\r\n  else return hm2sec(time) end\r\nend\r\n\r\nfunction fibaro.between(start,stop,optTime)\r\n  __assert_type(start,\"string\" )\r\n  __assert_type(stop,\"string\" )\r\n  start,stop,optTime=toTime(start),toTime(stop),optTime and toTime(optTime) or toTime(os.date(\"%H:%M\"))\r\n  stop = stop>=start and stop or stop+24*3600\r\n  optTime = optTime>=start and optTime or optTime+24*3600\r\n  return start <= optTime and optTime <= stop\r\nend\r\n------------------\r\n\r\nlocal function isEvent(e) return type(e) == 'table' and type(e.type)=='string' end\r\nlocal eventMT = {\r\n  --__eq = function(e1,e2) return equal(e1,e2) end,\r\n  __tostring = function(e) return fmt(\"#%s{%s\",e.type,encode(e):match(\",(.*)\")) end\r\n}\r\nlocal function addEventMT(event) if not getmetatable(event) then setmetatable(event,eventMT) end return event end\r\n\r\nlocal managedEvent = {}\r\n--- Manage timer events with optional alignment\r\n-- @param k string Handler identifier\r\n-- @param event table Event with 'time' and optional 'aligned' fields\r\n-- @return table Modified event\r\nfunction managedEvent.timer(k,event)\r\n  assert(event and type(event) == 'table', \"Timer event must be a table\")\r\n  assert(event.time, \"Timer event must have 'time' property\")\r\n  event = addEventMT(copy(event))\r\n  event.id = k\r\n  local t = toTime(event.time)\r\n  if event.aligned and type(event.time) == 'string' and event.time:sub(1,2) == '+/' then\r\n    local t0 = toTime(event.time:sub(3))\r\n    t = ((t-t0) // t0 + 1)*t0\r\n  end\r\n  --if event.aligned then print(\"ALIGN\",os.date(\"%c\",t)) end\r\n  if fibaro.debugFlags.post then\r\n    local tstr,t = timeStr(t)\r\n    DEBUG('post',\"post %s at %s-%s\",event,os.date(\"%d/%m\",t),tstr) \r\n  end\r\n  post({type='schedule',event=event,_sh=true},t)\r\n  return event\r\nend\r\n--- Manage cron events\r\n-- @param k string Handler identifier\r\n-- @param event table Event with 'time' field containing cron expression\r\n-- @return table Modified event\r\nfunction managedEvent.cron(k,event)\r\n  assert(event and type(event) == 'table', \"Cron event must be a table\")\r\n  assert(event.time, \"Cron event must have 'time' property with cron expression\")\r\n  event = addEventMT(copy(event))\r\n  event.id = k\r\n  addCronItem(event)\r\n  return event\r\nend\r\n--- Register a custom managed event type\r\n-- Managed events handle their own scheduling (like timer and cron)\r\n-- @param typ string Event type name\r\n-- @param fun function Manager function(handlerId, event) -> modifiedEvent\r\nfunction _builtin:_managedEvent(typ,fun)\r\n  assert(type(typ)=='string',\"Type expected\")\r\n  assert(type(fun)=='function',\"Function expected\")\r\n  managedEvent[typ] = fun\r\nend\r\n\r\nlocal function coerce(x,y) local x1 = tonumber(x) if x1 then return x1,tonumber(y) else return x,y end end\r\nlocal constraints = {}\r\nconstraints['=='] = function(val) return function(x) x,val=coerce(x,val) return x == val end end\r\nconstraints['<>'] = function(val) return function(x) return tostring(x):match(val) end end\r\nconstraints['>='] = function(val) return function(x) x,val=coerce(x,val) return x >= val end end\r\nconstraints['<='] = function(val) return function(x) x,val=coerce(x,val) return x <= val end end\r\nconstraints['>'] = function(val) return function(x) x,val=coerce(x,val) return x > val end end\r\nconstraints['<'] = function(val) return function(x) x,val=coerce(x,val) return x < val end end\r\nconstraints['~='] = function(val) return function(x) x,val=coerce(x,val) return x ~= val end end\r\nconstraints[''] = function(_) return function(x) return x ~= nil end end\r\n\r\n--- Compile event pattern with variable extraction and constraints\r\n-- Variables: $var, $var==val, $var~=val, $var>val, $var<val, $var>=val, $var<=val, $var<>pattern\r\n-- @param pattern table Pattern to compile\r\n-- @return table Compiled pattern with constraint functions\r\nlocal function compilePattern(pattern)\r\n  if type(pattern) == 'table' then\r\n    if pattern._var_ then return end\r\n    for k,v in pairs(pattern) do\r\n      if type(v) == 'string' and v:sub(1,1) == '$' then\r\n        local var,op,val = v:match(\"^$([%w_]*)([<>=~]*)(.*)\") \r\n        if not var then\r\n          error(fmt(\"Invalid pattern variable syntax '%s'. Expected $var, $var==val, $var>val, etc.\", v), 2)\r\n        end\r\n        var = var ==\"\" and \"_\" or var\r\n        -- Validate operator\r\n        if not constraints[op] then\r\n          local validOps = \"==, ~=, >, <, >=, <=, <> (pattern match)\"\r\n          error(fmt(\"Unknown constraint operator '%s' in '%s'. Valid operators: %s\", op, v, validOps), 2)\r\n        end\r\n        local c = constraints[op](tonumber(val) or val)\r\n        pattern[k] = {_var_=var, _constr=c, _str=v}\r\n      else compilePattern(v) end\r\n    end\r\n  end\r\n  return pattern\r\nend\r\n\r\nlocal function unify(pattern,expr,matches)\r\n  if pattern == expr then return true\r\n  elseif type(pattern) == 'table' then\r\n    if pattern._var_ then\r\n      local var, constr = pattern._var_, pattern._constr\r\n      if var == '_' then return constr(expr)\r\n      elseif matches[var] then return constr(expr) and unify(matches[var],expr,matches) -- Hmm, equal?\r\n      else matches[var] = expr return constr(expr) end\r\n    end\r\n    if type(expr) ~= \"table\" then return false end\r\n    for k,v in pairs(pattern) do if not unify(v,expr[k],matches) then return false end end\r\n    return true\r\n  else return false end\r\nend\r\n\r\nlocal toHash,fromHash={},{}\r\ntoHash['device'] = function(e) return \"device\"..(e.id or \"\")..(e.property or \"\") end\r\ntoHash['global-variable'] = function(e) return 'global-variable'..(e.name or \"\") end\r\ntoHash['quickvar'] = function(e) return 'quickvar'..(e.id or \"\")..(e.name or \"\") end\r\ntoHash['profile'] = function(e) return 'profile'..(e.property or \"\") end\r\ntoHash['weather'] = function(e) return 'weather'..(e.property or \"\") end\r\ntoHash['custom-event'] = function(e) return 'custom-event'..(e.name or \"\") end\r\ntoHash['deviceEvent'] = function(e) return 'deviceEvent'..(e.id or \"\")..(e.value or \"\") end\r\ntoHash['sceneEvent'] = function(e) return 'sceneEvent'..(e.id or \"\")..(e.value or \"\") end\r\ntoHash['timer'] = function(e) return 'timer'..(e.id or \"\")..(e.time or \"\") end\r\ntoHash['cron'] = function(e) return 'cron'..(e.id or \"\")..(e.time or \"\") end\r\n\r\nfromHash['device'] = function(e)\r\n  if not e.property then return {\"device\"..e.id,\"device\"} \r\n  else return {\"device\"..e.id..e.property,\"device\"..e.id,\"device\"..e.property,\"device\"} end\r\nend\r\nfromHash['global-variable'] = function(e) return {'global-variable'..e.name,'global-variable'} end\r\nfromHash['quickvar'] = function(e) return {\"quickvar\"..e.id..e.name,\"quickvar\"..e.id,\"quickvar\"..e.name,\"quickvar\"} end\r\nfromHash['profile'] = function(e) return {'profile'..e.property,'profile'} end\r\nfromHash['weather'] = function(e) return {'weather'..e.property,'weather'} end\r\nfromHash['custom-event'] = function(e) return {'custom-event'..e.name,'custom-event'} end\r\nfromHash['deviceEvent'] = function(e) return {\"deviceEvent\"..e.id..e.value,\"deviceEvent\"..e.id,\"deviceEvent\"..e.value,\"deviceEvent\"} end\r\nfromHash['sceneEvent'] = function(e) return {\"sceneEvent\"..e.id..e.value,\"sceneEvent\"..e.id,\"sceneEvent\"..e.value,\"sceneEvent\"} end\r\nfromHash['timer'] = function(e) return {\"timer\"..e.id..e.time} end\r\nfromHash['cron'] = function(e) return {\"cron\"..e.id..e.time} end\r\n\r\n--- Register an event pattern for a handler\r\n-- Validates and adds an event to the event map, enabling pattern matching\r\n-- @param k string Handler identifier  \r\n-- @param event table Event pattern (must have 'type' field)\r\nlocal function addEvent(k,event)\r\n  assert(isEvent(event),\"Event expected: must be table with 'type' field\")\r\n  addEventMT(event)\r\n  if managedEvent[event.type] then event = managedEvent[event.type](k,event) or event end\r\n  local pattern = copy(event)\r\n  compilePattern(pattern)\r\n  local key = toHash[event.type] and toHash[event.type](event) or event.type\r\n  local em = _eMap[key] or {}; _eMap[key]=em\r\n  for _,eventGroup in ipairs(em) do\r\n    if equal(event,eventGroup.event) then table.insert(eventGroup.handlers, k) return end\r\n  end\r\n  em[#em+1] = {event=event, pattern=pattern, handlers={k}}\r\nend\r\n\r\nlocal BREAK = '%%BREAK%%'\r\nlocal function lookupEvent(e,handler)\r\n  local keys = fromHash[e.type] and fromHash[e.type](e) or {e.type}\r\n  for _,key in ipairs(keys) do\r\n    local em = _eMap[key]\r\n    if em then\r\n      for _,eventGroup in ipairs(em) do\r\n        local match = {}\r\n        if unify(eventGroup.pattern,e,match) then\r\n          for _,k in ipairs(eventGroup.handlers) do\r\n            if handler(k,match) == BREAK then return end\r\n          end\r\n        end\r\n      end\r\n    end\r\n  end\r\nend\r\n\r\n---------------------------------\r\nlocal function init()\r\n  fibaro.debug(__TAG,\"EventLib v\".._version,_author)\r\n  Event:post({type='QAstart', _sh=true})\r\n  _inited=true\r\nend\r\n\r\nlocal eventTransformers = {}\r\n--- Register a custom event transformer\r\n-- Transformers convert one event type into one or more other events\r\n-- @param typ string Event type to transform  \r\n-- @param fun function Transformer function(event) -> {event1, event2, ...} or false\r\nfunction _builtin:_transformEvent(typ,fun)\r\n  assert(type(typ)=='string',\"Type expected\")\r\n  assert(type(fun)=='function',\"Function expected\")\r\n  eventTransformers[typ] = eventTransformers[typ] or {}\r\n  table.insert(eventTransformers[typ],fun)\r\nend\r\n\r\n--- Transform a single event into a list of events\r\n-- Applies registered transformers recursively with depth limit to prevent infinite loops\r\n-- @param event table Event to transform\r\n-- @param depth number Current recursion depth (internal use)\r\n-- @return table List of transformed events\r\nfunction transformEvent(event, depth) \r\n  depth = depth or 0\r\n  -- Prevent infinite transformation loops\r\n  if depth > 10 then \r\n    fibaro.warning(__TAG, fmt(\"Event transformation depth limit reached for event type '%s'\", event.type or \"unknown\"))\r\n    return {event} \r\n  end\r\n  \r\n  local tr = eventTransformers[event.type or \"\"]\r\n  if not tr then return {event} end\r\n  for _,fun in ipairs(tr) do\r\n    local nevent = fun(event)\r\n    if nevent then \r\n      return append(table.unpack(map(function(e) return transformEvent(e, depth+1) end, nevent))) \r\n    end\r\n  end\r\n  return {event}\r\nend\r\n\r\n--- Wait for a condition to remain true for a specified duration\r\n-- Returns true only after the condition has been continuously true for the given time\r\n-- Useful for debouncing and avoiding false triggers\r\n-- @param self table Handler context\r\n-- @param time number|string Duration to wait (seconds or time specification)\r\n-- @param cond boolean Current condition state\r\n-- @return boolean True if condition has been true for the full duration\r\nfunction trueFor(self,time,cond)\r\n  if self._trueForRef==true then \r\n    self._trueForRef = nil\r\n    return true \r\n  end\r\n  if not cond then\r\n    if self._trueForRef then \r\n      fibaro.cancel(self._trueForRef)\r\n      self._trueForRef = nil\r\n      self._trueForEvent = nil\r\n      self._trueForMatch = nil\r\n      return false \r\n    end\r\n  else\r\n    if self._trueForRef then \r\n      self._trueForEvent = self._event\r\n      self._trueForMatch = self._match\r\n      return false\r\n    else\r\n      self._trueForTime  = toTime(time)\r\n      self._trueForEvent = self._event\r\n      self._trueForMatch = self._match\r\n      local function success()\r\n        self._trueForRef = true\r\n        _handler[self.id](self._trueForEvent,self._trueForMatch)\r\n      end\r\n      self._trueForRef = setTimeout(success,1000*time)\r\n      return false\r\n    end\r\n  end\r\nend\r\n\r\n--- Repeat the handler after elapsed time interval (used with trueFor)\r\n-- Allows a handler to retrigger itself multiple times at regular intervals\r\n-- @param self table Handler context\r\n-- @param n number Maximum number of repeats (default: unlimited)\r\n-- @return number Current repeat count\r\nfunction again(self,n)\r\n  n = n or math.maxinteger\r\n  self._trueForAgain = self._trueForAgain or 0\r\n  if self._trueForAgain >= n-1 then return self._trueForAgain+1 end\r\n  self._trueForAgain = self._trueForAgain + 1\r\n  local function success()\r\n    self._trueForRef = true\r\n    _handler[self.id](self._trueForEvent,self._trueForMatch)\r\n  end\r\n  self._trueForRef = setTimeout(success,1000*self._trueForTime)\r\n  return self._trueForAgain\r\nend\r\n\r\nlocal function debugfun(f,...)\r\n  local args = {...}\r\n  if #args==1 then f(__TAG,args[1])\r\n  else f(__TAG,fmt(...)) end\r\nend\r\n\r\nlocal handlerMT = {\r\n  BREAK = BREAK,\r\n  again = again, \r\n  trueFor = trueFor,\r\n  post = function(k,event,time)\r\n    local timers = k._timers\r\n    if not timers then timers = {}; k._timers=timers end\r\n    local ref\r\n    ref = post(event,time,nil,function(event) timers[ref]=nil end)\r\n    timers[ref] = true\r\n  end,\r\n  cancel = function(k,ref) \r\n    fibaro.cancel(ref) \r\n    local timers = k._timers\r\n    if timers then timers[ref] = nil end  \r\n  end,\r\n  cancelAll = function(k) \r\n    local timers = k._timers\r\n    if timers then for t,_ in pairs(timers) do k:cancel(t) end  return true end\r\n  end,\r\n  enable = function(k) return fibaro.enable(k.id) end,\r\n  disable = function(k) k:cancelAll(); return fibaro.disable(k.id) end,\r\n  timer = function(k,t,f,...)\r\n    local args = {...}\r\n    return k:post({type='function',fun=f, args=args},t) \r\n  end,\r\n  between = function(_,...) return fibaro.between(...) end,\r\n  debug = function(self,...) fibaro.debug(__TAG,self._tag,...) end,\r\n  trace = function(self,...) fibaro.trace(__TAG,self._tag,...) end,\r\n  warning = function(self,...) fibaro.warning(__TAG,self._tag,...) end,\r\n  error = function(self,...) fibaro.error(__TAG,self._tag,...) end,\r\n  debugf = function(self,fmt,...) debugfun(fibaro.debug,(self._tag or \"\")..fmt,...) end,\r\n  tracef = function(self,fmt,...) debugfun(fibaro.trace,(self._tag or \"\")..fmt,...) end,\r\n  warningf = function(self,fmt,...) debugfun(fibaro.warning,(self._tag or \"\")..fmt,...) end,\r\n  errorf = function(self,fmt,...) debugfun(fibaro.error,(self._tag or \"\")..fmt,...) end,\r\n}\r\n\r\nlocal function createHandler(k,f)\r\n  local ht = { id = k }\r\n  return setmetatable({},{\r\n    __newindex = function(t,k,v)\r\n      if k == '_tag' and v~=nil then v = \"[\"..color(ht._tagColor or 'green',v)..\"] \" end\r\n      ht[k] = v\r\n    end,\r\n    __index = function(t,k) return ht[k]==nil and handlerMT[k] or ht[k] end,\r\n    __call = function(t,e,match) return f(t,e,match) end\r\n  })\r\nend\r\n\r\nlocal anonEvent = 1;\r\nlocal anonEventName = \"event:\"\r\nEvent = setmetatable({},{\r\n    __index = function(t,k)\r\n      if k == '_' then k = anonEventName..anonEvent end\r\n      if _builtin[k] then return _builtin[k] end\r\n      if not _inited then init() end\r\n      return function(...)\r\n        local es = {...}\r\n        if not es[1] then es = {es} end\r\n        es = append(table.unpack(map(transformEvent,es)))\r\n        if _trigger[k] then _trigger[k]=append(_trigger[k],es) \r\n        else _trigger[k]=es end\r\n        map(function(e) addEvent(k,e) end, es)\r\n      end\r\n    end,\r\n    __newindex = function(t,k,f)\r\n      if k == '_' then k = anonEventName..anonEvent; anonEvent = anonEvent + 1 end\r\n      assert(not _builtin[k],\"Can't redefine builtin Event function:\"..k)\r\n      assert(_trigger[k],\"Event not defined for: \"..tostring(k))\r\n      assert(not _handler[k],\"Handler already defined for: \"..tostring(k))\r\n      _handler[k]=createHandler(k,f)\r\n    end,\r\n    __call = function(t,k,event,f)\r\n      if k == '_' then k = anonEventName..anonEvent; anonEvent = anonEvent + 1 end\r\n      t[k](event)\r\n      _handler[k]=createHandler(k,f)\r\n      -- return ??\r\n    end\r\n  })\r\n\r\n--- Process an incoming event and trigger matching handlers\r\n-- Looks up handlers that match the event pattern and executes them\r\n-- @param event table Event to handle (must have 'type' field)\r\n-- @return any Result from handlers, or nil\r\nfunction handleEvent(event)\r\n  addEventMT(event)\r\n  return lookupEvent(event,function(k,match) \r\n    local handler = _handler[k]\r\n    if handler._disabled then return end\r\n    handler.date = os.date(\"*t\")\r\n    handler._event = event\r\n    handler._match = match\r\n    return handler(event,match)\r\n  end)\r\nend\r\n\r\n--- Post an event for processing now or in the future\r\n-- @param event table Event to post (must have 'type' field)\r\n-- @param time number|string Optional delay in seconds or time specification (default: 0)\r\n-- @param silent boolean If true, suppress debug output\r\n-- @param guard function Optional guard function called before handling\r\n-- @return userdata Timer reference, or nil if time is in the past\r\nfunction post(event,time,silent,guard)\r\n  assert(isEvent(event),\"Event expected: must be table with 'type' field\")\r\n  addEventMT(event)\r\n  local now = os.time()\r\n  time = toTime(time or 0)\r\n  -- Consider times under 72 hours as relative delays\r\n  local MAX_FUTURE_TIME = 72*3600  -- 72 hours in seconds\r\n  time = time < MAX_FUTURE_TIME and now+time or time\r\n  time = time-now\r\n  if time < 0 then return nil end\r\n  if not (event._sh or silent) then DEBUG('post',\"post %s at %s\",event,timeStr(time)) end\r\n  local handler = handleEvent\r\n  if guard then handler = function(event) guard(event) return handleEvent(event) end end\r\n  return setTimeout(function() handler(event) end,1000*time)\r\nend\r\n\r\nfibaro.post = post\r\n\r\n--- Cancel a scheduled timer\r\n-- @param ref userdata Timer reference returned from post() or setTimeout()\r\nfunction fibaro.cancel(ref) clearTimeout(ref) end\r\n\r\nlocal function isEnabled(k) return not _handler[k]._disabled end\r\n\r\n--- Enable a disabled event handler\r\n-- @param k string Handler identifier\r\nfunction fibaro.enable(k) \r\n  if not _handler[k] then\r\n    fibaro.warning(__TAG, fmt(\"Handler '%s' not found\", tostring(k)))\r\n    return\r\n  end\r\n  _handler[k]._disabled = nil \r\nend\r\n\r\n--- Disable an event handler (prevents it from triggering)\r\n-- @param k string Handler identifier  \r\nfunction fibaro.disable(k) \r\n  if not _handler[k] then\r\n    fibaro.warning(__TAG, fmt(\"Handler '%s' not found\", tostring(k)))\r\n    return\r\n  end\r\n  _handler[k]._disabled = true \r\nend\r\n\r\n--- Remove an event handler and clean up all associated resources\r\n-- Cancels all timers, removes from event map, and cleans up handler state\r\n-- @param k string Handler identifier to remove\r\n-- @return boolean True if handler was found and removed\r\nfunction fibaro.remove(k)\r\n  if not _handler[k] then \r\n    fibaro.warning(__TAG, fmt(\"Handler '%s' not found\", tostring(k)))\r\n    return false \r\n  end\r\n  \r\n  -- Cancel all timers associated with this handler\r\n  if _handler[k]._timers then\r\n    for ref,_ in pairs(_handler[k]._timers) do\r\n      fibaro.cancel(ref)\r\n    end\r\n  end\r\n  \r\n  -- Remove handler\r\n  _handler[k] = nil\r\n  \r\n  -- Clean up event map entries\r\n  for _,em in pairs(_eMap) do\r\n    for i = #em, 1, -1 do\r\n      local eventGroup = em[i]\r\n      for j = #eventGroup.handlers, 1, -1 do\r\n        if eventGroup.handlers[j] == k then\r\n          table.remove(eventGroup.handlers, j)\r\n        end\r\n      end\r\n      -- Remove event group if no handlers left\r\n      if #eventGroup.handlers == 0 then\r\n        table.remove(em, i)\r\n      end\r\n    end\r\n  end\r\n  \r\n  -- Clean up trigger\r\n  _trigger[k] = nil\r\n  \r\n  return true\r\nend\r\n\r\nfunction _builtin:post(...) return post(...) end\r\nfunction _builtin:cancel(...) return clearTimeout(...) end\r\nfunction _builtin:cancelAll(k) return _handler[k]:cancelAll() end\r\nfunction _builtin:enable(k) _handler[k]._disabled = nil end\r\nfunction _builtin:disable(k) _handler[k]._disabled = true end\r\nfunction _builtin:remove(k) return fibaro.remove(k) end\r\n--- Attach EventLib to HC3's RefreshState event stream\r\n-- Automatically receives and processes all HC3 system events\r\n-- Requires Trigger lib to be included\r\nfunction _builtin:attachRefreshstate(...)\r\n  assert(fibaro._APP.trigger,\"Trigger lib not included. Cannot attach to RefreshState.\")\r\n  function fibaro._APP.trigger.post(event) \r\n    if event.type=='device' and event.property=='icon' then return end\r\n    Event:post(event)\r\n  end\r\n  fibaro._APP.trigger.start()\r\nend\r\n\r\nEvent:_transformEvent('device',\r\nfunction(event)\r\n  if type(event.id)=='table' then\r\n    local res = {}\r\n    for _,id in ipairs(event.id) do\r\n      local nevent = copy(event)\r\n      nevent.id = id\r\n      res[#res+1] = nevent\r\n    end\r\n    return res\r\n  else return false end\r\nend)\r\n\r\nEvent.scheduler{type='schedule'}\r\nfunction Event:scheduler(event)\r\n  if isEnabled(event.event.id) then\r\n    post(event.event,0,true) \r\n    local tstr,t = timeStr(event.event.time)\r\n    DEBUG('post',\"post %s at %s-%s\",event.event,os.date(\"%d/%m\",t),tstr) \r\n  end\r\n  post(event,event.event.time)\r\nend\r\nEvent.func{type='function'}\r\nfunction Event:func(event) \r\n  local stat,err = pcall(event.fun,table.unpack(event.args or {}))\r\n  if not stat then fibaro.error(err) end\r\nend\r\n\r\nlocal Event2\r\ndo\r\n  local ID,FID = nil,nil\r\n  local key = {}\r\n  local props,dprops = {},{tag='_tag',tagColor='_tagColor',debug='_debug'}\r\n  local builtin = {}\r\n  function key.id(t,k,v) FID=v; ID = v==\"_\" and (anonEventName..anonEvent) or v; props = {} end\r\n  function key.handler(t,k,v) \r\n    assert(FID,\"Event: no Event.id declared\")\r\n    Event[FID] = v\r\n    for k,v in pairs(props) do if k~='tag' then _handler[ID][dprops[k]] = v end end\r\n    _handler[ID]._tag = props.tag and tostring(props.tag) or props.tag==nil and ID or nil\r\n    if props.debug then\r\n      fibaro.trace(__TAG,color('yellow',ID..\" defined\"))\r\n    end\r\n    ID=nil  \r\n  end\r\n  Event2 = setmetatable({},{\r\n    __index = function(t,k)\r\n      return builtin[k]\r\n    end,\r\n    __newindex = function(t,k,v)\r\n      if key[k] then \r\n        if k=='id' then assert(ID==nil,\"Event: not closed previous Event declaration:\"..(ID or \"\"))\r\n        else assert(ID~=nil,\"Event: no Event.id declared\") end\r\n        key[k](t,k,v) \r\n        return \r\n      elseif dprops[k] then props[k]=v; return end\r\n      error(\"Invalid Event key: \"..k,2)\r\n    end,\r\n    __call = function(t,event)\r\n      Event[ID](event)\r\n      -- return ??\r\n    end\r\n  }\r\n)\r\nfunction builtin:post(event,time) return Event:post(event,time) end\r\nfunction builtin:cancel(ref) return Event:cancel(ref) end\r\nfunction builtin:cancelAll(k) return Event:cancelAll(k) end\r\nfunction builtin:enable(k) return Event:enable(k) end\r\nfunction builtin:disable(k) return Event:disable(k) end\r\nfunction builtin:remove(k) return Event:remove(k) end\r\nfunction builtin:attachRefreshstate() return Event:attachRefreshstate() end\r\nend\r\n\r\n-------------------------------------\r\nEvent_basic = Event\r\nEvent_std = Event2\r\n\r\n------- lib/Trigger.lua ----------\r\nlocal exports = {\r\n  GlobalSourceTriggerGV = \"gkjhkjdfhgjhdsfgjhsdfgjhfdkj\"\r\n}\r\n\r\nlocal function equal(e1,e2)\r\n  if e1==e2 then return true\r\n  else\r\n    if type(e1) ~= 'table' or type(e2) ~= 'table' then return false\r\n    else\r\n      for k1,v1 in pairs(e1) do if e2[k1] == nil or not equal(v1,e2[k1]) then return false end end\r\n      for k2,_  in pairs(e2) do if e1[k2] == nil then return false end end\r\n      return true\r\n    end\r\n  end\r\nend\r\n\r\nlocal function quickVarEvent(d,_,post)\r\n  local old={}; for _,v in ipairs(d.oldValue) do old[v.name] = v.value end\r\n  for _,v in ipairs(d.newValue) do\r\n    if not equal(v.value,old[v.name]) then\r\n      post({type='quickvar', id=d.id, name=v.name, value=v.value, old=old[v.name]})\r\n    end\r\n  end\r\nend\r\n\r\n-- There are more, but these are what I seen so far...\r\n--[[\r\n{type='alarm', property='armed', id = <partitionId>, value=<boolean>}\r\n{type='alarm', property='breached', id = <partitionId>, value=<boolean>}\r\n{type='alarm', property='homeArmed', value=<boolean>\r\n{type='alarm', property='homeBreached', value=<boolean>\r\n{type='weather',property=<string>, value=<number>, old=<number>}\r\n{type='global-variable', name=<string>, value=<string>, old=<string>}\r\n{type='quickvar', id=<number>, name=<string>, value=<value>, old=<value>}\r\n{type='device', id=<number>, property=<string>, value=<value>, old=<value>}\r\n{type='device', id=<number>, property='centralSceneEvent', value={keyId=<number>, keyAttribute=<number>}}\r\n{type='device', id=<number>, property='sceneActivationEvent', value={sceneId=<number>}}\r\n{type='device', id=<number>, property='accessControlEvent', value=<table>}\r\n{type='custom-event', name=<string>, value=<string>}\r\n{type='deviceEvent', id=<number>, value='removed'}\r\n{type='deviceEvent', id=<number>, value='changedRoom'}\r\n{type='deviceEvent', id=<number>, value='created'}\r\n{type='deviceEvent', id=<number>, value='modified'}\r\n{type='deviceEvent', id=<number>, value='crashed', error=<string>}\r\n{type='sceneEvent', id=<number>, value='started'}\r\n{type='sceneEvent', id=<number>, value='finished'}\r\n{type='sceneEvent', id=<number>, value='instance', instance=<value>}\r\n{type='sceneEvent', id=<number>, value='removed'}\r\n{type='sceneEvent', id=<number>, value='modified'}\r\n{type='sceneEvent', id=<number>, value='created'}\r\n{type='onlineEvent', value=<boolean>}\r\n{type='profile',property='activeProfile',value=<string>, old=<string>}\r\n{type='ClimateZone', id=<number>, type=<string>, value=<string>, old=<string>}\r\n{type='ClimateZoneSetpoint', id=<number>, type=<string>, value=<number>, old=<number>}\r\n{type='notification', id=<number>, value='created'}\r\n{type='notification', id=<number>, value='removed'}\r\n{type='notification', id=<number>, value='updated'}\r\n{type='room', id=<number>, value='created'}\r\n{type='room', id=<number>, value='removed'}\r\n{type='room', id=<number>, value='modified'}\r\n{type='section', id=<number>, value='created'}\r\n{type='section', id=<number>, value='removed'}\r\n{type='section', id=<number>, value='modified'}\r\n{type='location',id=<number>,property=<string>,value=<string>,timestamp=<number>}\r\n{type='user',id=<number>,value='action',data=<value>}\r\n{type='system',value='action',data=<value>}\r\n--]]\r\nlocal EventTypes = {\r\n  AlarmPartitionArmedEvent = function(d,_,post) post({type='alarm', property='armed', id = d.partitionId, value=d.armed}) end,\r\n  AlarmPartitionBreachedEvent = function(d,_,post) post({type='alarm', property='breached', id = d.partitionId, value=d.breached}) end,\r\n  AlarmPartitionModifiedEvent = function(d,_,post)  end,\r\n  HomeArmStateChangedEvent = function(d,_,post) post({type='alarm', property='homeArmed', value=d.newValue}) end,\r\n  HomeDisarmStateChangedEvent = function(d,_,post) post({type='alarm', property='homeArmed', value=not d.newValue}) end,\r\n  HomeBreachedEvent = function(d,_,post) post({type='alarm', property='homeBreached', value=d.breached}) end,\r\n  WeatherChangedEvent = function(d,_,post) post({type='weather',property=d.change, value=d.newValue, old=d.oldValue}) end,\r\n  GlobalVariableChangedEvent = function(d,_,post)\r\n    if d.variableName == exports.GlobalSourceTriggerGV then\r\n      local stat,va = pcall(json.decode,d.newValue)\r\n      if not stat then return end\r\n      va._transID = nil\r\n      post(va)\r\n    else\r\n      post({type='global-variable', name=d.variableName, value=d.newValue, old=d.oldValue})\r\n    end\r\n  end,\r\n  GlobalVariableAddedEvent = function(d,_,post) post({type='global-variable', name=d.variableName, value=d.value, old=nil}) end,\r\n  DevicePropertyUpdatedEvent = function(d,_,post)\r\n    if d.property=='quickAppVariables' then quickVarEvent(d,_,post)\r\n    else\r\n      post({type='device', id=d.id, property=d.property, value=d.newValue, old=d.oldValue})\r\n    end\r\n  end,\r\n  CentralSceneEvent = function(d,_,post)\r\n    d.id,d.icon = d.id or d.deviceId,nil\r\n    post({type='device', property='centralSceneEvent', id=d.id, value={keyId=d.keyId, keyAttribute=d.keyAttribute}})\r\n  end,\r\n  SceneActivationEvent = function(d,_,post)\r\n    d.id = d.id or d.deviceId\r\n    post({type='device', property='sceneActivationEvent', id=d.id, value={sceneId=d.sceneId}})\r\n  end,\r\n  AccessControlEvent = function(d,_,post)\r\n    post({type='device', property='accessControlEvent', id=d.id, value=d})\r\n  end,\r\n  CustomEvent = function(d,_,post)\r\n    local value = api.get(\"/customEvents/\"..d.name)\r\n    post({type='custom-event', name=d.name, value=value and value.userDescription})\r\n  end,\r\n  PluginChangedViewEvent = function(d,_,post) post({type='PluginChangedViewEvent', value=d}) end,\r\n  WizardStepStateChangedEvent = function(d,_,post) post({type='WizardStepStateChangedEvent', value=d})  end,\r\n  UpdateReadyEvent = function(d,_,post) post({type='updateReadyEvent', value=d}) end,\r\n  DeviceRemovedEvent = function(d,_,post)  post({type='deviceEvent', id=d.id, value='removed'}) end,\r\n  DeviceChangedRoomEvent = function(d,_,post)  post({type='deviceEvent', id=d.id, value='changedRoom'}) end,\r\n  DeviceCreatedEvent = function(d,_,post)  post({type='deviceEvent', id=d.id, value='created'}) end,\r\n  DeviceModifiedEvent = function(d,_,post) post({type='deviceEvent', id=d.id, value='modified'}) end,\r\n  PluginProcessCrashedEvent = function(d,_,post) post({type='deviceEvent', id=d.deviceId, value='crashed', error=d.error}) end,\r\n  SceneStartedEvent = function(d,_,post)   post({type='sceneEvent', id=d.id, value='started'}) end,\r\n  SceneFinishedEvent = function(d,_,post)  post({type='sceneEvent', id=d.id, value='finished'})end,\r\n  SceneRunningInstancesEvent = function(d,_,post) post({type='sceneEvent', id=d.id, value='instance', instance=d}) end,\r\n  SceneRemovedEvent = function(d,_,post)  post({type='sceneEvent', id=d.id, value='removed'}) end,\r\n  SceneModifiedEvent = function(d,_,post)  post({type='sceneEvent', id=d.id, value='modified'}) end,\r\n  SceneCreatedEvent = function(d,_,post)  post({type='sceneEvent', id=d.id, value='created'}) end,\r\n  OnlineStatusUpdatedEvent = function(d,_,post) post({type='onlineEvent', value=d.online}) end,\r\n  ActiveProfileChangedEvent = function(d,_,post)\r\n    post({type='profile',property='activeProfile',value=d.newActiveProfile, old=d.oldActiveProfile})\r\n  end,\r\n  ClimateZoneChangedEvent = function(d,_,post) --ClimateZoneChangedEvent\r\n    if d.changes and type(d.changes)=='table' then\r\n      for _,c in ipairs(d.changes) do\r\n        c.type,c.id='ClimateZone',d.id\r\n        post(c)\r\n      end\r\n    end\r\n  end,\r\n  ClimateZoneSetpointChangedEvent = function(d,_,post) d.type = 'ClimateZoneSetpoint' post(d,_,post) end,\r\n  NotificationCreatedEvent = function(d,_,post) post({type='notification', id=d.id, value='created'}) end,\r\n  NotificationRemovedEvent = function(d,_,post) post({type='notification', id=d.id, value='removed'}) end,\r\n  NotificationUpdatedEvent = function(d,_,post) post({type='notification', id=d.id, value='updated'}) end,\r\n  RoomCreatedEvent = function(d,_,post) post({type='room', id=d.id, value='created'}) end,\r\n  RoomRemovedEvent = function(d,_,post) post({type='room', id=d.id, value='removed'}) end,\r\n  RoomModifiedEvent = function(d,_,post) post({type='room', id=d.id, value='modified'}) end,\r\n  SectionCreatedEvent = function(d,_,post) post({type='section', id=d.id, value='created'}) end,\r\n  SectionRemovedEvent = function(d,_,post) post({type='section', id=d.id, value='removed'}) end,\r\n  SectionModifiedEvent = function(d,_,post) post({type='section', id=d.id, value='modified'}) end,\r\n  QuickAppFilesChangedEvent = function(_) end,\r\n  ZwaveDeviceParametersChangedEvent = function(_) end,\r\n  ZwaveNodeAddedEvent = function(_) end,\r\n  RefreshRequiredEvent = function(_) end,\r\n  DeviceFirmwareUpdateEvent = function(_) end,\r\n  GeofenceEvent = function(d,_,post) post({type='location',id=d.userId,property=d.locationId,value=d.geofenceAction,timestamp=d.timestamp}) end,\r\n  DeviceActionRanEvent = function(d,e,post)\r\n    if e.sourceType=='user' then\r\n      post({type='user',id=e.sourceId,value='action',data=d})\r\n    elseif e.sourceType=='system' then\r\n      post({type='system',value='action',data=d})\r\n    end\r\n  end,\r\n  DeviceNotificationState = function(d,_,post)\r\n    post({type='device', id=d.id, property=d.notificationType, value=d.value})\r\n  end,\r\n}\r\n\r\nlocal refresh = RefreshStateSubscriber()\r\nlocal function filter(ev) return exports.filter(ev) end\r\n\r\nlocal function handler(ev)\r\n  if EventTypes[ev.type] then\r\n    EventTypes[ev.type](ev.data,ev,exports.post)\r\n  end\r\nend\r\nrefresh:subscribe(filter,handler)\r\n\r\nexports.start = function() refresh:run() end\r\nexports.stop = function() refresh:stop() end\r\nexports.filter = function(ev) return true end\r\nexports.post = function(ev)  end\r\n\r\nfibaro._APP = fibaro._APP or {}\r\nfibaro._APP.trigger = exports\r\n\r\n------- lib/RsrcLib.lua ----------\r\nlocal Event = Event_std\r\n\r\nlocal globs = {}\r\nlocal gprops = {\r\n  value = function(t,k) return fibaro.getGlobalVariable(t._gd.name) end\r\n}\r\nlocal GLOBMT = {\r\n  __index = function(t,k)\r\n    if gprops[k] then return gprops[k](t,k)\r\n    else return t._gd[k] end\r\n  end,\r\n  __newindex = function (t, k, v)\r\n    if k=='watch' then\r\n      Event.id='_'\r\n      Event{type='global-variable',name=t._gd.name}\r\n      function Event:handler(event)\r\n        v(self,event.value,event.old,t)\r\n      end\r\n    else t._gd[k]=v end\r\n  end,\r\n  __tostring = function(t) return t._gd.name end\r\n}\r\n--- Create a global variable helper object\r\n-- Provides easy access to global variables with watch capability\r\n-- @param name string Global variable name\r\n-- @return table Global variable object with .value and .watch properties\r\n-- @usage local myVar = GLOB(\"MyVariable\"); myVar.watch = function(self, new, old) ... end\r\nfunction GLOB(name)\r\n  assert(type(name) == 'string', \"GLOB expects variable name as string\")\r\n  if globs[name] then return globs[name] end\r\n  local gd = { name = name }\r\n  local g = setmetatable({_gd = gd},GLOBMT)\r\n  globs[name] = g\r\n  return g\r\nend\r\n\r\nlocal devs = {}\r\nlocal DEVMT = {\r\n  __index = function(t,k)\r\n    return t._dd.rsrc[k] or t._dd.rsrc.properties[k]\r\n  end,\r\n  __newindex = function (t, k, v)\r\n    local p = k:match('watch_(%w+)')\r\n    if p then\r\n      Event.id='_'\r\n      Event{type='device',id=t._dd.id,property=p}\r\n      function Event:handler(event)\r\n        v(self,event,t)\r\n      end\r\n    else t._dd[k]=v end\r\n  end,\r\n  __tostring = function(t) return t._dd.name end\r\n}\r\n--- Create a device helper object\r\n-- Provides easy access to device properties with watch capability\r\n-- @param id number Device ID\r\n-- @return table Device object with property accessors and watch_<property> methods\r\n-- @usage local light = DEV(123); light.watch_value = function(self, event) ... end\r\nfunction DEV(id)\r\n  assert(type(id) == 'number', \"DEV expects device ID as number\")\r\n  if devs[id] then return devs[id] end\r\n  local dd = { id = id, rsrc = api.get(\"/devices/\"..id) }\r\n  assert(dd.rsrc,fmt(\"Device %d not found in HC3\", id))\r\n  local d = setmetatable({_dd = dd},DEVMT)\r\n  devs[id] = d\r\n  return d\r\nend"}]}